---
// 404 handler. Astro emits this as dist/404.html, which Vercel serves (with a
// real HTTP 404) for any URL that matches neither a static route nor a
// vercel.json redirect rule. Per request, every unmatched URL is sent to the
// Peptide Therapy hub (/peptides/).
//
// Why the redirect lives here and not in vercel.json: Vercel's static output
// has no way to issue a server-side 301/308 for *arbitrary* unknown paths —
// redirect rules in vercel.json are evaluated before the filesystem, so a
// catch-all `/(.*)` there would also hijack every real page (and loop on
// /peptides/ itself). Instead the redirect is performed from the 404 document:
// the HTTP response keeps its honest 404 status for crawlers, while browsers
// are bounced immediately to /peptides/ via meta-refresh + a JS replace, with a
// plain link as the no-JS / no-meta fallback.
const DEST = "/peptides/";
const CANONICAL = "https://www.stronghealth.com/404/";
const DESCRIPTION =
  "The page you requested could not be found and has moved. Redirecting you to the Strong Health peptide therapy hub for guides, protocols, and clinics.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={CANONICAL} />
    <title>Redirecting… | Strong Health</title>
    <meta name="description" content={DESCRIPTION} />
    <script is:inline>
      window.location.replace("/peptides/");
    </script>
  </head>
  <body>
    <main style="font-family: system-ui, sans-serif; max-width: 40rem; margin: 4rem auto; padding: 0 1.5rem;">
      <h1>Page moved</h1>
      <p>
        The page you were looking for doesn't exist. If you're not redirected
        automatically, <a href={DEST}>continue to Strong Health peptide therapy →</a>.
      </p>
    </main>
  </body>
</html>
