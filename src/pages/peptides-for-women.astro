import body from "../content/fragments/peptides-for-women.html?raw";

const path = "/peptides-for-women/";
const { author, reviewer } = ARTICLE_AUTHORSHIP[path]!;

const faqs = [
  {
    question: "Are peptides safe for women?",
    answer:
      "It depends entirely on which peptide. FDA-approved peptide drugs have known safety profiles established in trials that included women. Unapproved research chemicals have no safety profile in women at all, and no reproductive toxicity data. The category label tells you nothing useful — the specific compound and your life stage are what determine risk.",
  },
  {
    question: "Can I take peptides while trying to conceive?",
    answer:
      "For GLP-1 medications, labeling recommends discontinuing at least two months before a planned pregnancy. For unapproved peptides, there is no safety data in pregnancy, so the appropriate answer is no. Always discuss preconception planning with your OB-GYN before starting or stopping any peptide.",
  },
  {
    question: "Do peptides affect birth control?",
    answer:
      "Tirzepatide reduces oral contraceptive absorption, and the label recommends backup or non-oral contraception for four weeks after starting and after each dose increase. Semaglutide and liraglutide do not appear to have a clinically meaningful effect. Non-oral methods — IUDs, implants, injections, patches, and rings — are unaffected.",
  },
  {
    question: "Is BPC-157 legal in 2026?",
    answer:
      "It was removed from FDA Category 2 in April 2026, but that did not authorize compounding. It went before the Pharmacy Compounding Advisory Committee on July 23, 2026, and any legal compounding pathway would still require FDA acceptance and rulemaking after that. Check the current status before relying on any claim about its legality.",
  },
  {
    question: "Do peptides help with menopause symptoms?",
    answer:
      "No peptide is FDA-approved for vasomotor symptoms. Oral collagen peptides have modest evidence for skin and mixed evidence for bone in menopausal women. For hot flashes, night sweats, and genitourinary symptoms, hormone therapy and approved non-hormonal options have far better evidence.",
  },
  {
    question: "Will peptides help me lose weight?",
    answer:
      "GLP-1 and dual agonist medications such as semaglutide and tirzepatide have strong trial evidence for weight loss. Growth hormone secretagogues marketed for fat loss do not have comparable evidence in healthy women, and rapid weight loss also costs lean mass and bone density, which matters more after menopause.",
  },
];

