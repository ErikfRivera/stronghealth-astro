---
/**
 * Port of src/pages/local/CityPeptidePage.tsx — config-driven local peptide
 * therapy page (Miami, Delray Beach, New York, …). Wrapper pages under
 * src/pages/{statePrefix}/{slug}/peptide-therapy.astro pass a CityPeptideConfig;
 * statePrefix defaults to "fl" (US-N1).
 */
import BaseLayout from "../BaseLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import {
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../components/seo/schemas";
import PageShell from "../../components/shared/PageShell.astro";
import FadeIn from "../../components/shared/FadeIn.astro";
import Btn from "../../components/shared/Btn.astro";
import Tag from "../../components/shared/Tag.astro";
import Icon from "../../components/shared/Icon.astro";
import FAQSection from "../../components/shared/FAQSection.astro";
import LocalProofSection from "../../components/local/LocalProofSection.astro";
import ReferencesSection from "../../components/local/ReferencesSection.astro";
import {
  ALL_PEPTIDE_CITIES,
  type CityPeptideConfig,
} from "../../data/local/cityPeptideConfig";
import {
  defaultReviewLinks,
  defaultRelatedInternalLinks,
  defaultPhysicianAvailability,
  DEFAULT_APPOINTMENT_EXPECTATIONS,
  DEFAULT_PEPTIDE_CITATIONS,
  type LocalProofData,
} from "../../data/local/cityLocalProof";

const SITE_URL = "https://www.stronghealth.com";

const PEPTIDE_CATEGORIES = [
  {
    icon: "shield-check",
    name: "Healing & Recovery",
    peptides: "BPC-157, TB-500",
    description:
      "Tissue-repair peptides used for tendon, ligament, joint, and soft-tissue healing. Common in rotator cuff, knee, Achilles, and chronic overuse injuries.",
    learnMore: { label: "Read the BPC-157 healing guide →", href: "/peptides-for-healing/" },
    secondary: { label: "Tendon repair peptides →", href: "/peptides-for-tendon-repair/" },
  },
  {
    icon: "dumbbell",
    name: "Body Composition & Muscle",
    peptides: "CJC-1295, Ipamorelin",
    description:
      "GH-secretagogue peptides that signal your pituitary to release more of your own growth hormone in its natural pulsatile pattern. Supports lean mass, recovery, and sleep.",
    learnMore: { label: "Peptides for muscle growth →", href: "/peptides-for-muscle-growth/" },
  },
  {
    icon: "activity",
    name: "Visceral Fat Reduction",
    peptides: "Tesamorelin",
    description:
      "Targeted GH-releasing peptide indicated for visceral (belly) fat reduction. Often used in mid-life metabolic patients alongside lifestyle and, when appropriate, GLP-1 weight-loss programs.",
    learnMore: { label: "Peptides for belly fat →", href: "/peptides-for-belly-fat/" },
  },
  {
    icon: "heart",
    name: "Sexual Health",
    peptides: "PT-141 (Bremelanotide)",
    description:
      "Neurologically-targeted peptide acting on melanocortin receptors to support desire and arousal in both men and women. Distinct from PDE5 inhibitors and works through a different pathway.",
    learnMore: { label: "Peptides for libido →", href: "/peptides-for-libido/" },
  },
  {
    icon: "moon",
    name: "Sleep & Restoration",
    peptides: "DSIP (Delta Sleep-Inducing Peptide)",
    description:
      "Used to support deep-sleep architecture without sedation. Often combined with GH-secretagogue protocols for patients reporting fragmented sleep or poor recovery.",
    learnMore: { label: "Peptides for sleep →", href: "/peptides-for-sleep/" },
  },
  {
    icon: "sparkles",
    name: "Joint & Connective Tissue",
    peptides: "Collagen Peptides + clinical adjuncts",
    description:
      "Pharmaceutical-grade collagen peptide protocols for joint, skin, and connective-tissue support. Frequently combined with healing peptides during arthritis or post-injury rehabilitation.",
    learnMore: { label: "Collagen peptides guide →", href: "/collagen-peptides/" },
    secondary: { label: "Peptides for arthritis →", href: "/peptides-for-arthritis/" },
  },
];

interface Props {
  config: CityPeptideConfig;
}

const { config } = Astro.props;

/** Split a heading string that may contain <gold>...</gold> markers into renderable parts. */
function parseHeading(html: string): { text: string; gold: boolean }[] {
  return html.split(/(<gold>.*?<\/gold>)/g).map((part) => {
    const m = part.match(/^<gold>([\s\S]*?)<\/gold>$/);
    if (m) return { text: m[1], gold: true };
    return { text: part, gold: false };
  });
}

const introHeadingParts = parseHeading(config.introHeadingHtml);
const whyHeadingParts = parseHeading(config.whyHeadingHtml);

// State-aware routing (US-N1). Florida remains the default. A state without a
// hub page (e.g. /ny/ — intentionally 404) has no destination for its crumb,
// so the state level is omitted from the breadcrumb trail rather than emitted
// as an unlinked crumb. Every BreadcrumbList ListItem must include an `item`
// URL for valid structured data (Google Search Console flagged the unlinked
// state entry as a "Missing field 'item'" error, since only the final item may
// omit `item`), so the trail is Home → [Florida →] Peptide Therapy. Matches the
// convention already established in CityTRTPage / CityWeightLossPage.
const statePrefix = config.statePrefix ?? "fl";
const stateName = config.stateName ?? "Florida";
const stateAbbr = statePrefix.toUpperCase();
const stateHubPath = statePrefix === "fl" ? "/fl/" : undefined;
const pagePath = `/${statePrefix}/${config.slug}/peptide-therapy/`;
const breadcrumbs = [
  { name: "Home", path: "/" },
  ...(stateHubPath ? [{ name: stateName, path: stateHubPath }] : []),
  { name: "Peptide Therapy", path: pagePath },
];

// Layout-string overrides (US-N1) — defaults reproduce the pre-N1 literals.
// The heading/subtitle fragments render via set:html with the exact whitespace
// the static template used to emit (Astro collapses whitespace differently
// around expressions), keeping existing FL pages byte-identical.
const escapeHtml = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const howItWorksTag =
  config.howItWorksTag ?? `How Peptide Therapy Works at Our ${config.cityName} Clinic`;
const howItWorksHeadingIntro = config.howItWorksHeadingIntro ?? "One in-person visit. Then";
const howItWorksHeadingGold = config.howItWorksHeadingGold ?? "monitored care.";
const howItWorksHeadingHtml = `\n${escapeHtml(howItWorksHeadingIntro)} <span class="text-gold">${escapeHtml(howItWorksHeadingGold)}</span> `;
const physiciansSubtitleSuffix =
  config.physiciansSubtitleSuffix ?? `at our ${config.clinicArea} clinic.`;
const physiciansSubtitleHtml = `\nNo anonymous "providers." You'll know exactly who's designing and monitoring your\n            peptide protocol ${escapeHtml(physiciansSubtitleSuffix)}\n`;
const relatedServicesHeadingIntro =
  config.relatedServicesHeadingIntro ?? `Same ${config.clinicArea} clinic.`;
const relatedServicesHeadingHtml = `\n${escapeHtml(relatedServicesHeadingIntro)} <span class="text-gold">Same physicians.</span> `;

const isPhysicalClinic = config.physicalClinic ?? true;
const tel = config.clinic.phone.replace(/[^\d+]/g, "");

const localProof: LocalProofData = {
  physicalClinic: isPhysicalClinic,
  cityName: config.cityName,
  serviceName: "Peptide Therapy",
  clinic: {
    name: config.clinic.name,
    streetAddress: config.clinic.streetAddress,
    city: config.clinic.city,
    state: config.clinic.state,
    postalCode: config.clinic.postalCode,
    phone: config.clinic.phone,
    hoursDisplay: `${config.clinic.hoursWeekday} · ${config.clinic.hoursSaturday}`,
  },
  parkingTransit: config.parkingTransit ?? `Located in ${config.clinicArea}, ${config.cityName}.`,
  physicianAvailability:
    config.physicianAvailability ??
    defaultPhysicianAvailability(config.physicians[0]?.name),
  appointmentExpectations:
    config.appointmentExpectations ?? DEFAULT_APPOINTMENT_EXPECTATIONS,
  neighborhoodsServed: config.neighborhoods,
  reviewLinks: config.reviewLinks ?? defaultReviewLinks(config.cityName, config.clinic.name),
  relatedInternalLinks:
    config.relatedInternalLinks ??
    defaultRelatedInternalLinks(config.slug, config.cityName, "peptide", statePrefix),
  stateName,
  stateAbbr,
};

const citations = config.outboundCitations ?? DEFAULT_PEPTIDE_CITATIONS;

// Nearby-city cross-links stay within the page's own state (US-N1): FL pages
// keep their Florida-only list, and a state with a single city renders no
// nearby-cities section at all.
const otherCities = ALL_PEPTIDE_CITIES.filter(
  (c) => c.slug !== config.slug && (c.statePrefix ?? "fl") === statePrefix,
);

// Port of the inline MedicalClinicJsonLd component (identical emitted JSON).
const fullAddress = `${config.clinic.streetAddress}, ${config.clinic.city}, ${config.clinic.state} ${config.clinic.postalCode}`;

const openingHoursSpecification: Array<Record<string, unknown>> = [
  {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: config.clinic.hoursWeekdayHours.opens,
    closes: config.clinic.hoursWeekdayHours.closes,
  },
];
if (config.clinic.hoursSaturdayHours) {
  openingHoursSpecification.push({
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Saturday"],
    opens: config.clinic.hoursSaturdayHours.opens,
    closes: config.clinic.hoursSaturdayHours.closes,
  });
}

const medicalClinicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "@id": `${SITE_URL}/#strong-health-${config.slug}`,
  name: config.clinic.name,
  url: `${SITE_URL}${pagePath}`,
  telephone: config.clinic.phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: config.clinic.streetAddress,
    addressLocality: config.clinic.city,
    addressRegion: config.clinic.state,
    postalCode: config.clinic.postalCode,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: config.clinic.lat,
    longitude: config.clinic.lng,
  },
  openingHoursSpecification,
  medicalSpecialty: ["Endocrinology", "PreventiveMedicine"],
  availableService: [
    {
      "@type": "MedicalTherapy",
      name: "Peptide Therapy",
      description: `Physician-supervised peptide therapy in ${config.cityName} including BPC-157, TB-500, CJC-1295, Ipamorelin, Tesamorelin, PT-141, DSIP, and clinical-grade collagen peptides.`,
      medicineSystem: "WesternConventional",
    },
    {
      "@type": "MedicalTherapy",
      name: "Healing & Recovery Peptide Protocols",
      description:
        "BPC-157 and TB-500 protocols for tendon, ligament, joint, and soft-tissue healing.",
    },
    {
      "@type": "MedicalTherapy",
      name: "GH-Secretagogue Peptide Protocols",
      description:
        "CJC-1295, Ipamorelin, and Tesamorelin protocols for body composition, recovery, and visceral fat reduction.",
    },
    {
      "@type": "MedicalTherapy",
      name: "Sexual Health Peptide Therapy (PT-141)",
      description:
        "PT-141 (Bremelanotide) prescribed for desire and arousal under physician supervision.",
    },
    {
      "@type": "MedicalTherapy",
      name: "Sleep Architecture Peptide Therapy (DSIP)",
      description:
        "DSIP protocols to support deep-sleep architecture in patients with poor recovery.",
    },
    {
      "@type": "MedicalTest",
      name: "Comprehensive Hormone & Metabolic Panel",
      description:
        "On-site biomarker lab panel including testosterone, estradiol, IGF-1, glucose, and metabolic markers used for peptide protocol design and monitoring.",
    },
  ],
  areaServed: [
    { "@type": "City", name: config.cityName },
    { "@type": "AdministrativeArea", name: config.county },
  ],
  hasMap: `https://maps.google.com/maps?q=${encodeURIComponent(`${config.clinic.name}, ${fullAddress}`)}`,
  isAcceptingNewPatients: true,
  currenciesAccepted: "USD",
  paymentAccepted: "Cash, Credit Card, Debit Card",
  parentOrganization: { "@id": `${SITE_URL}/#organization` },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: config.reviewRating,
    reviewCount: String(config.aggregateReviewCount),
  },
  priceRange: "$",
};
---

<BaseLayout title={config.seoTitle} description={config.seoDescription} path={pagePath}>
  <PageShell>
    <JsonLd
      schema={medicalWebPageSchema({
        name: config.jsonLdPageName,
        description: config.jsonLdPageDescription,
        url: pagePath,
        lastReviewed: config.lastReviewed,
        reviewedBy: {
          name: config.reviewedByName,
          credentials: "Board-Certified",
          role: config.reviewedByRole,
        },
      })}
    />
    {isPhysicalClinic && <JsonLd schema={medicalClinicSchema} />}
    <JsonLd schema={faqPageSchema(config.faqs)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {
            breadcrumbs.map((crumb, i) => (
              <li class="flex items-center gap-1.5">
                {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
                {i < breadcrumbs.length - 1 && crumb.path ? (
                  <a href={crumb.path} class="hover:text-gold transition-colors">
                    {crumb.name}
                  </a>
                ) : (
                  <span class={i === breadcrumbs.length - 1 ? "text-gold font-semibold" : ""}>
                    {crumb.name}
                  </span>
                )}
              </li>
            ))
          }
        </ol>
      </div>
    </nav>

    {/* Hero */}
    <section class="relative px-8 pt-12 pb-20 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#818CF8]/15 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">{config.reviewRating}</span>
          <span class="text-[13px] text-muted">{config.reviewCount}</span>
        </div>
        <Tag>{config.heroTag}</Tag>
        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[820px] tracking-[-1.5px]">
          {"Peptide Therapy in "}<span class="text-gold">{`${config.cityName}, ${stateAbbr}.`}</span>
        </h1>
        <p class="text-[18px] text-cream-muted leading-relaxed max-w-[680px] mb-3">
          {config.heroDescription1}
        </p>
        <p class="text-[15px] text-muted leading-relaxed max-w-[640px] mb-8">
          {config.heroDescription2}
        </p>
        <Btn trackLead>Book Your Free {config.cityName} Assessment →</Btn>
        <div class="mt-4 text-xs text-muted">
          {config.heroCtaMeta}
        </div>
      </div>
    </section>

    {/* Clinic card */}
    {
      isPhysicalClinic && (
        <section class="px-8 py-12 bg-surface border-b border-white/5">
          <div class="max-w-[1000px] mx-auto">
            <FadeIn>
              <div class="bg-surface-card rounded-2xl p-7 border border-white/10 grid md:grid-cols-3 gap-6">
                <div>
                  <div class="text-[12px] font-bold uppercase tracking-[0.08em] text-gold mb-2">
                    {config.clinic.name}
                  </div>
                  <div class="text-[15px] text-cream font-semibold leading-snug flex items-start gap-2">
                    <Icon name="map-pin" size={16} class="text-gold flex-shrink-0 mt-0.5" />
                    <span>{config.clinic.streetAddress}<br />{config.clinic.city}, {config.clinic.state} {config.clinic.postalCode}</span>
                  </div>
                </div>
                <div>
                  <div class="text-[12px] font-bold uppercase tracking-[0.08em] text-gold mb-2">
                    Phone
                  </div>
                  <a
                    href={`tel:${tel}`}
                    class="text-[15px] text-cream font-semibold flex items-center gap-2 hover:text-gold transition-colors"
                  >
                    <Icon name="phone" size={16} class="text-gold" />
                    {config.clinic.phone}
                  </a>
                </div>
                <div>
                  <div class="text-[12px] font-bold uppercase tracking-[0.08em] text-gold mb-2">
                    Hours
                  </div>
                  <div class="text-[14px] text-cream font-semibold flex items-start gap-2">
                    <Icon name="clock" size={16} class="text-gold flex-shrink-0 mt-0.5" />
                    <span>{config.clinic.hoursWeekday}<br />{config.clinic.hoursSaturday}</span>
                  </div>
                </div>
              </div>
              <div class="mt-6 rounded-2xl overflow-hidden border border-white/10">
                <iframe
                  title={`Map to ${config.clinic.name}`}
                  src={`https://maps.google.com/maps?q=${encodeURIComponent(
                    `${config.clinic.name}, ${config.clinic.streetAddress}, ${config.clinic.city}, ${config.clinic.state} ${config.clinic.postalCode}`,
                  )}&output=embed`}
                  width="100%"
                  height="320"
                  style="border:0;"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              </div>
            </FadeIn>
          </div>
        </section>
      )
    }

    {/* Intro */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[820px] mx-auto">
        <FadeIn>
          <Tag>Real Medicine. Pharmacy-Grade Peptides.</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-6 leading-[1.15]">
            {introHeadingParts.map((part) => (part.gold ? <span class="text-gold">{part.text}</span> : <span>{part.text}</span>))}
          </h2>
        </FadeIn>
        <FadeIn delay={100}>
          <div class="text-[16px] text-muted leading-[1.8] flex flex-col gap-4">
            {config.introParagraphs.map((p) => <p>{p}</p>)}
          </div>
        </FadeIn>
      </div>
    </section>

    {/* Peptide protocols */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Protocols We Prescribe in {config.cityName}</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Peptide therapy, organized by <span class="text-gold">what you want to fix</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[600px] mx-auto">
            The peptides Strong Health {config.cityName} physicians prescribe most. Each protocol is
            individualized to your labs, goals, and any contraindications.
          </p>
        </FadeIn>
        <div class="grid md:grid-cols-2 gap-5">
          {
            PEPTIDE_CATEGORIES.map((cat, i) => (
              <FadeIn delay={i * 60}>
                <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-lg bg-[#818CF8]/15 flex items-center justify-center flex-shrink-0">
                      <Icon name={cat.icon} size={18} class="text-[#818CF8]" />
                    </div>
                    <div>
                      <h3 class="text-[17px] font-bold text-cream leading-tight">{cat.name}</h3>
                      <div class="text-[12px] font-semibold text-gold mt-0.5">{cat.peptides}</div>
                    </div>
                  </div>
                  <p class="text-[14px] text-muted leading-relaxed flex-grow mb-4">
                    {cat.description}
                  </p>
                  <div class="flex flex-col gap-1.5 pt-3 border-t border-white/5">
                    <a href={cat.learnMore.href} class="text-[12px] font-semibold text-gold hover:underline">
                      {cat.learnMore.label}
                    </a>
                    {cat.secondary && (
                      <a href={cat.secondary.href} class="text-[12px] font-semibold text-gold hover:underline">
                        {cat.secondary.label}
                      </a>
                    )}
                  </div>
                </div>
              </FadeIn>
            ))
          }
        </div>
        <FadeIn delay={400}>
          <div class="mt-8 text-center">
            <a
              href="/peptides/"
              class="text-[13px] font-semibold text-gold hover:underline"
            >
              Browse the full Strong Health peptide therapy library →
            </a>
          </div>
        </FadeIn>
      </div>
    </section>

    {/* How it works */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>{howItWorksTag}</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3" set:html={howItWorksHeadingHtml} />
        </FadeIn>
        <div class="grid md:grid-cols-2 gap-5">
          {
            config.steps.map((s, i) => (
              <FadeIn delay={i * 80}>
                <div class="bg-surface-raised rounded-2xl p-6 border border-white/10 h-full">
                  <div class="text-[12px] font-bold text-gold mb-2">STEP {i + 1}</div>
                  <h3 class="text-lg font-bold text-cream mb-2">{s.title}</h3>
                  <p class="text-[14px] text-muted leading-relaxed">{s.desc}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* Local physicians */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Your {config.cityName} Peptide Physicians</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Named doctors. <span class="text-gold">Real credentials.</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[520px] mx-auto" set:html={physiciansSubtitleHtml} />
        </FadeIn>
        <div class="grid md:grid-cols-3 gap-5">
          {
            config.physicians.map((doc, i) => (
              <FadeIn delay={i * 150}>
                <div class="bg-surface-raised rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#C9A84C]/20 to-[#1A1F2A] border border-white/10 flex items-center justify-center mb-4">
                    <Icon name="user-check" size={28} class="text-gold" />
                  </div>
                  <h3 class="text-lg font-bold text-cream mb-1">{doc.name}</h3>
                  <div class="text-[11px] font-bold text-gold tracking-wider uppercase mb-3">
                    {doc.title}
                  </div>
                  <p class="text-[12px] text-muted leading-relaxed mb-3 border-b border-white/5 pb-3">
                    {doc.credentials}
                  </p>
                  <p class="text-[13px] text-cream-muted leading-relaxed flex-grow">
                    {doc.focus}
                  </p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* Why Strong Health */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <FadeIn>
            <Tag>Why Strong Health {config.cityName}</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              {whyHeadingParts.map((part) => (part.gold ? <span class="text-gold">{part.text}</span> : <span>{part.text}</span>))}
            </h2>
            <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
              {config.whyParagraphs.map((p) => <p>{p}</p>)}
            </div>
          </FadeIn>
          <FadeIn delay={200}>
            <div class="bg-surface-card rounded-2xl p-8 border border-white/10">
              <h3 class="text-lg font-bold text-cream mb-5 flex items-center gap-2">
                <Icon name="flask-conical" size={18} class="text-gold" />
                The Strong Health {config.cityName} standard
              </h3>
              <div class="text-[14px] text-cream-muted leading-[1.7] flex flex-col gap-3">
                {
                  config.whyStandardBullets.map((item) => (
                    <div class="flex items-start gap-3">
                      <span class="text-gold font-bold">·</span>
                      <span>{item}</span>
                    </div>
                  ))
                }
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <LocalProofSection data={localProof} />

    {/* Neighborhoods served */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Areas We Serve</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Peptide therapy across <span class="text-gold">{config.neighborhoodAreaName}</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            {config.neighborhoodsSubtitle}
          </p>
        </FadeIn>
        <FadeIn delay={200}>
          <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 gap-3">
            {
              config.neighborhoods.map((n) => (
                <div class="bg-surface-card rounded-lg px-4 py-3 border border-white/10 text-center hover:border-gold/30 transition-colors">
                  <span class="text-[13px] font-medium text-cream-muted">{n}</span>
                </div>
              ))
            }
          </div>
        </FadeIn>
      </div>
    </section>

    {/* Related services */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Other Strong Health {config.cityName} Services</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3" set:html={relatedServicesHeadingHtml} />
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            {config.relatedServicesSubtitle}
          </p>
        </FadeIn>
        <div class="grid md:grid-cols-3 gap-5">
          {
            config.relatedServices.map((s, i) => (
              <FadeIn delay={i * 80}>
                <div class="bg-surface-raised rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <h3 class="text-lg font-bold text-cream mb-3">{s.name}</h3>
                  <p class="text-[14px] text-muted leading-relaxed flex-grow mb-4">{s.desc}</p>
                  <a href={s.href} class="text-[13px] font-semibold text-gold hover:underline">
                    {s.cta}
                  </a>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* Nearby peptide cities */}
    {
      otherCities.length > 0 && (
        <section class="px-8 py-16 bg-surface border-b border-white/5">
          <div class="max-w-[1000px] mx-auto">
            <FadeIn class="text-center mb-8">
              <Tag>Strong Health Peptide Clinics Across {stateName}</Tag>
              <h2 class="text-[28px] font-extrabold text-cream mt-4 mb-3">
                Peptide therapy in <span class="text-gold">other {stateName} cities</span>
              </h2>
            </FadeIn>
            <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
              {otherCities.map((c) => (
                <a
                  href={`/${statePrefix}/${c.slug}/peptide-therapy/`}
                  class="bg-surface-card rounded-xl p-4 border border-white/10 hover:border-gold/40 transition-colors flex items-center justify-between"
                >
                  <span class="text-[14px] font-semibold text-cream">
                    Peptide Therapy in {c.cityName}
                  </span>
                  <Icon name="chevron-right" size={14} class="text-gold flex-shrink-0" />
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {/* FAQ */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[800px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>{config.cityName} Peptide Therapy FAQ</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Common questions about <span class="text-gold">peptide therapy in {config.cityName}</span>
          </h2>
        </FadeIn>
        <FAQSection items={config.faqs} />
      </div>
    </section>

    <ReferencesSection citations={citations} />

    {/* Final CTA */}
    <section class="px-8 py-24 bg-gradient-to-br from-[#818CF8]/[0.08] to-[#0D0F12] border-b border-white/5">
      <div class="max-w-[700px] mx-auto text-center">
        <FadeIn>
          <h2 class="text-[36px] font-black text-cream leading-[1.1] mb-4">
            {config.finalCtaHeading}
          </h2>
          <p class="text-[17px] text-muted leading-relaxed mb-8 max-w-[520px] mx-auto">
            {config.finalCtaCopy}
          </p>
          <div class="flex items-center justify-center gap-2 mb-6 text-[13px] text-muted">
            <Icon name="phone" size={14} class="text-gold" />
            <a href={`tel:${tel}`} class="hover:text-gold">
              Or call {config.clinic.phone}
            </a>
          </div>
          <Btn trackLead>Book Your Free Assessment →</Btn>
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
