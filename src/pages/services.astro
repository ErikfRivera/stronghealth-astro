---
// /services/ hub — port of src/pages/Services.tsx (11-card services grid).
import BaseLayout from "../layouts/BaseLayout.astro";
import PageShell from "../components/shared/PageShell.astro";
import FadeIn from "../components/shared/FadeIn.astro";
import Tag from "../components/shared/Tag.astro";
import Btn from "../components/shared/Btn.astro";
import Icon from "../components/shared/Icon.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import { breadcrumbSchema, medicalWebPageSchema } from "../components/seo/schemas";

const services = [
  {
    icon: "syringe",
    title: "Testosterone Replacement Therapy",
    tag: "Core Service",
    desc: "Our anchor service — comprehensive diagnostic workup, custom treatment protocol design, and ongoing management. Injectable testosterone cypionate/enanthate, topical gels/creams, or subcutaneous pellets. Includes estrogen management, fertility preservation options, and lab-driven dosing optimization.",
    color: "#C9A84C",
  },
  {
    icon: "microscope",
    title: "Comprehensive Lab Testing",
    tag: "Diagnostics",
    desc: "Far beyond what your PCP orders. Our baseline panel covers 40+ biomarkers: total and free testosterone, estradiol (sensitive assay), SHBG, LH, FSH, prolactin, complete metabolic panel, CBC, lipids, fasting insulin, HbA1c, thyroid panel, PSA, DHEA-S, cortisol, vitamin D, B12, and iron/ferritin.",
    color: "#5DADE2",
  },
  {
    icon: "heart",
    title: "Sexual Health",
    tag: "Performance",
    desc: "ED treatment with PDE5 inhibitors (tadalafil, sildenafil), PT-141 for libido, penile injection therapy for refractory ED, and performance optimization protocols that integrate with your hormone plan. Comprehensive solutions — not just a prescription.",
    color: "#EF4444",
  },
  {
    icon: "scale",
    title: "Weight Management",
    tag: "Metabolic",
    desc: "Medical weight loss aligned with your hormonal profile. GLP-1 receptor agonist evaluation (semaglutide, tirzepatide), body composition analysis, metabolic rate testing, and nutritional guidance. The integration with TRT is the differentiator — optimizing testosterone alongside metabolic health.",
    color: "#34D399",
  },
  {
    icon: "activity",
    title: "Thyroid Optimization",
    tag: "Endocrine",
    desc: "Many men have subclinical thyroid issues that fall within 'normal' lab ranges but produce real symptoms. We run comprehensive thyroid panels (not just TSH), prescribe thyroid hormone replacement when indicated, and monitor thyroid function alongside your TRT protocol.",
    color: "#D4B96A",
  },
  {
    icon: "shield-check",
    title: "Preventive Health & Cardiovascular Risk",
    tag: "Prevention",
    desc: "Proactive screening beyond hormones: advanced lipid panels (ApoB, Lp(a)), coronary calcium scoring referrals, metabolic syndrome identification, blood pressure monitoring, hematocrit management, liver health monitoring, and PSA tracking with urology referrals when appropriate.",
    color: "#8B5CF6",
  },
  {
    icon: "test-tubes",
    title: "Peptide Therapy",
    tag: "Recovery & Performance",
    desc: "BPC-157 for injury recovery and gut health, CJC-1295/Ipamorelin growth hormone secretagogue stacks, sermorelin, tesamorelin for visceral fat reduction, and AOD-9604. All protocols current with FDA guidance and physician-supervised.",
    color: "#F97316",
  },
  {
    icon: "pill",
    title: "Supplement & Nutraceutical Protocols",
    tag: "Optimization",
    desc: "Evidence-based supplementation tailored to your lab findings — vitamin D3, magnesium, zinc, boron, omega-3s, ashwagandha, tongkat ali, and DIM for estrogen metabolism. No guesswork, no proprietary blends — just what your bloodwork says you need.",
    color: "#06B6D4",
  },
  {
    icon: "moon",
    title: "Sleep Optimization",
    tag: "Recovery",
    desc: "Sleep apnea screening (both a cause and consequence of low testosterone), referrals for sleep studies, pharmaceutical sleep support where appropriate, and sleep hygiene coaching. Poor sleep tanks testosterone — we address the root cause.",
    color: "#6366F1",
  },
  {
    icon: "brain",
    title: "Mental Health & Cognitive Performance",
    tag: "Cognitive",
    desc: "Screening for depression and anxiety that overlaps with low-T symptoms, cognitive performance optimization, and referral pathways to psychiatric care when needed. Brain fog and focus issues often resolve when hormones are optimized.",
    color: "#EC4899",
  },
  {
    icon: "smartphone",
    title: "Ongoing Monitoring & Telehealth",
    tag: "Convenience",
    desc: "Scheduled telehealth check-ins, lab review consultations, dosage adjustments, prescription refill management, secure messaging with your care team, and patient portal access. In-person visits remain available anytime — it's your call.",
    color: "#14B8A6",
  },
];

const reasons = [
  "One physician team that knows your full history — hormones, metabolics, and risk factors",
  "Lab results cross-referenced across all service lines for comprehensive optimization",
  "No referral runaround — every service under one roof with coordinated protocols",
  "Telehealth convenience for ongoing management after in-person baselines",
  "Month-to-month treatment, no contracts — stay because results speak for themselves",
];
---

<BaseLayout
  title="Men's Health Services"
  description="Testosterone therapy, comprehensive lab testing, sexual health, weight management, peptide therapy, and more. All physician-supervised, all under one roof."
  path="/services/"
>
  <PageShell>
    <JsonLd
      schema={breadcrumbSchema([
        { name: "Home", path: "/" },
        { name: "Services", path: "/services/" },
      ])}
    />
    <JsonLd
      schema={medicalWebPageSchema({
        name: "Physician-Supervised Men's Health Services",
        description:
          "Testosterone therapy, comprehensive lab testing, sexual health, weight management, peptide therapy, and more. All physician-supervised, all under one roof.",
        url: "/services/",
      })}
    />

    {/* Hero */}
    <section class="relative px-6 md:px-8 pt-10 md:pt-20 pb-14 md:pb-20 overflow-hidden border-b border-white/5">
      <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-[1000px] mx-auto relative z-10">
        <FadeIn>
          <Tag>Full-Spectrum Men's Health</Tag>
        </FadeIn>

        <FadeIn delay={100}>
          <h1 class="text-[34px] md:text-[52px] font-black text-cream leading-[1.08] mt-5 mb-5 max-w-[720px] tracking-[-1.5px]">
            Men's Health Services. <span class="text-gold">One clinic. One team.</span>
          </h1>
        </FadeIn>

        <FadeIn delay={200}>
          <p class="text-[17px] text-muted leading-relaxed max-w-[560px] mb-8">
            Testosterone therapy is our foundation — but real optimization means treating the whole picture.
            Hormones, metabolics, sexual health, sleep, and prevention, all under physician supervision.
          </p>
        </FadeIn>

        <FadeIn delay={300}>
          <div class="flex flex-wrap gap-3.5 items-center">
            <Btn trackLead>Book Your Free Assessment →</Btn>
          </div>
          <div class="mt-4 text-xs text-muted">
            No commitment · No insurance needed · All services physician-supervised
          </div>
        </FadeIn>
      </div>
    </section>

    {/* Service Grid */}
    <section class="px-6 md:px-8 py-16 md:py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1100px] mx-auto">
        <FadeIn class="text-center mb-12">
          <Tag>Our Services</Tag>
          <h2 class="text-[32px] md:text-[38px] font-extrabold text-cream mt-4 mb-3">
            Built around <span class="text-gold">your biology</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            Every protocol is designed by board-certified physicians and tailored to your lab results — not a one-size-fits-all template.
          </p>
        </FadeIn>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            services.map((service, i) => (
              <FadeIn delay={i * 60}>
                <div class="bg-surface-card rounded-2xl p-7 border border-white/10 h-full flex flex-col hover:border-white/20 transition-all duration-300 group">
                  <div
                    class="w-14 h-14 rounded-xl flex items-center justify-center mb-5 border border-white/5 shrink-0"
                    style={`background-color: ${service.color}15`}
                  >
                    <div style={`color: ${service.color}`}>
                      <Icon name={service.icon} size={28} />
                    </div>
                  </div>
                  <div class="flex items-center gap-2 mb-3">
                    <h3 class="text-[17px] font-bold text-cream leading-snug">{service.title}</h3>
                  </div>
                  <span
                    class="inline-block text-[9px] font-bold tracking-[1.5px] uppercase px-2 py-1 rounded mb-4 w-fit"
                    style={`color: ${service.color}; background-color: ${service.color}15`}
                  >
                    {service.tag}
                  </span>
                  <p class="text-[13px] text-muted leading-[1.7] flex-grow">{service.desc}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* Why One Clinic */}
    <section class="px-6 md:px-8 py-16 md:py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <FadeIn>
            <Tag>The Integrated Advantage</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-5">
              Why everything works better <span class="text-gold">under one roof</span>
            </h2>
            <p class="text-[15px] text-muted leading-[1.7]">
              Most men see a PCP for bloodwork, a urologist for ED, a weight loss clinic for GLP-1s,
              and a telehealth mill for testosterone — none of them talking to each other.
              We built Strong Health to end that fragmentation.
            </p>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-raised rounded-2xl p-8 border border-white/10">
              <div class="flex flex-col gap-4">
                {
                  reasons.map((reason) => (
                    <div class="flex items-start gap-3">
                      <div class="w-5 h-5 rounded-full bg-[#34D399]/10 flex items-center justify-center shrink-0 mt-0.5">
                        {/* Check icon with strokeWidth={3} — inlined because Icon.astro hardcodes stroke-width="2" */}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width={11}
                          height={11}
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="3"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-check text-[#34D399]"
                          aria-hidden="true"
                        ><path d="M20 6 9 17l-5-5"></path></svg>
                      </div>
                      <span class="text-[14px] text-cream-muted leading-[1.5]">{reason}</span>
                    </div>
                  ))
                }
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* Final CTA */}
    <section class="px-6 md:px-8 py-20 md:py-24 bg-gradient-to-br from-[#C9A84C]/[0.15] via-[#0D0F12] to-[#1B4F72]/[0.15] border-b border-white/5 relative overflow-hidden">
      <div class="max-w-[700px] mx-auto text-center relative z-10">
        <FadeIn>
          <Tag>Start Here</Tag>
          <h2 class="text-[32px] md:text-[40px] font-black text-cream mt-5 mb-5 leading-[1.1]">
            Your first step is a <span class="text-gold">free assessment</span>
          </h2>
          <p class="text-[16px] text-muted leading-relaxed mb-8 max-w-[500px] mx-auto">
            Walk in. Meet your physician. Get your labs drawn on-site. We'll tell you exactly
            what's going on — and what we can do about it.
          </p>
          <Btn trackLead>Book Your Free Assessment →</Btn>
          <div class="mt-4 text-xs text-muted">
            No commitment · No insurance needed · 15–20 min in-person visit
          </div>
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
