---
// /fl/ — Florida peptide-therapy hub. Peptides are the sole service theme:
// in-person care at the Miami (Brickell) clinic, telehealth service areas for
// the other Florida metros. Legacy Brickell-clinic services (PRP, DEXA, stem
// cell) remain reachable here but are deliberately de-emphasized.
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageShell from "../../components/shared/PageShell.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import {
  breadcrumbSchema,
  collectionPageSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../components/seo/schemas";
import FadeIn from "../../components/shared/FadeIn.astro";
import Btn from "../../components/shared/Btn.astro";
import Tag from "../../components/shared/Tag.astro";
import Icon from "../../components/shared/Icon.astro";
import { ALL_PEPTIDE_CITIES } from "../../data/local/cityPeptideConfig";

const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Florida", path: "/fl/" },
];

const flCities = ALL_PEPTIDE_CITIES.filter((c) => (c.statePrefix ?? "fl") === "fl").map(
  (c) => ({
    slug: c.slug,
    cityName: c.cityName,
    clinicArea: c.clinicArea,
    inPerson: c.physicalClinic !== false,
    href: `/fl/${c.slug}/peptide-therapy/`,
  }),
);

const services = [
  {
    name: "Peptide Therapy",
    desc: "Physician-supervised peptide protocols for healing, body composition, sleep, libido, and longevity — pharmacy-compounded under 503A/503B standards with labs and ongoing monitoring.",
    href: "/peptides/",
    cta: "Browse peptide therapies by goal →",
  },
  {
    name: "Healing & Recovery Protocols",
    desc: "BPC-157 and TB-500 protocols for tendon, ligament, joint, and soft-tissue recovery, designed around your labs and injury history.",
    href: "/peptides-for-healing/",
    cta: "Peptides for healing →",
  },
  {
    name: "Body Composition & Metabolic",
    desc: "Tesamorelin, GH-secretagogue, and GLP-1 protocols targeting visceral fat and lean-mass preservation, with full metabolic workups.",
    href: "/peptides-for-belly-fat/",
    cta: "Peptides for belly fat →",
  },
  {
    name: "Comprehensive Lab Testing",
    desc: "Full biomarker panels — hormones, IGF-1, glucose, and metabolic markers — drawn on-site in Brickell and monitored at every protocol review.",
    href: "/about/",
    cta: "How our clinical model works →",
  },
  {
    name: "PRP Therapy (Platelet-Rich Plasma)",
    desc: "Physician-performed PRP for hair restoration, skin rejuvenation, and joint & sports-injury recovery at our Brickell clinic.",
    href: "/fl/miami/prp-therapy/",
    cta: "PRP therapy in Miami →",
  },
  {
    name: "DEXA Scan (Body Composition)",
    desc: "Clinical DEXA body-composition and bone-density analysis at our Brickell clinic — the gold standard for tracking peptide protocol results.",
    href: "/fl/miami/dexascan/",
    cta: "DEXA Scan in Miami →",
  },
  {
    name: "Stem Cell & Regenerative Medicine",
    desc: "Physician-supervised regenerative treatments for arthritis, knee, joint, and tendon pain at our Miami (Brickell) clinic.",
    href: "/fl/miami/stem-cell-therapy/",
    cta: "Stem Cell Therapy in Miami →",
  },
];

const STATEWIDE_FAQS = [
  {
    question: "Where is Strong Health's Florida clinic located?",
    answer:
      "Strong Health's physical clinic is in Miami's Brickell neighborhood at 1000 Brickell Plaza, Miami, FL 33131. Patients across Florida — including Delray Beach and Tampa — are served via telehealth, with the in-person baseline evaluation and on-site lab draw completed at the Brickell clinic.",
  },
  {
    question: "How does peptide therapy work for Florida patients outside Miami?",
    answer:
      "Florida law and our clinical standards require an in-person physician evaluation before starting peptide therapy. That baseline visit — physical exam, medical history, and on-site labs — happens at the Miami (Brickell) clinic. After the baseline, follow-ups, dose adjustments, lab reviews, and renewals are handled via telehealth statewide, with periodic in-person check-ins.",
  },
  {
    question: "Is peptide therapy legal in Florida?",
    answer:
      "Yes, when prescribed by a licensed Florida physician and dispensed through a licensed compounding pharmacy. Strong Health works only with 503A and 503B pharmacies under physician orders — no research-only or gray-market peptides. Every protocol includes physician oversight, ongoing monitoring, and standard Florida medical-record documentation.",
  },
  {
    question: "Is Strong Health's Florida care bilingual?",
    answer:
      "Yes. Our Miami (Brickell) clinic offers bilingual care in English and Spanish, with multiple Spanish-speaking team members including the Medical Director.",
  },
  {
    question: "Does Strong Health accept insurance in Florida?",
    answer:
      "Strong Health operates on a transparent direct-pay model. We do not bill insurance directly, but we provide itemized superbills that many patients submit for partial reimbursement under plans common in Florida, including Florida Blue, Aetna, UnitedHealthcare, and Cigna. The direct-pay model keeps care affordable and free from insurance-driven restrictions on lab work and treatment options.",
  },
  {
    question: "Are Saturday appointments available?",
    answer:
      "Yes. The Miami (Brickell) clinic offers Saturday morning appointments from 9:00 AM to 1:00 PM, in addition to weekday hours from 8:00 AM to 6:00 PM. Saturday hours are designed for working professionals, tradespeople, and shift workers who can't easily make weekday appointments.",
  },
  {
    question: "Is Strong Health open to seasonal residents and snowbirds?",
    answer:
      "Yes. Strong Health serves a large population of seasonal residents who split time between Florida and other states or countries. Telehealth follow-ups travel with you, and we coordinate refills with pharmacies near wherever you happen to be. Initial in-person visits and periodic labs can be scheduled around your time in Florida.",
  },
];

const cityItems = flCities.map((c) => ({
  name: `Strong Health ${c.cityName} — Peptide Therapy`,
  url: c.href,
}));
---

<BaseLayout
  title="Florida Peptide Therapy Clinic & Telehealth"
  description="Physician-supervised peptide therapy across Florida — in-person at our Miami (Brickell) clinic, telehealth for Delray Beach, Tampa, and statewide follow-ups."
  path="/fl/"
>
  <PageShell>
    <JsonLd
      schema={medicalWebPageSchema({
        name: "Strong Health Florida — Peptide Therapy in Miami, Delray Beach, and Tampa",
        description:
          "Physician-supervised peptide therapy at Strong Health's Miami (Brickell) clinic, with telehealth service areas in Delray Beach and Tampa and statewide follow-ups.",
        url: "/fl/",
        lastReviewed: "2026-07-18",
        reviewedBy: {
          name: "Dr. Angel Rivera, M.D.",
          credentials: "Board-Certified",
          role: "Medical Director — Strong Health",
        },
      })}
    />
    <JsonLd
      schema={collectionPageSchema({
        name: "Strong Health Florida Locations",
        description: "Strong Health peptide therapy locations across Florida",
        url: "/fl/",
        items: cityItems,
      })}
    />
    <JsonLd schema={faqPageSchema(STATEWIDE_FAQS)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.path} class="hover:text-gold transition-colors">
                  {crumb.name}
                </a>
              ) : (
                <span class="text-gold font-semibold">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>

    {/* Hero */}
    <section class="relative px-8 pt-12 pb-20 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">4.9</span>
          <span class="text-[13px] text-muted">from 1,000+ Florida patient reviews</span>
        </div>
        <Tag>Strong Health Florida · Peptide Therapy</Tag>
        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[760px] tracking-[-1.5px]">
          Peptide therapy in Florida, <span class="text-gold">done like real medicine.</span>
        </h1>
        <p class="text-[17px] text-muted leading-relaxed max-w-[600px] mb-8">
          Physician-supervised peptide protocols from our Miami (Brickell) clinic, with
          telehealth care for Delray Beach, Tampa, and follow-ups statewide. Labs first,
          protocols second — never the other way around.
        </p>
        <Btn trackLead>Book Your Free Assessment →</Btn>
        <div class="mt-4 text-xs text-muted">
          No commitment · No insurance needed · Free first assessment
        </div>
      </div>
    </section>

    {/* Locations */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Find Your Location</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Peptide therapy across <span class="text-gold">Florida</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            In-person physician visits and on-site labs in Brickell; telehealth visits with
            physician oversight everywhere else. Pick the location closest to you.
          </p>
        </FadeIn>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
          {flCities.map((city) => (
            <FadeIn>
              <div class="bg-surface-raised rounded-xl p-5 border border-white/10 flex flex-col gap-1.5 h-full">
                <div class="text-[15px] font-bold text-cream">
                  {city.cityName}, FL
                </div>
                <div class="flex items-center gap-1.5 text-[12px] text-cream-muted">
                  <Icon name="map-pin" size={11} class="text-gold flex-shrink-0" />
                  <span>
                    {city.inPerson
                      ? `In-person clinic · ${city.clinicArea}`
                      : "Telehealth service area"}
                  </span>
                </div>
                <div class="flex flex-col gap-1.5 mt-2 pt-2 border-t border-white/5">
                  <a
                    href={city.href}
                    class="text-[12px] text-gold font-semibold hover:underline"
                  >
                    {city.cityName} Peptide Therapy →
                  </a>
                  {city.slug === "miami" && (
                    <>
                      <a
                        href="/fl/miami/dexascan/"
                        class="text-[12px] text-gold font-semibold hover:underline"
                      >
                        DEXA Scan →
                      </a>
                      <a
                        href="/fl/miami/prp-therapy/"
                        class="text-[12px] text-gold font-semibold hover:underline"
                      >
                        PRP Therapy →
                      </a>
                    </>
                  )}
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* ServicesOverview */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Physician-Supervised Care</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Real medicine. <span class="text-gold">One standard of care.</span>
          </h2>
        </FadeIn>
        <div class="grid md:grid-cols-2 gap-5">
          {services.map((s, i) => (
            <FadeIn delay={i * 80}>
              <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                <h3 class="text-lg font-bold text-cream mb-3">{s.name}</h3>
                <p class="text-[14px] text-muted leading-relaxed flex-grow mb-4">{s.desc}</p>
                <a href={s.href} class="text-[13px] font-semibold text-gold hover:underline">
                  {s.cta}
                </a>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* WhyFlorida */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <FadeIn>
            <Tag>Built for Florida</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              Why we built Strong Health <span class="text-gold">in South Florida</span>
            </h2>
            <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
              <p>
                Florida has no shortage of med spas and IV lounges willing to sell peptides.
                What it lacked was a physician-led practice that treats peptide therapy as
                real medicine: comprehensive diagnostics, board-certified physicians, and
                ongoing monitoring, on a transparent direct-pay model with no concierge
                membership and no supplement subscription.
              </p>
              <p>
                We built our clinic in Miami's Brickell neighborhood and extended care
                across the state via telehealth, so Delray Beach and Tampa patients get the
                same physician, the same labs, and the same pharmacy-grade compounds without
                driving to Miami for every visit.
              </p>
              <p>
                Every protocol starts with bloodwork and a physical exam — not a sales
                script.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-raised rounded-2xl p-8 border border-white/10">
              <h3 class="text-lg font-bold text-cream mb-5">The Strong Health standard</h3>
              <div class="text-[14px] text-cream-muted leading-[1.7] flex flex-col gap-3">
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Board-certified physicians on every protocol</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Full biomarker lab panel drawn on-site in Brickell</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Real physical exam before any prescription</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>503A/503B pharmacy-compounded peptides. No gray-market vials</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Telehealth follow-ups after your in-person baseline</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Bilingual care (English & Spanish)</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Month-to-month treatment. No long-term contracts</span>
                </div>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* FAQSection */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[800px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Statewide FAQs</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            About Strong Health <span class="text-gold">in Florida</span>
          </h2>
        </FadeIn>
        <div class="flex flex-col gap-4">
          {STATEWIDE_FAQS.map((faq, i) => (
            <FadeIn delay={i * 40}>
              <details class="bg-surface-card rounded-xl border border-white/10 group">
                <summary class="cursor-pointer p-5 list-none flex items-start justify-between gap-4">
                  <h3 class="text-[15px] font-bold text-cream pr-2">{faq.question}</h3>
                  <Icon
                    name="chevron-right"
                    size={18}
                    class="text-gold flex-shrink-0 transition-transform group-open:rotate-90 mt-0.5"
                  />
                </summary>
                <div class="px-5 pb-5 text-[14px] text-muted leading-[1.7]">{faq.answer}</div>
              </details>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* FinalCTA */}
    <section class="px-8 py-24 bg-gradient-to-br from-[#C9A84C]/[0.08] to-[#0D0F12] border-b border-white/5">
      <div class="max-w-[700px] mx-auto text-center">
        <FadeIn>
          <h2 class="text-[36px] font-black text-cream leading-[1.1] mb-4">
            Talk to a Florida physician about peptide therapy
          </h2>
          <p class="text-[17px] text-muted leading-relaxed mb-8 max-w-[520px] mx-auto">
            In-person in Brickell or via telehealth from anywhere in Florida. Book a free
            assessment with a board-certified physician.
          </p>
          <div class="flex items-center justify-center gap-2 mb-6 text-[13px] text-muted">
            <Icon name="phone" size={14} class="text-gold" />
            <span>Or call the clinic directly</span>
          </div>
          <Btn trackLead>Book Your Free Assessment →</Btn>
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
