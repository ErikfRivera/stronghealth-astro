                  <h4 class="text-base font-bold text-cream mb-1">{d.name}</h4>
                  <p class="text-xs text-muted leading-relaxed mb-3 min-h-[36px]">{d.cred}</p>
                  <span class="text-xs font-semibold text-gold flex items-center gap-1">
                    {d.yrs} experience <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </span>
