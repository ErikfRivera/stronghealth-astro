---
// /fl/miami/dexascan/ — port of src/pages/local/MiamiDexaScan.tsx (source monorepo).
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageShell from "../../../components/shared/PageShell.astro";
import JsonLd from "../../../components/seo/JsonLd.astro";
import {
  articleSchema,
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../../components/seo/schemas";
import FadeIn from "../../../components/shared/FadeIn.astro";
import Btn from "../../../components/shared/Btn.astro";
import Tag from "../../../components/shared/Tag.astro";
import Icon from "../../../components/shared/Icon.astro";
import AuthorByline from "../../../components/shared/AuthorByline.astro";
import { MAHADEV_MUKHERJEE, DR_ANGEL_RIVERA } from "../../../data/articleAuthors";
import { MIAMI_BRICKELL_CLINIC, MIAMI_BRICKELL_FULL_ADDRESS } from "../../../data/miamiClinic";

const CLINIC = MIAMI_BRICKELL_CLINIC;
const FULL_ADDRESS = MIAMI_BRICKELL_FULL_ADDRESS;
const PUBLISH_DATE = "2026-05-01";
const MAPS_QUERY = encodeURIComponent(`${CLINIC.name}, ${FULL_ADDRESS}`);

// Normalized per remediation D4: production source used the bare local number;
// SMS URIs must carry the country code to work across devices.
const BOOKING_SMS_NUMBER = "+19546635563";
const BOOKING_SMS_BODY = "I would like to book a Dexascan with Strong Health";
// Use the "?&body=" form so the pre-filled message works on both iOS and Android.
const BOOKING_SMS_HREF = `sms:${BOOKING_SMS_NUMBER}?&body=${encodeURIComponent(
  BOOKING_SMS_BODY,
)}`;

const TEL_HREF = `tel:${CLINIC.phone.replace(/[^\d+]/g, "")}`;

const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Florida", path: "/fl/" },
  { name: "DEXA Scan Miami", path: "/fl/miami/dexascan/" },
];

const FAQS = [
  {
    question: "Where can I get a DEXA scan in Miami?",
    answer:
      "Strong Health offers DEXA scan body composition analysis at our Brickell clinic at 1000 Brickell Plaza, Miami, FL 33131. We're centrally located in the heart of Miami's financial district with validated parking and Metrorail access (Brickell station, 0.3 mi). Walk-ins are welcome and same-week appointments are typically available. Call (754) 263-6026 to book.",
  },
  {
    question: "How much does a DEXA scan cost in Miami?",
    answer:
      "A body composition DEXA scan at our Miami clinic is competitively priced for the South Florida market, with transparent direct-pay pricing and no hidden fees. Most patients pay under $200 per scan, and bundled pricing is available if you plan to track progress with multiple scans over the year. Bone density DEXA scans (for osteoporosis screening) may be covered by insurance for eligible patients.",
  },
  {
    question: "What does a DEXA scan measure?",
    answer:
      "A DEXA (Dual-Energy X-ray Absorptiometry) scan precisely measures three things across your entire body: lean muscle mass (in pounds, broken down by limb and trunk), fat mass (total and visceral), and bone mineral density. It's the clinical gold standard for body composition with a margin of error of roughly 1–2%, far more accurate than BIA scales or skinfold calipers.",
  },
  {
    question: "How long does a DEXA scan take at your Miami clinic?",
    answer:
      "The actual scan takes 10–15 minutes. Plan for about 30 minutes total at our Brickell location, including check-in, the scan itself, and a brief consultation to walk through your results. There are no injections, no enclosed spaces, and the radiation dose is roughly 1/10th of a standard chest X-ray.",
  },
  {
    question: "Do I need a doctor's referral for a DEXA scan in Miami?",
    answer:
      "No referral is needed for a body composition DEXA scan at our Miami clinic. We accept walk-ins and self-pay patients. If you're already a Strong Health patient on a TRT, peptide, or weight loss protocol, your physician can order the scan as part of your treatment plan and review the results with you at your next visit.",
  },
  {
    question: "How should I prepare for my DEXA scan?",
    answer:
      "Wear comfortable clothing without metal (no zippers, underwire bras, or metal buttons). Avoid eating a large meal within 2 hours of the scan, hydrate normally, skip calcium supplements for 24 hours, and avoid intense exercise the night before. Consistency between scans matters more than perfect prep — try to repeat the same conditions for follow-up scans.",
  },
  {
    question: "How often should I get a DEXA scan?",
    answer:
      "For active body recomposition (TRT, peptides, weight loss program), every 3–6 months is ideal. For general health monitoring, once per year is sufficient. Scanning more frequently than every 90 days rarely shows meaningful changes and wastes resources. We recommend using our Miami clinic for every follow-up scan, as the same scanner produces the most reliable trend data.",
  },
  {
    question: "Is DEXA the best body composition test in Miami?",
    answer:
      "DEXA is widely considered the clinical gold standard for body composition analysis. Compared to BIA scales (5–8% error), skinfold calipers (highly operator-dependent), and InBody machines (sensitive to hydration), DEXA offers 1–2% precision with regional breakdowns that no other commonly available method can match. Underwater hydrostatic weighing is comparable but rarely available in Miami.",
  },
  {
    question: "Can a DEXA scan track results from TRT or GLP-1 weight loss?",
    answer:
      "Yes. DEXA is the most accurate way to verify that testosterone therapy is producing real lean mass gains and that GLP-1 weight loss (semaglutide, tirzepatide) is preserving muscle while reducing fat. The scale only tells you total weight; DEXA tells you exactly where it's coming from. Many of our Miami TRT and weight loss patients use DEXA scans every 3–6 months to track progress objectively.",
  },
  {
    question: "Is the DEXA scan safe?",
    answer:
      "Yes. A DEXA scan uses an extremely low dose of ionizing radiation — roughly 1/10th of a standard chest X-ray and less than a single day of natural background exposure in South Florida. It's FDA-approved for repeated use and considered one of the safest medical imaging technologies available.",
  },
];

const TESTIMONIALS = [
  {
    name: "Carlos M.",
    neighborhood: "Brickell",
    text: "I've been on TRT for eight months. The scale only moved 6 lbs but my DEXA showed I gained 14 lbs of lean mass and lost 20 lbs of fat. I would have given up without that data. The Brickell location is five minutes from my condo.",
  },
  {
    name: "Andrea P.",
    neighborhood: "Coral Gables",
    text: "I was on tirzepatide and worried I was losing muscle. Strong Health's DEXA scan confirmed I'd kept almost all my lean mass while losing 32 lbs of fat. That's exactly what I needed to see to keep going.",
  },
  {
    name: "Marco T.",
    neighborhood: "Coconut Grove",
    text: "I've used InBody scales at my gym for years and the numbers were all over the place. The DEXA report I got from Strong Health was on a different level — broken down by arm, leg, trunk, plus visceral fat and bone density. Worth every dollar.",
  },
];

// WhyDexa
const whyDexaPoints = [
  { icon: "chart-line", text: "1–2% margin of error vs. 5–8% for BIA scales" },
  { icon: "activity", text: "Region-by-region breakdown (arms, legs, trunk)" },
  { icon: "bone", text: "Bone density scoring (T-score, Z-score)" },
  { icon: "scale", text: "Visceral fat measurement, not just total body fat" },
  { icon: "heart-pulse", text: "FDA-approved, low-dose, repeatable for trend data" },
];

// WhatYouGet
const whatYouGetItems = [
  { icon: "microscope", title: "Total & Regional Body Fat %", desc: "Body fat broken down by arms, legs, trunk, and android/gynoid regions. Track exactly where you're losing fat." },
  { icon: "activity", title: "Lean Muscle Mass", desc: "Pound-precise lean mass for each limb. Verify TRT, peptide, or training programs are actually building muscle." },
  { icon: "scale", title: "Visceral Adipose Tissue", desc: "The dangerous fat around your organs, separated from subcutaneous. The single best metric for metabolic risk." },
  { icon: "bone", title: "Bone Mineral Density", desc: "T-score and Z-score for hip and spine. Catch early osteopenia before it becomes osteoporosis." },
  { icon: "shield-check", title: "Symmetry Analysis", desc: "Left vs. right comparisons by limb. Spot muscle imbalances from old injuries or training asymmetries." },
  { icon: "clipboard-check", title: "Trend Tracking", desc: "Side-by-side comparison reports across every scan, so you can see real change over months and years." },
];

// UseCases
const useCases = [
  {
    title: "TRT patients",
    desc: "Verify that testosterone therapy is producing real lean mass gains and reducing fat — not just moving the scale.",
    href: "/fl/miami/trt-therapy/",
    cta: "Miami TRT therapy →",
  },
  {
    title: "GLP-1 weight loss",
    desc: "Make sure semaglutide or tirzepatide is preserving muscle while you lose fat. Critical for long-term metabolic health.",
    href: "/fl/miami/weight-loss-clinic/",
    cta: "Miami weight loss clinic →",
  },
  {
    title: "Peptide therapy",
    desc: "Quantify body composition changes from peptides like CJC-1295/ipamorelin, BPC-157, or growth hormone secretagogues.",
    href: "/fl/miami/peptide-therapy/",
    cta: "Miami peptide therapy →",
  },
  {
    title: "Athletes & lifters",
    desc: "Get the same body composition data professional sports nutritionists use. Track muscle gain by limb, identify imbalances.",
    href: "/dexa-scan/",
    cta: "Read the full DEXA guide →",
  },
];

// HowItWorks
const steps = [
  {
    num: "01",
    title: "Book Your Miami Scan",
    desc: "Reserve a time online or call (754) 263-6026. Same-week appointments are typically available at our Brickell clinic.",
    color: "#C9A84C",
  },
  {
    num: "02",
    title: "10–15 Minute Scan",
    desc: "Lie flat on an open table while the scanner arm passes over you. No injections, no enclosed space, ultra-low radiation.",
    color: "#5DADE2",
  },
  {
    num: "03",
    title: "Get Your Detailed Report",
    desc: "Full PDF report within 24 hours: lean mass, body fat % by region, visceral fat, bone density, symmetry analysis.",
    color: "#34D399",
  },
  {
    num: "04",
    title: "Track Progress Over Time",
    desc: "Re-scan every 3–6 months on active protocols. Side-by-side trend reports show what's actually changing.",
    color: "#D4B96A",
  },
];

// Neighborhoods
const hoods = [
  "Brickell", "Wynwood", "Coral Gables", "Coconut Grove",
  "Little Havana", "Doral", "Kendall", "Miami Beach",
  "Key Biscayne", "Edgewater", "Midtown", "Design District",
  "Aventura", "Pinecrest", "South Miami", "Hialeah",
];

const SITE_URL = "https://www.stronghealth.com";

// Port of MedicalClinicJsonLd (MedicalBusiness schema) — key order matches the TSX.
const medicalClinicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": `${SITE_URL}/fl/miami/dexascan/#clinic`,
  name: `${CLINIC.name} — DEXA Scan`,
  url: `${SITE_URL}/fl/miami/dexascan/`,
  telephone: CLINIC.phoneTel,
  image: `${SITE_URL}/opengraph.jpg`,
  parentOrganization: { "@id": `${SITE_URL}/#organization` },
  branchOf: { "@id": CLINIC.schemaId },
  sameAs: [
    "https://www.trustpilot.com/review/stronghealth.com",
    `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
      `${CLINIC.name}, ${CLINIC.streetAddress}, ${CLINIC.city}, ${CLINIC.state} ${CLINIC.postalCode}`,
    )}`,
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: CLINIC.streetAddress,
    addressLocality: CLINIC.city,
    addressRegion: CLINIC.state,
    postalCode: CLINIC.postalCode,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: CLINIC.lat,
    longitude: CLINIC.lng,
  },
  areaServed: {
    "@type": "City",
    name: "Miami",
  },
  medicalSpecialty: ["DiagnosticRadiology", "PreventiveMedicine"],
  availableService: [
    {
      "@type": "MedicalProcedure",
      name: "DEXA Scan — Body Composition Analysis",
      procedureType: "https://schema.org/DiagnosticProcedure",
      description:
        "Dual-Energy X-ray Absorptiometry scan for precise measurement of lean mass, body fat percentage, visceral adipose tissue, and bone mineral density.",
    },
    {
      "@type": "MedicalProcedure",
      name: "DEXA Scan — Bone Density",
      procedureType: "https://schema.org/DiagnosticProcedure",
      description:
        "Bone mineral density scanning (T-score and Z-score) for osteopenia and osteoporosis screening.",
    },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: CLINIC.hoursWeekday.opens,
      closes: CLINIC.hoursWeekday.closes,
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: CLINIC.hoursSaturday.opens,
      closes: CLINIC.hoursSaturday.closes,
    },
  ],
  priceRange: "$",
};
---

<BaseLayout
  title="DEXA Scan Miami — Body Composition"
  description="Clinical DEXA scan in Miami at our Brickell clinic. Precise body composition, lean mass, body fat %, visceral fat & bone density. Walk-ins welcome."
  path="/fl/miami/dexascan/"
>
  <PageShell>
    <JsonLd schema={medicalClinicSchema} />
    <JsonLd
      schema={medicalWebPageSchema({
        name: "DEXA Scan Miami — Body Composition",
        description:
          "Physician-supervised DEXA scan body composition analysis in Miami at our Brickell clinic. Lean mass, body fat percentage, visceral fat, and bone density.",
        url: "/fl/miami/dexascan/",
        lastReviewed: PUBLISH_DATE,
        reviewedBy: DR_ANGEL_RIVERA,
      })}
    />
    <JsonLd
      schema={articleSchema({
        headline: "DEXA Scan Miami — Body Composition & Bone Density",
        description:
          "Physician-supervised DEXA scan body composition analysis in Miami at our Brickell clinic. Lean mass, body fat percentage, visceral fat, and bone density.",
        author: MAHADEV_MUKHERJEE,
        reviewer: DR_ANGEL_RIVERA,
        publishDate: PUBLISH_DATE,
        url: "/fl/miami/dexascan/",
      })}
    />
    <JsonLd schema={faqPageSchema(FAQS)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {breadcrumbs.map((crumb, i) => {
            const isLast = i === breadcrumbs.length - 1;
            return (
              <li class="flex items-center gap-1.5">
                {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
                {isLast ? (
                  <span class="text-gold font-semibold">{crumb.name}</span>
                ) : (
                  <a href={crumb.path} class="hover:text-gold transition-colors">
                    {crumb.name}
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    </nav>

    {/* Hero */}
    <section class="relative px-8 pt-12 pb-24 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">4.9</span>
          <span class="text-[13px] text-muted">from 850+ Miami patient reviews</span>
        </div>

        <Tag>Miami DEXA Scan · Brickell Clinic · Walk-Ins Welcome</Tag>

        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[760px] tracking-[-1.5px]">
          DEXA Scan in Miami. <span class="text-gold">Gold-standard body composition, in 15 minutes.</span>
        </h1>

        <p class="text-[17px] text-muted leading-relaxed max-w-[600px] mb-8">
          Walk into our Brickell clinic for a precise, physician-supervised DEXA scan. See exactly
          how much lean muscle, body fat, visceral fat, and bone density you carry — broken down
          region by region. The most accurate body composition test available in Miami.
        </p>

        <Btn trackLead href={BOOKING_SMS_HREF}>Book Your DEXA Scan in Miami →</Btn>
        <div class="mt-4 text-xs text-muted">
          15–20 min visit · Same-week appointments · No referral needed
        </div>
      </div>
    </section>

    {/* Byline */}
    <section class="px-8 pt-2 pb-6 bg-surface">
      <div class="max-w-[800px] mx-auto">
        <AuthorByline
          author={MAHADEV_MUKHERJEE}
          reviewer={DR_ANGEL_RIVERA}
          publishDate={PUBLISH_DATE}
        />
      </div>
    </section>

    {/* WhyDexa */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <FadeIn>
            <Tag>Why DEXA in Miami</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              The scale lies. <span class="text-gold">DEXA tells the truth.</span>
            </h2>
            <p class="text-[15px] text-muted leading-[1.7] mb-4">
              Miami is full of body composition gimmicks — InBody scales at the gym, calipers
              at "longevity" clinics, smart scales at home. None of them come close to the
              precision of a clinical DEXA scan.
            </p>
            <p class="text-[15px] text-muted leading-[1.7]">
              At Strong Health Miami, you get the same scan technology used in clinical
              research, performed at our Brickell clinic, with results you can use to track
              real progress on TRT, GLP-1 weight loss, peptide therapy, or your own training.
            </p>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="flex flex-col gap-3.5">
              {whyDexaPoints.map((s) => (
                <div class="flex items-center gap-3 bg-surface-raised rounded-xl p-4 border border-white/5">
                  <div class="w-9 h-9 rounded-full bg-surface flex items-center justify-center shrink-0 border border-white/5">
                    <Icon name={s.icon} size={18} class="text-gold" />
                  </div>
                  <span class="text-sm text-cream-muted">{s.text}</span>
                </div>
              ))}
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* ClinicDetails */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Our Miami DEXA Clinic</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Visit Us in <span class="text-gold">{CLINIC.area}</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[540px] mx-auto">
            Centrally located in Miami's Brickell financial district with easy access from I-95,
            the Metrorail, and validated parking. DEXA scans by appointment or walk-in.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-6">
          <FadeIn>
            <div class="bg-surface-card rounded-2xl border border-white/10 overflow-hidden h-full">
              <iframe
                src={`https://maps.google.com/maps?q=${MAPS_QUERY}&output=embed`}
                class="w-full h-[240px] border-0"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`${CLINIC.name} - ${CLINIC.streetAddress}`}
              ></iframe>
              <div class="p-6 flex flex-col gap-4">
                <div class="flex items-start gap-3">
                  <Icon name="map-pin" size={16} class="text-gold shrink-0 mt-0.5" />
                  <div>
                    <div class="text-sm font-bold text-cream">{CLINIC.name}</div>
                    <div class="text-sm text-cream-muted mt-0.5">{FULL_ADDRESS}</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="phone" size={16} class="text-gold shrink-0 mt-0.5" />
                  <a
                    href={TEL_HREF}
                    class="text-sm text-cream-muted hover:text-gold transition-colors"
                  >
                    {CLINIC.phone}
                  </a>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="clock" size={16} class="text-gold shrink-0 mt-0.5" />
                  <div class="text-sm text-cream-muted">{CLINIC.hours}</div>
                </div>
                <div class="flex items-start gap-3">
                  <Icon name="navigation" size={16} class="text-gold shrink-0 mt-0.5" />
                  <div class="text-xs text-muted leading-relaxed">{CLINIC.directions}</div>
                </div>
              </div>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-card rounded-2xl border border-white/10 p-7 h-full flex flex-col">
              <h3 class="text-lg font-bold text-cream mb-4">What to expect at your Miami DEXA appointment</h3>
              <div class="flex flex-col gap-4 text-[14px] text-cream-muted leading-[1.7]">
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-gold/10 flex items-center justify-center shrink-0 text-[11px] font-bold text-gold">1</div>
                  <span>Quick check-in at our Brickell front desk. Wear comfortable, metal-free clothing.</span>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-gold/10 flex items-center justify-center shrink-0 text-[11px] font-bold text-gold">2</div>
                  <span>10–15 minute scan on an open table. No injections, no enclosed space, no discomfort.</span>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-gold/10 flex items-center justify-center shrink-0 text-[11px] font-bold text-gold">3</div>
                  <span>Detailed PDF report emailed within 24 hours, plus a brief in-person review of the highlights before you leave.</span>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-gold/10 flex items-center justify-center shrink-0 text-[11px] font-bold text-gold">4</div>
                  <span>Optional 20-minute physician consultation to set baselines and a follow-up cadence (every 3–6 months for active protocols).</span>
                </div>
              </div>
              <div class="mt-6 pt-5 border-t border-white/5 text-[12px] text-muted">
                Most patients are seen within 5 business days of booking. Walk-ins accepted on
                Saturday mornings (9 AM – 1 PM) at our Brickell clinic.
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* WhatYouGet */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Your Report</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            What you get from a <span class="text-gold">Strong Health DEXA scan</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            Your DEXA report goes far beyond a body fat percentage. Here's everything included
            with every scan at our Miami clinic.
          </p>
        </FadeIn>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          {whatYouGetItems.map((u, i) => (
            <FadeIn delay={i * 80}>
              <div class="bg-surface rounded-xl p-6 border border-white/10 h-full hover:bg-surface-raised transition-colors">
                <div class="text-gold mb-4 p-3 rounded-xl bg-surface-raised border border-white/5 w-fit"><Icon name={u.icon} size={28} /></div>
                <h3 class="text-[15px] font-bold text-cream mb-2">{u.title}</h3>
                <p class="text-[13px] text-muted leading-relaxed">{u.desc}</p>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* UseCases */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Who Books DEXA in Miami</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Built for Miami men and women on <span class="text-gold">real protocols</span>
          </h2>
        </FadeIn>
        <div class="grid md:grid-cols-2 gap-5">
          {useCases.map((c, i) => (
            <FadeIn delay={i * 80}>
              <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                <h3 class="text-lg font-bold text-cream mb-3">{c.title}</h3>
                <p class="text-[14px] text-muted leading-relaxed flex-grow mb-4">{c.desc}</p>
                <a href={c.href} class="text-[13px] font-semibold text-gold hover:underline">
                  {c.cta}
                </a>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* HowItWorks */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>How It Works</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Four steps. <span class="text-gold">Real data.</span>
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-4 gap-4">
          {steps.map((s, i) => (
            <FadeIn delay={i * 100}>
              <div
                class="bg-surface rounded-[14px] p-6 border border-white/10 h-full hover:border-white/20 transition-colors"
                style={`border-top:3px solid ${s.color}`}
              >
                <div class="text-[28px] font-black mb-3" style={`color:${s.color}`}>{s.num}</div>
                <h3 class="text-base font-bold text-cream mb-3">{s.title}</h3>
                <p class="text-[13px] text-muted leading-relaxed">{s.desc}</p>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* Testimonials */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Miami Patient Reviews</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Real data from <span class="text-gold">real Miami patients</span>
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-3 gap-5">
          {TESTIMONIALS.map((r, i) => (
            <FadeIn delay={i * 100}>
              <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                <div class="flex items-center gap-2 mb-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }).map(() => (
                      <Icon name="star" size={13} class="fill-[#C9A84C] text-gold" />
                    ))}
                  </div>
                  <span class="text-[10px] text-muted uppercase tracking-wider font-semibold">Verified Patient</span>
                </div>
                <Icon name="quote" size={20} class="text-gold/30 mb-2" />
                <p class="text-[13px] text-cream-muted leading-relaxed flex-grow mb-4">{r.text}</p>
                <div class="border-t border-white/5 pt-3 flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center">
                    <span class="text-[11px] font-bold text-gold">{r.name[0]}</span>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-cream">{r.name}</div>
                    <div class="text-[11px] text-muted">{r.neighborhood}, Miami</div>
                  </div>
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* Neighborhoods */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-8">
          <Tag>Serving Miami-Dade</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            DEXA scan patients from <span class="text-gold">across Miami</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[540px] mx-auto">
            Our Brickell clinic is centrally located for patients across the greater Miami area.
          </p>
        </FadeIn>
        <FadeIn delay={150}>
          <div class="flex flex-wrap gap-2 justify-center max-w-[820px] mx-auto">
            {hoods.map((n) => (
              <span class="text-[12px] text-cream-muted bg-surface-raised border border-white/10 rounded-full px-3.5 py-1.5">
                {n}
              </span>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>

    {/* FAQ */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[800px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Miami DEXA FAQs</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Common questions about <span class="text-gold">DEXA scans in Miami</span>
          </h2>
        </FadeIn>
        <div class="flex flex-col gap-4">
          {FAQS.map((faq, i) => (
            <FadeIn delay={i * 30}>
              <details class="bg-surface-card rounded-xl border border-white/10 group">
                <summary class="cursor-pointer p-5 list-none flex items-start justify-between gap-4">
                  <h3 class="text-[15px] font-bold text-cream pr-2">{faq.question}</h3>
                  <Icon
                    name="chevron-right"
                    size={18}
                    class="text-gold flex-shrink-0 transition-transform group-open:rotate-90 mt-0.5"
                  />
                </summary>
                <div class="px-5 pb-5 text-[14px] text-muted leading-[1.7]">{faq.answer}</div>
              </details>
            </FadeIn>
          ))}
        </div>
        <FadeIn delay={300}>
          <p class="text-[13px] text-muted text-center mt-8">
            Want a deeper dive on the science? Read our full <a href="/dexa-scan/" class="text-gold hover:underline">guide to DEXA scans</a>.
          </p>
        </FadeIn>
      </div>
    </section>

    {/* FinalCTA */}
    <section class="px-8 py-24 bg-gradient-to-br from-[#C9A84C]/[0.08] to-[#0D0F12] border-b border-white/5">
      <div class="max-w-[700px] mx-auto text-center">
        <FadeIn>
          <h2 class="text-[36px] font-black text-cream leading-[1.1] mb-4">
            Book your DEXA scan in Miami
          </h2>
          <p class="text-[17px] text-muted leading-relaxed mb-8 max-w-[520px] mx-auto">
            Walk into our Brickell clinic for the most accurate body composition test in Miami.
            15 minutes. No referral needed. Detailed report within 24 hours.
          </p>
          <div class="flex items-center justify-center gap-2 mb-6 text-[13px] text-muted">
            <Icon name="phone" size={14} class="text-gold" />
            <a
              href={TEL_HREF}
              class="hover:text-gold transition-colors"
            >
              {CLINIC.phone}
            </a>
          </div>
          <Btn trackLead href={BOOKING_SMS_HREF}>Book Your DEXA Scan →</Btn>
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
