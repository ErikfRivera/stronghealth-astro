---
// Article-footer locations block: links every peptide-therapy metro from the
// same configs that render the city pages, so the list can never drift.
import Icon from "./Icon.astro";
import { ALL_PEPTIDE_CITIES } from "../../data/local/cityPeptideConfig";

const locations = ALL_PEPTIDE_CITIES.map((c) => {
  const inPerson = c.physicalClinic !== false;
  return {
    cityName: c.cityName,
    state: c.clinic.state,
    href: `/${c.statePrefix ?? "fl"}/${c.slug}/peptide-therapy/`,
    detail: inPerson
      ? `In-person visits & on-site labs · ${c.clinicArea}`
      : "Telehealth visits with physician oversight",
  };
});
---

<section class="mt-12 pt-8 border-t border-white/10">
  <div class="flex items-center justify-between flex-wrap gap-3 mb-2">
    <h3 class="text-lg font-bold text-cream">Peptide therapy near you</h3>
    <a href="/fl/" class="text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors">
      View all locations →
    </a>
  </div>
  <p class="text-[13px] text-muted leading-relaxed mb-6">
    Physician-supervised peptide therapy from our Miami (Brickell) clinic and via
    telehealth across {ALL_PEPTIDE_CITIES.length} metros. Pick the location nearest you.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {
      locations.map((loc) => (
        <div class="rounded-lg border border-white/10 bg-surface-card/60 p-4">
          <div class="flex items-center gap-1.5">
            <Icon name="map-pin" size={13} class="text-gold shrink-0" />
            <span class="text-[13px] font-bold text-cream leading-tight">
              {loc.cityName}, {loc.state}
            </span>
          </div>
          <div class="text-[11px] text-muted mt-0.5">{loc.detail}</div>
          <a
            href={loc.href}
            class="inline-block mt-2 text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors"
          >
            {loc.cityName} Peptide Therapy →
          </a>
        </div>
      ))
    }
  </div>
</section>
