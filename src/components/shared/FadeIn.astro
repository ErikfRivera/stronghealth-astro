---
/**
 * Scroll fade-in wrapper (port of shared/FadeIn.tsx). Progressive enhancement:
 * server HTML ships fully visible; the shared site runtime
 * (src/scripts/site-runtime.ts, loaded once by BaseLayout) hides
 * below-the-fold elements and fades them in on intersect. No-JS and reduced-motion users see
 * everything immediately.
 */
interface Props {
  delay?: number;
  class?: string;
}

const { delay = 0, class: className = "" } = Astro.props;
---

<div
  class={`sh-fade opacity-100 md:translate-y-0 ${className}`}
  data-fade-delay={delay || undefined}
>
  <slot />
</div>
