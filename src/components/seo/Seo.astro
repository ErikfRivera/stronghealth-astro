---
/**
 * The single source of head SEO tags for every page (FR-3).
 * Mirrors the old `PageSeo.tsx` behavior:
 *  - `<title>` = `title + " | Strong Health"` for every page except the root,
 *    which passes its full title (brand included) itself.
 *  - canonical = site origin + trailing-slash path.
 *  - robots defaults to `index, follow, max-image-preview:large`;
 *    `noindex` switches to `noindex, follow` (404 page).
 *
 * Build-time guards make the historical SEO_AUDIT defects structurally
 * impossible: a non-root title that already carries the brand suffix
 * (double-brand bug) or a slashless `path` prop throws and fails the build.
 * Length budgets (title ≤ 60, description 120–160) are enforced across the
 * built HTML by scripts/check-seo.mjs.
 */
const SITE_NAME = "Strong Health";
const DEFAULT_OG_IMAGE = "https://www.stronghealth.com/opengraph.jpg";
// Intrinsic size / format of DEFAULT_OG_IMAGE (public/opengraph.jpg). Any page
// that overrides `ogImage` MUST also pass matching `ogImageWidth`/`ogImageHeight`
// (and `ogImageType` if not JPEG), or the dimension tags below would misdescribe
// the real asset. The build guard further down enforces that.
const DEFAULT_OG_IMAGE_WIDTH = 1280;
const DEFAULT_OG_IMAGE_HEIGHT = 720;
const DEFAULT_OG_IMAGE_ALT =
  "Strong Health — physician-supervised peptide therapy clinic in Miami with telehealth nationwide";

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageType?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt = DEFAULT_OG_IMAGE_ALT,
  ogImageWidth = DEFAULT_OG_IMAGE_WIDTH,
  ogImageHeight = DEFAULT_OG_IMAGE_HEIGHT,
  ogImageType = "image/jpeg",
  ogType = "website",
  noindex = false,
} = Astro.props;

if (path !== "/" && !path.endsWith("/")) {
  throw new Error(
    `Seo: path "${path}" must end with a trailing slash (canonical policy).`,
  );
}
if (!path.startsWith("/")) {
  throw new Error(`Seo: path "${path}" must start with "/".`);
}
if (path !== "/" && title.includes(`| ${SITE_NAME}`)) {
  throw new Error(
    `Seo: title "${title}" already contains "| ${SITE_NAME}" — the suffix is appended automatically (double-brand guard).`,
  );
}
// A custom og:image must carry its own dimensions, or the width/height tags
// would inherit the default banner's 1280×720 and misreport the real asset.
if (
  ogImage !== DEFAULT_OG_IMAGE &&
  (ogImageWidth === DEFAULT_OG_IMAGE_WIDTH ||
    ogImageHeight === DEFAULT_OG_IMAGE_HEIGHT)
) {
  throw new Error(
    `Seo: custom ogImage "${ogImage}" must pass its own ogImageWidth/ogImageHeight (got ${ogImageWidth}×${ogImageHeight}, the default banner size).`,
  );
}

const canonicalUrl = new URL(path, Astro.site).href;
const fullTitle = path === "/" ? title : `${title} | ${SITE_NAME}`;
const robots = noindex
  ? "noindex, follow"
  : "index, follow, max-image-preview:large";
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={robots} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:type" content={ogImageType} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_NAME} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
