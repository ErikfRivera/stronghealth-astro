---
// Port of LocalProofSection from src/pages/local/cityLocalProof.tsx.
import FadeIn from "../shared/FadeIn.astro";
import Tag from "../shared/Tag.astro";
import Icon from "../shared/Icon.astro";
import type { LocalProofData } from "../../data/local/cityLocalProof";

interface Props {
  data: LocalProofData;
}

const { data } = Astro.props;
const fullAddress = `${data.clinic.streetAddress}, ${data.clinic.city}, ${data.clinic.state} ${data.clinic.postalCode}`;
const tel = data.clinic.phone.replace(/[^\d+]/g, "");
// State-aware service-area copy (US-N1); defaults keep FL pages byte-identical.
const stateName = data.stateName ?? "Florida";
const stateAbbr = data.stateAbbr ?? "FL";
---

<section class="px-8 py-20 bg-surface border-b border-white/5">
  <div class="max-w-[1000px] mx-auto">
    <FadeIn class="text-center mb-10">
      <Tag>This Location</Tag>
      <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
        {
          data.physicalClinic ? (
            <>
              Visit our <span class="text-gold">{data.cityName}</span> clinic
            </>
          ) : (
            <>
              Serving <span class="text-gold">{data.cityName}</span> by appointment
            </>
          )
        }
      </h2>
      <p class="text-[15px] text-muted max-w-[640px] mx-auto">
        {
          data.physicalClinic
            ? `What to expect when you visit Strong Health for ${data.serviceName.toLowerCase()} in ${data.cityName}.`
            : `Strong Health ${data.serviceName.toLowerCase()} care for ${data.cityName} patients is delivered by appointment, including telehealth follow-ups across ${stateName}.`
        }
      </p>
    </FadeIn>

    <div class="grid md:grid-cols-2 gap-6">
      <FadeIn>
        <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size={18} class="text-gold shrink-0 mt-0.5" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-1">
                {data.physicalClinic ? "Address" : "Service area"}
              </div>
              <div class="text-sm font-bold text-cream">{data.clinic.name}</div>
              <div class="text-sm text-cream-muted mt-0.5">
                {
                  data.physicalClinic
                    ? fullAddress
                    : `Serving ${data.cityName}, ${stateAbbr} and surrounding ${data.clinic.state} communities by appointment.`
                }
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="phone" size={18} class="text-gold shrink-0 mt-0.5" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-1">Phone</div>
              <a href={`tel:${tel}`} class="text-sm text-cream-muted hover:text-gold transition-colors">
                {data.clinic.phone}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="bus" size={18} class="text-gold shrink-0 mt-0.5" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-1">
                Parking &amp; transit
              </div>
              <div class="text-sm text-cream-muted leading-relaxed">{data.parkingTransit}</div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="user-check" size={18} class="text-gold shrink-0 mt-0.5" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-1">
                Physician availability
              </div>
              <div class="text-sm text-cream-muted leading-relaxed">{data.physicianAvailability}</div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="calendar" size={18} class="text-gold shrink-0 mt-0.5" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-1">
                Appointment expectations
              </div>
              <div class="text-sm text-cream-muted leading-relaxed">{data.appointmentExpectations}</div>
            </div>
          </div>
        </div>
      </FadeIn>

      <FadeIn delay={150}>
        <div class="flex flex-col gap-6 h-full">
          <div class="bg-surface-card rounded-2xl p-6 border border-white/10">
            <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-3">
              Neighborhoods we see patients from
            </div>
            <div class="flex flex-wrap gap-2">
              {
                data.neighborhoodsServed.map((n) => (
                  <span class="text-[12px] text-cream-muted bg-surface-raised border border-white/10 rounded-full px-3 py-1">
                    {n}
                  </span>
                ))
              }
            </div>
          </div>

          {
            data.physicalClinic && data.reviewLinks.length > 0 && (
              <div class="bg-surface-card rounded-2xl p-6 border border-white/10">
                <div class="flex items-center gap-2 mb-3">
                  <Icon name="star" size={14} class="fill-gold text-gold" />
                  <div class="text-[11px] uppercase tracking-wider text-gold font-bold">
                    Read independent reviews
                  </div>
                </div>
                <ul class="flex flex-col gap-2">
                  {data.reviewLinks.map((r) => (
                    <li>
                      <a
                        href={r.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-[13px] text-cream-muted hover:text-gold transition-colors flex items-center gap-1.5"
                      >
                        <Icon name="external-link" size={12} class="text-gold/80" />
                        {r.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }

          <div class="bg-surface-card rounded-2xl p-6 border border-white/10 flex-grow">
            <div class="text-[11px] uppercase tracking-wider text-gold font-bold mb-3">
              More from Strong Health {data.cityName}
            </div>
            <ul class="flex flex-col gap-2">
              {
                data.relatedInternalLinks.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      class="text-[13px] font-semibold text-cream-muted hover:text-gold transition-colors"
                    >
                      {l.label} →
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </FadeIn>
    </div>
  </div>
</section>
