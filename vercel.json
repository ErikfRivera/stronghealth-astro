{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    { "source": "/about/(.+)", "destination": "/about/", "permanent": true },
    { "source": "/services/", "destination": "/peptides/", "permanent": true },
    { "source": "/services/(.+)", "destination": "/peptides/", "permanent": true },
    { "source": "/fl/miami/trt-therapy/", "destination": "/fl/miami/peptide-therapy/", "permanent": true },
    { "source": "/fl/miami/trt-therapy/(.+)", "destination": "/fl/miami/peptide-therapy/", "permanent": true },
    { "source": "/fl/delray-beach/trt-therapy/", "destination": "/fl/delray-beach/peptide-therapy/", "permanent": true },
    { "source": "/fl/delray-beach/trt-therapy/(.+)", "destination": "/fl/delray-beach/peptide-therapy/", "permanent": true },
    { "source": "/fl/miami/weight-loss-clinic/", "destination": "/fl/miami/peptide-therapy/", "permanent": true },
    { "source": "/fl/miami/weight-loss-clinic/(.+)", "destination": "/fl/miami/peptide-therapy/", "permanent": true },
    { "source": "/fl/delray-beach/weight-loss-clinic/", "destination": "/fl/delray-beach/peptide-therapy/", "permanent": true },
    { "source": "/fl/delray-beach/weight-loss-clinic/(.+)", "destination": "/fl/delray-beach/peptide-therapy/", "permanent": true },
    { "source": "/molecules/(.+)", "destination": "/peptides/$1", "permanent": true },
    { "source": "/peptides-for-tendon-repair/(.+)", "destination": "/peptides-for-tendon-repair/", "permanent": true },
    { "source": "/peptides-for-libido/(.+)", "destination": "/peptides-for-libido/", "permanent": true },
    { "source": "/peptides-for-sleep/(.+)", "destination": "/peptides-for-sleep/", "permanent": true },
    { "source": "/peptides-for-belly-fat/(.+)", "destination": "/peptides-for-belly-fat/", "permanent": true },
    { "source": "/peptides-for-muscle-growth/(.+)", "destination": "/peptides-for-muscle-growth/", "permanent": true },
    { "source": "/peptides-for-arthritis/(.+)", "destination": "/peptides-for-arthritis/", "permanent": true },
    { "source": "/peptides-for-healing/(.+)", "destination": "/peptides-for-healing/", "permanent": true },
    { "source": "/collagen-peptides/(.+)", "destination": "/collagen-peptides/", "permanent": true },
    { "source": "/semaglutide-diet/(.+)", "destination": "/semaglutide-diet/", "permanent": true },
    { "source": "/stillman-diet/(.+)", "destination": "/stillman-diet/", "permanent": true },
    { "source": "/detox-diet/(.+)", "destination": "/detox-diet/", "permanent": true },
    { "source": "/fl/boca-raton/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/hollywood/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/homestead/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/hialeah/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/pembroke-pines/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/fort-lauderdale/(.*)", "destination": "/", "permanent": true },
    { "source": "/fl/coral-gables/(.*)", "destination": "/", "permanent": true },
    { "source": "/dexascans/(.*)", "destination": "https://www.dexascans.com/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "staging.stronghealth.com" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
