---
import Icon from "./Icon.astro";
import { ALL_CITIES, type CityListing } from "../../data/local/cityTrtConfig";

const COUNTY_DISPLAY_ORDER = [
  "Miami-Dade County",
  "Broward County",
  "Palm Beach County",
];

function groupCitiesByCounty(): { name: string; cities: CityListing[] }[] {
  const groups = new Map<string, CityListing[]>();
  for (const city of ALL_CITIES) {
    const list = groups.get(city.county) ?? [];
    list.push(city);
    groups.set(city.county, list);
  }
  const knownOrder = COUNTY_DISPLAY_ORDER.filter((c) => groups.has(c));
  const extras = [...groups.keys()].filter((c) => !COUNTY_DISPLAY_ORDER.includes(c));
  return [...knownOrder, ...extras].map((name) => ({
    name,
    cities: groups.get(name)!,
  }));
}

const REGIONS = groupCitiesByCounty();
---

<section class="mt-12 pt-8 border-t border-white/10">
  <div class="flex items-center justify-between flex-wrap gap-3 mb-2">
    <h3 class="text-lg font-bold text-cream">Find a Strong Health clinic near you</h3>
    <a href="/fl/" class="text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors">
      View all Florida locations →
    </a>
  </div>
  <p class="text-[13px] text-muted leading-relaxed mb-6">
    Physician-supervised TRT and medical weight loss across {ALL_CITIES.length} South Florida
    cities. Pick the location nearest you.
  </p>

  <div class="flex flex-col gap-6">
    {
      REGIONS.map((region) => (
        <div>
          <div class="flex items-center gap-2 mb-3">
            <Icon name="map-pin" size={14} class="text-gold" />
            <h4 class="text-[13px] font-bold text-cream-muted uppercase tracking-[0.06em]">
              {region.name}
            </h4>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {region.cities.map((city) => (
              <div class="rounded-lg border border-white/10 bg-surface-card/60 p-4">
                <div class="text-[13px] font-bold text-cream leading-tight">{city.clinicName}</div>
                <div class="text-[11px] text-muted mt-0.5">
                  {city.area}, {city.name}, FL
                </div>
                <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-3">
                  <a
                    href={`/fl/${city.slug}/trt-therapy/`}
                    class="text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors"
                  >
                    TRT Therapy →
                  </a>
                  <a
                    href={`/fl/${city.slug}/weight-loss-clinic/`}
                    class="text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors"
                  >
                    Weight Loss Clinic →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
