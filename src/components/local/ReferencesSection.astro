---
// Port of ReferencesSection from src/pages/local/cityLocalProof.tsx.
import FadeIn from "../shared/FadeIn.astro";
import Tag from "../shared/Tag.astro";
import Icon from "../shared/Icon.astro";
import type { OutboundCitation } from "../../data/local/cityLocalProof";

interface Props {
  citations: OutboundCitation[];
  serviceLabel?: string;
}

const { citations, serviceLabel = "peptide therapy" } = Astro.props;
---

{
  citations.length > 0 && (
    <section class="px-8 py-16 bg-surface-card border-b border-white/5">
      <div class="max-w-[820px] mx-auto">
        <FadeIn>
          <Tag>References</Tag>
          <h2 class="text-[26px] font-extrabold text-cream mt-3 mb-4">
            Sources cited on this {serviceLabel} page
          </h2>
          <ol class="flex flex-col gap-3 list-decimal list-inside">
            {citations.map((c) => (
              <li class="text-[13px] text-cream-muted leading-relaxed">
                <a
                  href={c.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gold hover:underline inline-flex items-center gap-1"
                >
                  <span>{c.label}</span>
                  <Icon name="external-link" size={11} />
                </a>
              </li>
            ))}
          </ol>
        </FadeIn>
      </div>
    </section>
  )
}
