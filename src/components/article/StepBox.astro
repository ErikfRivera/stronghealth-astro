---
interface Props {
  step: number;
  title: string;
}
const { step, title } = Astro.props;
---

<div class="bg-surface-card border border-white/10 rounded-xl p-5 mb-3">
  <div class="flex items-center gap-3 mb-2">
    <span class="w-7 h-7 rounded-full bg-gold/20 text-gold text-xs font-bold flex items-center justify-center shrink-0">
      {step}
    </span>
    <h4 class="text-[15px] font-bold text-cream">{title}</h4>
  </div>
  <div class="text-[14px] text-text-mid leading-[1.7] pl-10">
    <slot />
  </div>
</div>
