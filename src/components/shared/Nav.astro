---
/**
 * Primary navigation (port of shared/Nav.tsx).
 *
 * Desktop dropdowns are CSS-only (group-hover + focus-within) — no JS, still
 * keyboard-accessible. The mobile drawer uses one tiny inline script (~0.5 KB)
 * to toggle visibility, lock body scroll, and close on Escape/backdrop —
 * replacing the React portal implementation.
 */
import { BOOKING_SMS_HREF } from "../../lib/booking";
import { articles } from "../../data/articles";
import { ALL_CITIES } from "../../data/local/cityTrtConfig";
import { ALL_WEIGHT_LOSS_CITIES } from "../../data/local/cityWeightLossConfig";
import { ALL_PEPTIDE_CITIES } from "../../data/local/cityPeptideConfig";
import Icon from "./Icon.astro";

const peptideArticles = articles.filter((a) => a.category === "Peptide Therapy");
const weightLossSlugs = new Set(ALL_WEIGHT_LOSS_CITIES.map((c) => c.slug));
const peptideSlugs = new Set(ALL_PEPTIDE_CITIES.map((c) => c.slug));

const dropdownPanelClass =
  "absolute top-full right-0 mt-2 bg-surface-card border border-white/10 rounded-xl shadow-2xl z-50 opacity-0 invisible pointer-events-none group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto";
const triggerClass = "inline-flex items-center gap-1 hover:text-cream transition-colors";
const chevronClass = "transition-transform group-hover:rotate-180";
---

<nav
  aria-label="Primary"
  class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-white/5 px-8"
>
  <div class="max-w-[1100px] mx-auto flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#C9A84C] to-[#A88832] flex items-center justify-center">
        <span class="text-surface font-black text-lg">S</span>
      </div>
      <span class="font-extrabold text-lg text-cream tracking-tight">STRONG HEALTH</span>
    </a>
    <div class="hidden md:flex gap-7 items-center text-[13px] font-medium text-muted">
      <div class="relative group">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Peptides
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={dropdownPanelClass}>
          <div class="p-4 w-[320px]">
            <a
              href="/peptides/"
              class="block mb-2 px-3 py-2 rounded-md text-[13px] font-bold text-gold hover:bg-white/5 transition-colors"
            >
              Peptides Hub →
            </a>
            <div class="border-t border-white/5 my-2"></div>
            <div class="flex flex-col">
              {
                peptideArticles.map((a) => (
                  <a
                    href={a.path}
                    class="block px-3 py-2 rounded-md text-[13px] text-cream hover:bg-white/5 hover:text-gold transition-colors leading-snug"
                  >
                    {a.title.split(":")[0]}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="relative group">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Locations
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={dropdownPanelClass}>
          <div class="p-4 w-[640px]">
            <a
              href="/fl/"
              class="block mb-2 px-3 py-2 rounded-md text-[13px] font-bold text-gold hover:bg-white/5 transition-colors"
            >
              Florida Locations Hub →
            </a>
            <div class="border-t border-white/5 my-2"></div>
            <div class="grid grid-cols-3 gap-x-4 gap-y-3">
              {
                ALL_CITIES.map((c) => (
                  <div>
                    <div class="px-3 py-1 text-[11px] font-bold uppercase tracking-[1.2px] text-cream">
                      {c.name}
                    </div>
                    <a
                      href={`/fl/${c.slug}/trt-therapy/`}
                      class="block px-3 py-1 rounded-md text-[12px] text-muted hover:bg-white/5 hover:text-gold transition-colors"
                    >
                      {c.name} TRT Therapy
                    </a>
                    {weightLossSlugs.has(c.slug) && (
                      <a
                        href={`/fl/${c.slug}/weight-loss-clinic/`}
                        class="block px-3 py-1 rounded-md text-[12px] text-muted hover:bg-white/5 hover:text-gold transition-colors"
                      >
                        {c.name} Weight Loss Clinics
                      </a>
                    )}
                    {peptideSlugs.has(c.slug) && (
                      <a
                        href={`/fl/${c.slug}/peptide-therapy/`}
                        class="block px-3 py-1 rounded-md text-[12px] text-muted hover:bg-white/5 hover:text-gold transition-colors"
                      >
                        {c.name} Peptide Therapy
                      </a>
                    )}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="relative group">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Blog
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={dropdownPanelClass}>
          <div class="p-4 w-[220px]">
            <a
              href="/blog/"
              class="block mb-2 px-3 py-2 rounded-md text-[13px] font-bold text-gold hover:bg-white/5 transition-colors"
            >
              Blog →
            </a>
            <div class="border-t border-white/5 my-2"></div>
            <a
              href="/reviews/"
              class="block px-3 py-2 rounded-md text-[13px] text-cream hover:bg-white/5 hover:text-gold transition-colors"
            >
              Reviews
            </a>
          </div>
        </div>
      </div>

      <div class="relative group">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Dexascans
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={dropdownPanelClass}>
          <div class="p-4 w-[260px]">
            <a
              href="https://www.Dexascans.com"
              target="_blank"
              rel="noopener noreferrer"
              class="block mb-2 px-3 py-2 rounded-md text-[13px] font-bold text-gold hover:bg-white/5 transition-colors"
            >
              Dexa Scan
            </a>
            <div class="border-t border-white/5 my-2"></div>
            <a
              href="/fl/miami/dexascan/"
              class="block px-3 py-2 rounded-md text-[13px] text-cream hover:bg-white/5 hover:text-gold transition-colors"
            >
              DEXA Scan Miami
            </a>
          </div>
        </div>
      </div>

      <a
        href={BOOKING_SMS_HREF}
        data-track-lead
        class="inline-flex items-center justify-center bg-gold text-surface font-bold hover:bg-gold-hover transition-colors rounded-lg uppercase tracking-[1.2px] px-5 py-2.5 text-[11px]"
      >
        Book Free Assessment
      </a>
    </div>
    <button
      type="button"
      id="mobile-nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
      class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-cream hover:bg-white/5 transition-colors"
    >
      <span class="nav-icon-menu"><Icon name="menu" size={22} /></span>
      <span class="nav-icon-close hidden"><Icon name="x" size={22} /></span>
    </button>
  </div>
</nav>

<div
  id="mobile-nav-backdrop"
  class="md:hidden fixed inset-0 top-16 z-[60] bg-black/60 hidden"
  aria-hidden="true"
>
</div>

<div
  id="mobile-nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  aria-hidden="true"
  class="md:hidden fixed top-16 right-0 bottom-0 w-[85%] max-w-sm z-[70] bg-surface border-l border-white/10 transform transition-transform duration-200 ease-out translate-x-full"
>
  <div class="flex flex-col h-full overflow-y-auto px-6 py-6">
    <details class="border-b border-white/5 group">
      <summary class="w-full min-h-[44px] flex items-center justify-between py-3 text-[15px] font-medium text-cream hover:text-gold transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
        Peptides
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a href="/peptides/" class="min-h-[44px] flex items-center py-3 text-[13px] font-bold text-gold hover:underline">
          Peptides Hub →
        </a>
        {
          peptideArticles.map((a) => (
            <a
              href={a.path}
              class="min-h-[44px] flex items-center py-3 text-[13px] text-cream hover:text-gold transition-colors leading-snug"
            >
              {a.title.split(":")[0]}
            </a>
          ))
        }
      </div>
    </details>

    <details class="border-b border-white/5 group">
      <summary class="w-full min-h-[44px] flex items-center justify-between py-3 text-[15px] font-medium text-cream hover:text-gold transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
        Locations
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a href="/fl/" class="min-h-[44px] flex items-center py-3 text-[13px] font-bold text-gold hover:underline">
          Florida Locations Hub →
        </a>
        {
          ALL_CITIES.map((c) => (
            <details class="group/city">
              <summary class="w-full min-h-[44px] flex items-center justify-between py-2.5 text-[13px] font-semibold uppercase tracking-[1.2px] text-cream hover:text-gold transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                {c.name}
                <Icon name="chevron-down" size={14} class="transition-transform group-open/city:rotate-180" />
              </summary>
              <div class="pb-2 pl-3 flex flex-col">
                <a
                  href={`/fl/${c.slug}/trt-therapy/`}
                  class="min-h-[44px] flex items-center py-3 text-[13px] text-muted hover:text-gold transition-colors"
                >
                  {c.name} TRT Therapy
                </a>
                {weightLossSlugs.has(c.slug) && (
                  <a
                    href={`/fl/${c.slug}/weight-loss-clinic/`}
                    class="min-h-[44px] flex items-center py-3 text-[13px] text-muted hover:text-gold transition-colors"
                  >
                    {c.name} Weight Loss Clinics
                  </a>
                )}
                {peptideSlugs.has(c.slug) && (
                  <a
                    href={`/fl/${c.slug}/peptide-therapy/`}
                    class="min-h-[44px] flex items-center py-3 text-[13px] text-muted hover:text-gold transition-colors"
                  >
                    {c.name} Peptide Therapy
                  </a>
                )}
              </div>
            </details>
          ))
        }
      </div>
    </details>

    <details class="border-b border-white/5 group">
      <summary class="w-full min-h-[44px] flex items-center justify-between py-3 text-[15px] font-medium text-cream hover:text-gold transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
        Blog
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a href="/blog/" class="min-h-[44px] flex items-center py-3 text-[13px] font-bold text-gold hover:underline">
          Blog →
        </a>
        <a href="/reviews/" class="min-h-[44px] flex items-center py-3 text-[13px] text-cream hover:text-gold transition-colors">
          Reviews
        </a>
      </div>
    </details>

    <details class="border-b border-white/5 group">
      <summary class="w-full min-h-[44px] flex items-center justify-between py-3 text-[15px] font-medium text-cream hover:text-gold transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
        Dexascans
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a
          href="https://www.Dexascans.com"
          target="_blank"
          rel="noopener noreferrer"
          class="min-h-[44px] flex items-center py-3 text-[13px] font-bold text-gold hover:underline"
        >
          Dexa Scan
        </a>
        <a href="/fl/miami/dexascan/" class="min-h-[44px] flex items-center py-3 text-[13px] text-cream hover:text-gold transition-colors">
          DEXA Scan Miami
        </a>
      </div>
    </details>

    <a
      href={BOOKING_SMS_HREF}
      data-track-lead
      class="mt-6 min-h-[44px] inline-flex items-center justify-center px-5 py-3 rounded-lg uppercase tracking-[1.2px] text-[12px] bg-gold text-surface font-bold hover:bg-gold-hover transition-colors"
    >
      Book Free Assessment
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById("mobile-nav-toggle")!;
  const drawer = document.getElementById("mobile-nav-drawer")!;
  const backdrop = document.getElementById("mobile-nav-backdrop")!;
  const iconMenu = toggle.querySelector(".nav-icon-menu")!;
  const iconClose = toggle.querySelector(".nav-icon-close")!;
  let open = false;

  function setOpen(next: boolean) {
    open = next;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    drawer.setAttribute("aria-hidden", String(!open));
    drawer.classList.toggle("translate-x-full", !open);
    drawer.classList.toggle("translate-x-0", open);
    backdrop.classList.toggle("hidden", !open);
    iconMenu.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
    document.body.style.overflow = open ? "hidden" : "";
  }

  toggle.addEventListener("click", () => setOpen(!open));
  backdrop.addEventListener("click", () => setOpen(false));
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) setOpen(false);
  });
</script>
