---
/**
 * Primary navigation (port of shared/Nav.tsx).
 *
 * Desktop dropdowns are CSS-only (group-hover + focus-within) — no JS, still
 * keyboard-accessible. The mobile drawer is toggled by the shared
 * site runtime (src/scripts/site-runtime.ts) — visibility, body scroll lock,
 * Escape/backdrop close — replacing the React portal implementation.
 *
 * The Peptides menu is a mega menu exposing both taxonomies with direct
 * links to every page: outcomes (/peptides/ hub + all goal spokes from
 * GOAL_PAGES) and molecules (/molecules/ hub + every molecule page from the
 * MOLECULES registry, grouped by MoleculeGroup). Locations lists every
 * peptide-therapy metro from cityPeptideConfig — the sole service theme.
 */
import { BOOKING_SMS_HREF } from "../../lib/booking";
import { GOAL_PAGES } from "../../data/molecules/goals";
import { moleculesByGroup, moleculePath } from "../../data/molecules";
import { ALL_PEPTIDE_CITIES } from "../../data/local/cityPeptideConfig";
import Icon from "./Icon.astro";

const goalLinks = Object.values(GOAL_PAGES).map((g) => ({
  label: g.label,
  href: g.path,
}));
const moleculeGroups = moleculesByGroup().map(({ group, items }) => ({
  group,
  items: items.map((m) => ({ label: m.name, href: moleculePath(m.slug) })),
}));
const peptideCities = ALL_PEPTIDE_CITIES.map((c) => ({
  label: `${c.cityName} Peptide Therapy`,
  href: `/${c.statePrefix ?? "fl"}/${c.slug}/peptide-therapy/`,
}));

const dropdownPanelClass = "nav-drop"; // shared rule in global.css (Phase 8)
const triggerClass = "inline-flex items-center gap-1 hover:text-cream transition-colors";
const chevronClass = "transition-transform group-hover:rotate-180";
---

<nav
  aria-label="Primary"
  class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-white/5 px-8"
>
  <div class="max-w-[1100px] mx-auto flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#C9A84C] to-[#A88832] flex items-center justify-center">
        <span class="text-surface font-black text-lg">S</span>
      </div>
      <span class="font-extrabold text-lg text-cream tracking-tight">STRONG HEALTH</span>
    </a>
    <div class="hidden md:flex gap-7 items-center text-[13px] font-medium text-muted">
      {/* No `relative` here: the mega panel positions against the sticky
          <nav> so it can span wider than the trigger (see .nav-drop-mega).
          h-16 keeps the hover zone continuous from trigger to panel. */}
      <div class="group h-16 flex items-center">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Peptides
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={`${dropdownPanelClass} nav-drop-mega`}>
          <div class="p-5 grid grid-cols-[220px_1fr] gap-6">
            <div>
              <a href="/peptides/" class="nav-drop-hub">
                Peptides by Goal →
              </a>
              <div class="flex flex-col">
                {
                  goalLinks.map((g) => (
                    <a href={g.href} class="nav-drop-a">
                      {g.label}
                    </a>
                  ))
                }
              </div>
            </div>
            <div class="border-l border-white/5 pl-6">
              <a href="/molecules/" class="nav-drop-hub">
                Peptides by Molecule →
              </a>
              <div class="columns-2 gap-4">
                {
                  moleculeGroups.map(({ group, items }) => (
                    <div class="break-inside-avoid mb-2">
                      <div class="px-3 pt-1.5 pb-0.5 text-[10px] font-semibold uppercase tracking-[1.2px] text-muted">
                        {group}
                      </div>
                      {items.map((m) => (
                        <a href={m.href} class="nav-drop-a">
                          {m.label}
                        </a>
                      ))}
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative group">
        <button type="button" aria-haspopup="menu" class={triggerClass}>
          Locations
          <Icon name="chevron-down" size={14} class={chevronClass} />
        </button>
        <div role="menu" class={dropdownPanelClass}>
          <div class="p-4 w-[320px]">
            <a
              href="/fl/"
              class="nav-drop-hub"
            >
              All Locations →
            </a>
            <div class="border-t border-white/5 my-2"></div>
            <div class="flex flex-col">
              {
                peptideCities.map((c) => (
                  <a
                    href={c.href}
                    class="nav-drop-a"
                  >
                    {c.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <a href="/blog/" class={triggerClass}>Blog</a>

      <a
        href={BOOKING_SMS_HREF}
        data-track-lead
        class="inline-flex items-center justify-center bg-gold text-surface font-bold hover:bg-gold-hover transition-colors rounded-lg uppercase tracking-[1.2px] px-5 py-2.5 text-[11px]"
      >
        Book Free Assessment
      </a>
    </div>
    <button
      type="button"
      id="mobile-nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
      class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-cream hover:bg-white/5 transition-colors"
    >
      <span class="nav-icon-menu"><Icon name="menu" size={22} /></span>
      <span class="nav-icon-close hidden"><Icon name="x" size={22} /></span>
    </button>
  </div>
</nav>

<div
  id="mobile-nav-backdrop"
  class="md:hidden fixed inset-0 top-16 z-[60] bg-black/60 hidden"
  aria-hidden="true"
>
</div>

<div
  id="mobile-nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  aria-hidden="true"
  class="md:hidden fixed top-16 right-0 bottom-0 w-[85%] max-w-sm z-[70] bg-surface border-l border-white/10 transform transition-transform duration-200 ease-out translate-x-full"
>
  <div class="flex flex-col h-full overflow-y-auto px-6 py-6">
    <details class="border-b border-white/5 group">
      <summary class="mnav-sum">
        Peptides
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a href="/peptides/" class="mnav-hub">
          Peptides by Goal →
        </a>
        {
          goalLinks.map((g) => (
            <a href={g.href} class="mnav-a">
              {g.label}
            </a>
          ))
        }
        <a href="/molecules/" class="mnav-hub mt-2 border-t border-white/5">
          Peptides by Molecule →
        </a>
        {
          moleculeGroups.map(({ group, items }) => (
            <div class="flex flex-col">
              <div class="pt-2 pb-1 text-[10px] font-semibold uppercase tracking-[1.2px] text-muted">
                {group}
              </div>
              {items.map((m) => (
                <a href={m.href} class="mnav-a">
                  {m.label}
                </a>
              ))}
            </div>
          ))
        }
      </div>
    </details>

    <details class="border-b border-white/5 group">
      <summary class="mnav-sum">
        Locations
        <Icon name="chevron-down" size={16} class="transition-transform group-open:rotate-180" />
      </summary>
      <div class="pb-3 pl-2 flex flex-col">
        <a href="/fl/" class="mnav-hub">
          All Locations →
        </a>
        {
          peptideCities.map((c) => (
            <a href={c.href} class="mnav-a">
              {c.label}
            </a>
          ))
        }
      </div>
    </details>

    <a href="/blog/" class="mnav-sum border-b border-white/5">Blog</a>

    <a
      href={BOOKING_SMS_HREF}
      data-track-lead
      class="mt-6 min-h-[44px] inline-flex items-center justify-center px-5 py-3 rounded-lg uppercase tracking-[1.2px] text-[12px] bg-gold text-surface font-bold hover:bg-gold-hover transition-colors"
    >
      Book Free Assessment
    </a>
  </div>
</div>
