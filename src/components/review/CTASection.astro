---
import Icon from "../shared/Icon.astro";
import { BOOKING_SMS_HREF } from "../../lib/booking";
import { STRONG_HEALTH_PHONE_DISPLAY } from "../../data/miamiClinic";
---

<section class="my-16 text-center py-16 px-8 rounded-2xl bg-gradient-to-br from-[#0D1117] to-[#0D0F12] border border-white/5">
  <div class="flex justify-center gap-1 mb-4">
    {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={18} class="fill-[#C9A84C] text-gold" />)}
  </div>
  <h2 class="text-3xl font-bold text-cream mb-4">Ready for Evidence-Based Hormone Optimization?</h2>
  <p class="text-muted text-[17px] mb-8 max-w-[500px] mx-auto">
    Skip the supplements. Talk to a physician who specializes in testosterone therapy.
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <a
      href={BOOKING_SMS_HREF}
      data-track-lead
      class="inline-flex items-center justify-center gap-2 px-9 py-4 rounded-lg cursor-pointer uppercase tracking-[1.2px] transition-all duration-200 text-[15px] bg-gold text-surface font-bold hover:bg-gold-hover"
    >
      Book Your Free Assessment <Icon name="arrow-right" size={18} />
    </a>
    <button class="inline-flex items-center justify-center gap-2 px-9 py-4 rounded-lg cursor-pointer uppercase tracking-[1.2px] transition-all duration-200 text-[15px] bg-transparent text-cream border-[1.5px] border-white/25 font-semibold hover:bg-white/5">
      <Icon name="phone" size={18} /> Call {STRONG_HEALTH_PHONE_DISPLAY}
    </button>
  </div>
</section>
