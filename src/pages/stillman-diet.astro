import BlogArticleLayout from "../layouts/BlogArticleLayout.astro";
import AccordionFoodList from "../components/diet/AccordionFoodList.astro";
import { faqPageSchema } from "../components/seo/schemas";
import { ARTICLE_AUTHORSHIP } from "../data/articleAuthors";
import body0 from "../content/fragments/stillman-diet.0.html?raw";
import body1 from "../content/fragments/stillman-diet.1.html?raw";
import body2 from "../content/fragments/stillman-diet.2.html?raw";

const path = "/stillman-diet/";
const { author, reviewer } = ARTICLE_AUTHORSHIP[path]!;

const faqs = [{"question": "What is the Stillman Diet and how does it work?", "answer": "The Stillman Diet is a 1967 crash diet created by Dr. Irwin Maxwell Stillman. It strips out both fats and carbohydrates, leaving lean protein as roughly 90% of your calories. The theory is that protein's high thermic effect (it burns 20-30% of its own calories during digestion) would speed up metabolism. You eat lean meats, eggs, non-fat cottage cheese, and skim milk cheeses while drinking 8 glasses of water a day. It's designed for 1-2 weeks maximum, not long-term use."}, {"question": "How much weight can you lose on the Stillman Diet?", "answer": "Dr. Stillman claimed 7-15 pounds in the first week. The only clinical study (Rickman et al., 1974) found an average loss of 7 pounds over 7.6 days, but researchers classified most of that as water weight from glycogen depletion. Participants who stopped the diet regained 2-8 pounds within a week. Rapid initial loss is real, but it's not the same as fat loss."}, {"question": "Is the Stillman Diet safe?", "answer": "For most people, no. The 1974 JAMA study found cholesterol rose in every single participant (from 215 to 248 mg/dL on average). The diet provides zero fiber, no vitamin C, and insufficient fat for absorbing fat-soluble vitamins. Kidney stress from the extreme protein load is a concern, and the very low calorie intake (500-1,200 calories) creates risks for nutrient deficiency. No major medical organization recommends it."}, {"question": "What's the difference between the Stillman Diet and Atkins?", "answer": "Fat. That's the fundamental divide. Atkins replaces carbs with fat (butter, oils, cream, cheese are all encouraged). Stillman replaces carbs with lean protein and bans fat along with carbs. Atkins also allows low-carb vegetables from Phase 1 and has a structured 4-phase reintroduction system. Stillman has no vegetables at all in its original protocol. Atkins actually cited Stillman as a prototype when developing his own approach."}, {"question": "Can you follow the Stillman Diet while on semaglutide or other GLP-1 medications?", "answer": "No. The Stillman Diet is strongly incompatible with GLP-1 medications. GLP-1 drugs slow gastric emptying, and a diet of almost pure protein would compound that effect, likely causing severe nausea, bloating, and vomiting. The diet provides zero fiber, which would worsen GLP-1-induced constipation. The protein levels (2.5-3.0 g/kg/day) far exceed what research supports for GLP-1 patients (1.0-1.5 g/kg/day)."}, {"question": "What foods can you eat on the Stillman Diet?", "answer": "The list is short. Lean meats (beef, veal, chicken, turkey without skin), lean white fish and seafood, boiled eggs, non-fat cottage cheese, skim milk cheeses, and sugar-free gelatin. Everything must be prepared by broiling, baking, or boiling with no added oils or fats. You also drink 8 glasses of water daily plus black coffee or tea."}, {"question": "How long should you stay on the Stillman Diet?", "answer": "Dr. Stillman designed it for 1-2 weeks maximum. His own book title (14-Day Shape-Up Program) confirms the intended duration. After the initial phase, he recommended transitioning to a maintenance plan with gradual carbohydrate reintroduction at 30-60g carbs per day with calorie counting."}, {"question": "Is the Stillman Diet the same as a Protein-Sparing Modified Fast?", "answer": "They're close cousins. Both focus on lean protein at very low total calories (around 800 cal/day) to preserve muscle while forcing fat loss. The key difference is that modern PSMFs are medically supervised with electrolyte monitoring, vitamin supplementation, and regular lab work. The Stillman Diet lacked all of those safeguards, which is a big part of why it fell out of favor."}, {"question": "Could medical weight loss with GLP-1 therapy be a better option?", "answer": "For sustained weight loss, the evidence strongly favors GLP-1 therapy over crash diets like Stillman. Semaglutide produces average weight loss of 15% over 68 weeks in clinical trials, with cardiovascular benefits and physician supervision built in. The Stillman Diet has one small study showing mostly water weight loss over 7 days. If you're serious about lasting results, a physician-supervised approach gives you much better odds."}];

const citations = [{"id": 1, "text": "Rickman F, et al. Changes in serum cholesterol during the Stillman Diet. JAMA. 1974;228(1):54-58.", "url": "https://pubmed.ncbi.nlm.nih.gov/4405914/"}, {"id": 2, "text": "Westerterp-Plantenga MS, et al. Dietary protein, weight loss, and weight maintenance. Annu Rev Nutr. 2009;29:21-41.", "url": "https://pubmed.ncbi.nlm.nih.gov/19400750/"}, {"id": 3, "text": "Skov AR, et al. Randomized trial on protein vs carbohydrate in ad libitum fat reduced diet for the treatment of obesity. Int J Obes. 1999;23(5):528-536.", "url": "https://pubmed.ncbi.nlm.nih.gov/10375057/"}, {"id": 4, "text": "Johnston CS, et al. High-protein, low-fat diets are effective for weight loss and favorably alter biomarkers in healthy adults. J Nutr. 2004;134(3):586-591.", "url": "https://pubmed.ncbi.nlm.nih.gov/14988451/"}, {"id": 5, "text": "Devries MC, et al. Changes in kidney function do not differ between healthy adults consuming higher- compared with lower- or normal-protein diets: a systematic review and meta-analysis. J Nutr. 2018;148(11):1760-1775.", "url": "https://pubmed.ncbi.nlm.nih.gov/30383278/"}, {"id": 6, "text": "Wilding JPH, et al. Once-weekly semaglutide in adults with overweight or obesity (STEP 1). N Engl J Med. 2021;384(11):989-1002.", "url": "https://pubmed.ncbi.nlm.nih.gov/33567185/"}, {"id": 7, "text": "Lincoff AM, et al. Semaglutide and cardiovascular outcomes in obesity without diabetes (SELECT). N Engl J Med. 2023;389(24):2221-2232.", "url": "https://pubmed.ncbi.nlm.nih.gov/37952131/"}, {"id": 8, "text": "Hall KD, Kahan S. Maintenance of lost weight and long-term management of obesity. Med Clin North Am. 2018;102(1):183-197.", "url": "https://pubmed.ncbi.nlm.nih.gov/29156185/"}, {"id": 9, "text": "Halton TL, Hu FB. The effects of high protein diets on thermogenesis, satiety and weight loss: a critical review. J Am Coll Nutr. 2004;23(5):373-385.", "url": "https://pubmed.ncbi.nlm.nih.gov/15466943/"}, {"id": 10, "text": "KDIGO 2024 Clinical Practice Guideline for the Evaluation and Management of Chronic Kidney Disease. Kidney Int. 2024;105(4S):S117-S314.", "url": "https://pubmed.ncbi.nlm.nih.gov/38490803/"}, {"id": 11, "text": "Wharton S, et al. Managing the gastrointestinal side effects of GLP-1 receptor agonists in obesity. Obesity (Silver Spring). 2022;30(1):17-22.", "url": "https://pubmed.ncbi.nlm.nih.gov/34936189/"}, {"id": 12, "text": "Jensen MD, et al. 2013 AHA/ACC/TOS guideline for the management of overweight and obesity in adults. Circulation. 2014;129(25 Suppl 2):S102-S138.", "url": "https://pubmed.ncbi.nlm.nih.gov/24222017/"}];

const foodsToEat = [{"category": "Lean Meats", "emoji": "🥩", "items": ["Lean beef (trimmed of all visible fat), broiled or baked", "Veal (any lean cut), prepared without added oil", "Chicken breast and turkey breast (skin removed before cooking)", "Lean hamburger patties (broiled, no bun, no condiments with oil)"]}, {"category": "Fish & Seafood", "emoji": "🐟", "items": ["Lean white fish: cod, haddock, sole, flounder", "Shrimp, lobster, crab (steamed or boiled)", "Oysters and clams", "No fatty fish like salmon (too much fat for this protocol)"]}, {"category": "Eggs", "emoji": "🥚", "items": ["Hard-boiled or soft-boiled eggs (no limit specified)", "Scrambled without butter or oil (use non-stick pan only)", "Sample menus show 2-3 eggs per meal as a staple"]}, {"category": "Low-Fat Dairy", "emoji": "🧀", "items": ["Non-fat cottage cheese (a daily staple of the diet)", "Farmer cheese and curd cheese (made from skim milk)", "Skim milk cheeses only (no regular cheese allowed)"]}, {"category": "Beverages & Extras", "emoji": "☕", "items": ["8 glasses of water per day (mandatory, non-negotiable)", "Black coffee and tea (no sugar, no cream, artificial sweeteners okay)", "Diet sodas and herbal teas", "Sugar-free gelatin (limited to 1-2 servings per day)", "Condiments: salt, pepper, herbs, mustard, vinegar, soy sauce (oil-free only)"]}];

const foodsToAvoid = [{"category": "All Carbohydrates", "emoji": "🍞", "items": ["Bread, pasta, rice, grains, cereals, potatoes", "Legumes, beans, lentils", "All starchy foods without exception"]}, {"category": "All Fruits & Vegetables", "emoji": "🥗", "items": ["Every fruit (including juices)", "Every vegetable (even salad greens in the original Phase 1)", "No exceptions for low-carb options"]}, {"category": "All Fats & Oils", "emoji": "🧈", "items": ["Butter, margarine, cooking oils of any kind", "Salad dressings, mayonnaise, gravy, tartar sauce", "Fatty cuts of meat, poultry skin", "Pork (excluded in some versions), salmon (too fatty)", "Full-fat dairy: whole milk, cream, regular cheese"]}, {"category": "Sugar, Alcohol & Everything Else", "emoji": "🍭", "items": ["All sugar: white sugar, honey, molasses, candy, desserts", "All alcohol (completely banned)", "All processed foods containing carbs or added fats", "The book puts it bluntly: 'NOTHING ELSE IS PERMITTED'"]}];

const tocItems = [{"id": "what-is", "title": "What Is the Stillman Diet?"}, {"id": "history", "title": "History and Origin Story"}, {"id": "scorecard", "title": "Diet Scorecard"}, {"id": "macro-profile", "title": "Macro & Nutrition Profile"}, {"id": "foods-to-eat", "title": "Foods You're Allowed to Eat"}, {"id": "foods-to-avoid", "title": "Foods That Are Completely Banned"}, {"id": "meal-plan", "title": "Sample One-Day Meal Plan"}, {"id": "health-benefits", "title": "Health Benefits & Evidence"}, {"id": "risks", "title": "Risks & Side Effects"}, {"id": "glp1-compatibility", "title": "GLP-1 Compatibility"}, {"id": "vs-other-diets", "title": "Compared to Other Diets"}, {"id": "faq", "title": "FAQ"}, {"id": "bottom-line", "title": "The Bottom Line"}, {"id": "references", "title": "References"}];

const relatedLinks = [{"url": "/semaglutide-diet/", "label": "Semaglutide Diet: Complete Guide for Weight Loss"}, {"url": "/fl/miami/weight-loss-clinic/", "label": "Weight Loss Clinic in Miami, FL"}, {"url": "/fl/delray-beach/weight-loss-clinic/", "label": "Weight Loss Clinic in Delray Beach, FL"}, {"url": "/peptides-for-belly-fat/", "label": "Peptides for Belly Fat: How GH Secretagogues Target Visceral Fat"}, {"url": "/foods-that-lower-testosterone/", "label": "Foods That Lower Testosterone: Separating Myth from Evidence"}];

// Production wrapped this page's FAQPage schema in an @graph envelope.
const { ["@context"]: _ctx, ...faqNoCtx } = faqPageSchema(faqs) as Record<string, unknown>;
const structuredData = { "@context": "https://schema.org", "@graph": [faqNoCtx] };
---

<BlogArticleLayout
  title="The Stillman Diet: History, Risks, and Why Modern Medicine Moved On (2026)"
  seoTitle="The Stillman Diet: History, Risks & Verdict"
  subtitle="A 1967 crash diet that sold 5 million copies, raised cholesterol in every study participant, and pioneered ideas that still influence how we think about protein and weight loss."
  seoDescription="Complete guide to the Stillman Diet: 1967 high-protein origins, extreme restrictions, documented health risks, and how it compares to modern weight loss."
  path={path}
  author={author}
  reviewer={reviewer}
  datePublishedISO="2026-04-04"
  dateModifiedISO="2026-04-04"
  readTime="16 min"
  tocItems={tocItems}
  faqs={faqs}
  citations={citations}
  relatedLinks={relatedLinks}
  structuredData={structuredData}
  ctaHeading="Looking for Weight Loss That Lasts?"
  ctaText="Crash diets produce crash results. Our physicians build evidence-based, physician-supervised weight loss plans around your body, your goals, and your health history."
  ctaButtonText="Book Your Free Assessment →"
>
  <Fragment set:html={body0} />
  <AccordionFoodList groups={foodsToEat} variant="eat" />
  <Fragment set:html={body1} />
  <AccordionFoodList groups={foodsToAvoid} variant="avoid" />
