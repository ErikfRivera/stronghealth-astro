---
/**
 * Port of src/pages/local/CityWeightLossPage.tsx — config-driven city
 * weight-loss clinic page (hero, GLP-1 program, timeline, testimonials,
 * FAQ, clinic details, local proof, nearby cities, citations, final CTA).
 */
import BaseLayout from "../BaseLayout.astro";
import PageShell from "../../components/shared/PageShell.astro";
import FadeIn from "../../components/shared/FadeIn.astro";
import Btn from "../../components/shared/Btn.astro";
import Tag from "../../components/shared/Tag.astro";
import Icon from "../../components/shared/Icon.astro";
import FAQSection from "../../components/shared/FAQSection.astro";
import CitationList, { type Citation } from "../../components/shared/CitationList.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import {
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../components/seo/schemas";
import LocalProofSection from "../../components/local/LocalProofSection.astro";
import {
  ALL_WEIGHT_LOSS_CITIES,
  type CityWeightLossConfig,
} from "../../data/local/cityWeightLossConfig";
import {
  defaultReviewLinks,
  defaultRelatedInternalLinks,
  defaultPhysicianAvailability,
  DEFAULT_APPOINTMENT_EXPECTATIONS,
  type LocalProofData,
} from "../../data/local/cityLocalProof";

interface Props {
  config: CityWeightLossConfig;
}

const { config } = Astro.props;

interface ProgramStep {
  num: string;
  title: string;
  desc: string;
  detail?: string;
  color: string;
  icon: string;
  bullets?: string[];
}

const programSteps: ProgramStep[] = [
  {
    num: "01",
    title: "Medical Evaluation",
    desc: "Your journey starts with a thorough medical evaluation with a licensed physician, not a health coach, not a questionnaire reviewed by someone you'll never meet. We review your full health history, current medications, lab work, and weight loss goals to determine whether GLP-1 therapy is appropriate for you.",
    detail: "Not everyone is a candidate for semaglutide or tirzepatide, and we'll tell you upfront. If another approach is better suited to your situation, we'll point you in the right direction. No pressure, no upsell.",
    color: "#C9A84C",
    icon: "stethoscope",
  },
  {
    num: "02",
    title: "Personalized Treatment Plan",
    desc: "Based on your evaluation, your physician prescribes the medication and dosage that fits your medical profile. We offer both semaglutide (the active ingredient in Ozempic® and Wegovy®) and tirzepatide (the active ingredient in Mounjaro® and Zepbound®), with dosing protocols that follow clinical guidelines for safe, effective weight loss.",
    color: "#5DADE2",
    icon: "file-check",
    bullets: [
      "Prescribed GLP-1 medication at the clinically appropriate dose",
      "Dosage titration schedule tailored to your tolerance and response",
      "Baseline and follow-up lab work to monitor metabolic health markers",
      "Nutritional guidance to maximize results while on medication",
      "Side effect management protocols for nausea, constipation, and other common early responses",
    ],
  },
  {
    num: "03",
    title: "Ongoing Medical Monitoring",
    desc: "This isn't a \"get your prescription and figure it out\" operation. You have scheduled check-ins with your physician to track progress, adjust dosing, review labs, and address any concerns. We monitor the metrics that matter, not just the number on the scale, but blood pressure, A1C, cholesterol, liver function, and other markers that tell the full story of your health.",
    detail: "When your bloodwork improves, when your doctor takes you off your blood pressure medication, when your sleep apnea resolves... those are the wins that outlast any number on a scale.",
    color: "#34D399",
    icon: "heart-pulse",
  },
];

const timelinePhases = [
  {
    period: "Weeks 1–4",
    title: "Appetite Reduction Begins",
    desc: "Most patients notice a significant decrease in food noise (the constant background hum of cravings and hunger that's been running your decisions for years). Some early nausea is common and usually manageable.",
    color: "#C9A84C",
    icon: "brain",
  },
  {
    period: "Months 2–3",
    title: "Visible Weight Loss",
    desc: "Clothes fit differently. Energy levels improve. Friends and family start noticing. Lab work often shows early improvements in blood sugar, triglycerides, and cholesterol.",
    color: "#5DADE2",
    icon: "trending-down",
  },
  {
    period: "Months 4–6",
    title: "Substantial Results",
    desc: "Many patients report feeling like a different person, not just physically, but emotionally. Confidence returns. Activities that felt impossible become routine. Health markers continue to improve, and some patients begin reducing or eliminating other medications under their doctor's supervision.",
    color: "#34D399",
    icon: "zap",
  },
  {
    period: "Months 6–12+",
    title: "Target Weight & Maintenance",
    desc: "Patients approach or reach their target weight. The focus shifts to maintenance: sustaining the habits, adjusting medication as needed, and ensuring long-term metabolic health.",
    color: "#D4B96A",
    icon: "shield",
  },
] as const;

const candidateCriteria = [
  { icon: "scale", text: "BMI of 30 or higher (clinically obese), or BMI of 27+ with at least one weight-related health condition such as type 2 diabetes, high blood pressure, high cholesterol, or sleep apnea" },
  { icon: "calendar", text: "History of unsuccessful weight loss attempts through diet and exercise alone" },
  { icon: "heart-pulse", text: "Recent health scare or alarming lab results that make weight loss medically urgent" },
  { icon: "pill", text: "Currently managing obesity-related conditions and looking to reduce or eliminate medications" },
] as const;

const differentiators = [
  {
    icon: "dollar-sign",
    title: "Transparent Pricing, No Hidden Fees",
    desc: "We publish our pricing upfront because you deserve to know what you're paying before you walk through the door. No surprise supplement charges, no mandatory add-ons, no \"complex visit\" billing codes that inflate your bill.",
  },
  {
    icon: "stethoscope",
    title: "Real Physicians, Not Auto-Generated Coaching",
    desc: "Your care is managed by a licensed physician, not an algorithm, not a chatbot, not a health coach reading from a script. When you have a question about your medication, your side effects, or your labs, you talk to a doctor who knows your case.",
  },
  {
    icon: "zap",
    title: "Fast, Reliable Medication Access",
    desc: "Prescription delays are the #1 complaint across telehealth weight loss platforms. At Strong Health, we've built our process to eliminate the gaps. Your prescription is coordinated before your medication runs out, not three weeks after.",
  },
  {
    icon: "shield",
    title: "No Long-Term Contracts",
    desc: "We don't lock you into 6- or 12-month commitments. You stay because the program is working, not because you're trapped in a billing cycle. If you need to pause or stop, you can. No cancellation fees, no runaround.",
  },
  {
    icon: "file-check",
    title: "Insurance Coordination Support",
    desc: "GLP-1 insurance coverage is complex: employer exclusions, prior authorization requirements, formulary restrictions. We help you understand your coverage options and, where possible, assist with prior authorization submissions to maximize your benefits.",
  },
] as const;

const citations: Citation[] = [
  {
    id: 1,
    authors: "Wilding JPH, Batterham RL, Calanna S, et al",
    title: "Once-Weekly Semaglutide in Adults with Overweight or Obesity (STEP 1)",
    journal: "N Engl J Med",
    year: 2021,
    url: "https://pubmed.ncbi.nlm.nih.gov/33567185/",
  },
  {
    id: 2,
    authors: "Jastreboff AM, Aronne LJ, Ahmad NN, et al",
    title: "Tirzepatide Once Weekly for the Treatment of Obesity (SURMOUNT-1)",
    journal: "N Engl J Med",
    year: 2022,
    url: "https://pubmed.ncbi.nlm.nih.gov/35658024/",
  },
  {
    id: 3,
    authors: "Rubino D, Abrahamsson N, Davies M, et al",
    title: "Effect of Continued Weekly Subcutaneous Semaglutide vs Placebo on Weight Loss Maintenance (STEP 4)",
    journal: "JAMA",
    year: 2021,
    url: "https://pubmed.ncbi.nlm.nih.gov/33755728/",
  },
  {
    id: 4,
    authors: "Frias JP, Davies MJ, Rosenstock J, et al",
    title: "Tirzepatide versus Semaglutide Once Weekly in Patients with Type 2 Diabetes (SURPASS-2)",
    journal: "N Engl J Med",
    year: 2021,
    url: "https://pubmed.ncbi.nlm.nih.gov/34170647/",
  },
];

const path = `/fl/${config.slug}/weight-loss-clinic/`;
const fullClinicAddress = `${config.clinic.streetAddress}, ${config.clinic.city}, ${config.clinic.state} ${config.clinic.postalCode}`;
const mapQuery = encodeURIComponent(`${config.clinic.name}, ${fullClinicAddress}`);

// No city-hub page exists at /fl/{slug}/ yet, so the city level is omitted
// from the breadcrumb trail. Every BreadcrumbList ListItem must include an
// `item` URL for valid structured data (Google Search Console flagged the
// unlinked city entry as a "Missing field 'item'" error), so the trail is
// Home → Florida → [Service Page].
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Florida", path: "/fl/" },
  { name: "Weight Loss Clinic", path: path },
];

const localProof: LocalProofData = {
  physicalClinic: config.physicalClinic ?? true,
  cityName: config.cityName,
  serviceName: "Medical Weight Loss",
  clinic: {
    name: config.clinic.name,
    streetAddress: config.clinic.streetAddress,
    city: config.clinic.city,
    state: config.clinic.state,
    postalCode: config.clinic.postalCode,
    phone: config.clinic.phone,
    hoursDisplay: config.clinic.hours,
  },
  parkingTransit: config.parkingTransit ?? config.directions,
  physicianAvailability:
    config.physicianAvailability ??
    defaultPhysicianAvailability(config.physicians[0]?.name),
  appointmentExpectations:
    config.appointmentExpectations ?? DEFAULT_APPOINTMENT_EXPECTATIONS,
  neighborhoodsServed: config.neighborhoods,
  reviewLinks:
    config.reviewLinks ?? defaultReviewLinks(config.cityName, config.clinic.name),
  relatedInternalLinks:
    config.relatedInternalLinks ??
    defaultRelatedInternalLinks(config.slug, config.cityName, "weight-loss"),
};

const otherCities = ALL_WEIGHT_LOSS_CITIES.filter((c) => c.slug !== config.slug);

// Port of the inline MedicalClinicJsonLd schema builder — emits identical JSON.
function medicalClinicSchema(): Record<string, unknown> {
  return {
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "@id": `https://www.stronghealth.com/#strong-health-${config.slug}`,
    name: config.clinic.name,
    ...(config.clinicImage ? { image: config.clinicImage } : {}),
    url: `https://www.stronghealth.com${path}`,
    telephone: config.clinic.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: config.clinic.streetAddress,
      addressLocality: config.clinic.city,
      addressRegion: config.clinic.state,
      postalCode: config.clinic.postalCode,
      addressCountry: "US",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: config.clinic.lat,
      longitude: config.clinic.lng,
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: config.clinic.hoursWeekday.opens,
        closes: config.clinic.hoursWeekday.closes,
      },
      ...(config.clinic.hoursSaturday
        ? [
            {
              "@type": "OpeningHoursSpecification",
              dayOfWeek: ["Saturday"],
              opens: config.clinic.hoursSaturday.opens,
              closes: config.clinic.hoursSaturday.closes,
            },
          ]
        : []),
    ],
    medicalSpecialty: "Bariatric Medicine",
    ...(config.schemaEmployees && config.schemaEmployees.length > 0
      ? {
          employee: config.schemaEmployees.map((e) => ({
            "@type": "Physician",
            name: e.name,
            jobTitle: e.jobTitle,
            medicalSpecialty: e.medicalSpecialty,
            qualifications: e.qualifications,
          })),
        }
      : {}),
    availableService: [
      {
        "@type": "MedicalTherapy",
        name: "GLP-1 Medical Weight Loss Program",
        description: `Physician-supervised weight loss using semaglutide and tirzepatide with ongoing medical monitoring in ${config.cityName}, FL.`,
        medicineSystem: "WesternConventional",
      },
      {
        "@type": "MedicalTest",
        name: "Metabolic Health Panel",
        description: "Comprehensive lab work including blood sugar, A1C, cholesterol, liver function, triglycerides, and other metabolic health markers.",
      },
    ],
    areaServed: [
      {
        "@type": "City",
        name: config.cityName,
        ...(config.citySameAs ? { sameAs: config.citySameAs } : {}),
      },
      {
        "@type": "AdministrativeArea",
        name: config.county,
        ...(config.countySameAs ? { sameAs: config.countySameAs } : {}),
      },
    ],
    hasMap: `https://maps.google.com/maps?q=${mapQuery}`,
    isAcceptingNewPatients: true,
    currenciesAccepted: "USD",
    paymentAccepted: "Cash, Credit Card, Debit Card",
    parentOrganization: { "@id": "https://www.stronghealth.com/#organization" },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: config.reviewRating,
      reviewCount: String(config.aggregateReviewCount),
    },
    priceRange: "$$",
    ...(config.schemaSameAs && config.schemaSameAs.length > 0
      ? { sameAs: config.schemaSameAs }
      : {}),
  };
}
---

<BaseLayout title={config.seoTitle} description={config.seoDescription} path={path}>
  <PageShell>
    {(config.physicalClinic ?? true) && <JsonLd schema={medicalClinicSchema()} />}
    <JsonLd
      schema={medicalWebPageSchema({
        name: config.seoTitle,
        description: config.seoDescription,
        url: path,
        lastReviewed: "2026-04-01",
        reviewedBy: {
          name: config.reviewedByName,
          credentials: "Board-Certified",
          role: config.reviewedByRole,
        },
      })}
    />
    <JsonLd schema={faqPageSchema(config.faqs)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {
            breadcrumbs.map((crumb, i) => {
              const isLast = i === breadcrumbs.length - 1;
              return (
                <li class="flex items-center gap-1.5">
                  {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
                  {isLast ? (
                    <span class="text-gold font-semibold">{crumb.name}</span>
                  ) : crumb.path ? (
                    <a href={crumb.path} class="hover:text-gold transition-colors">
                      {crumb.name}
                    </a>
                  ) : (
                    <span>{crumb.name}</span>
                  )}
                </li>
              );
            })
          }
        </ol>
      </div>
    </nav>

    {/* CityHero */}
    <section class="relative px-8 pt-12 pb-24 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">{config.reviewRating}</span>
          <span class="text-[13px] text-muted">{config.reviewCount}</span>
        </div>

        <Tag>{config.heroTag}</Tag>

        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[720px] tracking-[-1.5px]">
          {`Weight Loss Clinic in ${config.cityName}. `}
          <span class="text-gold">Physician-supervised. FDA-backed.</span>
        </h1>

        <p class="text-[17px] text-muted leading-relaxed max-w-[560px] mb-8">
          {config.heroSubtitle}
        </p>

        <Btn trackLead>Book Your Free Assessment →</Btn>
        <div class="mt-4 text-xs text-muted">
          No commitment · No insurance needed · 15–20 min in-person visit
        </div>
      </div>
    </section>

    {/* WhyDietsFail */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <FadeIn>
            <Tag>The Science Behind Your Struggle</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              Why Nothing Has Worked — <span class="text-gold">Until Now</span>
            </h2>
            <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
              <p>
                Here's what most weight loss programs won't tell you: research shows that fewer than 5%
                of people who lose weight through dieting alone keep it off after five years. Not because
                they stopped trying, because the body actively fights back.
              </p>
              <p>
                When you lose weight, your metabolism slows down. Your hunger hormones spike. Your brain
                sends louder and louder signals to eat. It's not willpower failure. It's your body doing
                exactly what it's designed to do: protect its fat stores.
              </p>
              <p>
                A <a href="/dexa-scan/" class="text-gold hover:underline">DEXA body composition scan</a> can
                reveal the full picture: how much visceral fat you're carrying, your lean mass, and where
                you're starting from.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-raised rounded-2xl p-8 border border-white/10">
              <h3 class="text-lg font-bold text-cream mb-5">How GLP-1 medications change the equation</h3>
              <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
                <p>
                  Semaglutide and tirzepatide work directly on the hormones that control hunger and
                  satiety. They quiet the constant noise, the cravings that hijack your decisions,
                  the obsessive food thoughts that make every meal a negotiation.
                </p>
                <p>
                  Patients describe it the same way over and over: for the first time in their lives,
                  they're not thinking about food every second of the day.
                </p>
                <p class="text-gold font-semibold">
                  That's not a shortcut. That's medicine addressing the root cause.
                </p>
                <div class="mt-4">
                  <Btn trackLead variant="outline">Learn If GLP-1 Is Right for You →</Btn>
                </div>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* LocalPhysicians */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Your {config.cityName} Physicians</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Named doctors. <span class="text-gold">Real credentials.</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[500px] mx-auto">
            No anonymous "providers." You'll know exactly who's managing your treatment.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-5">
          {
            config.physicians.map((doc, i) => (
              <FadeIn delay={i * 150}>
                <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#C9A84C]/20 to-[#141820] border border-white/10 flex items-center justify-center mb-4">
                    <Icon name="user-check" size={28} class="text-gold" />
                  </div>
                  <h3 class="text-lg font-bold text-cream mb-1">{doc.name}</h3>
                  <div class="text-[11px] font-bold text-gold tracking-wider uppercase mb-3">{doc.title}</div>
                  <p class="text-[12px] text-muted leading-relaxed mb-3 border-b border-white/5 pb-3">{doc.credentials}</p>
                  <p class="text-[13px] text-cream-muted leading-relaxed flex-grow">{doc.focus}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* HowItWorks */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Our GLP-1 Weight Loss Program</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            How Our {config.cityName} Weight Loss Program <span class="text-gold">Works</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            Built around three principles: physician oversight, medication access, and ongoing
            accountability. No gimmicks, no meal replacement shakes, no mandatory supplement purchases.
          </p>
        </FadeIn>

        <div class="flex flex-col gap-6">
          {
            programSteps.map((s, i) => (
              <FadeIn delay={i * 100}>
                <div
                  class="bg-surface-card rounded-[14px] p-6 md:p-8 border border-white/10 hover:border-white/20 transition-colors"
                  style={`border-left:4px solid ${s.color}`}
                >
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center border border-white/10" style={`color:${s.color};background-color:${s.color}10`}>
                      <Icon name={s.icon} size={24} />
                    </div>
                    <div>
                      <div class="text-[13px] font-bold tracking-wider uppercase" style={`color:${s.color}`}>Step {s.num}</div>
                      <h3 class="text-xl font-bold text-cream">{s.title}</h3>
                    </div>
                  </div>
                  <p class="text-[15px] text-muted leading-[1.7] mb-3">{s.desc}</p>
                  {s.detail && (
                    <p class="text-[14px] text-cream-muted leading-[1.7] italic">{s.detail}</p>
                  )}
                  {s.bullets && (
                    <div class="mt-4 flex flex-col gap-2.5">
                      {s.bullets.map((b) => (
                        <div class="flex items-start gap-3">
                          <div class="w-5 h-5 rounded-full bg-[#34D399]/10 flex items-center justify-center shrink-0 mt-0.5">
                            <Icon name="check" size={11} class="text-[#34D399] [stroke-width:3]" />
                          </div>
                          <span class="text-[14px] text-cream-muted leading-[1.5]">{b}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </FadeIn>
            ))
          }
        </div>

        <FadeIn delay={400} class="mt-10 text-center">
          <Btn trackLead>See If You Qualify →</Btn>
        </FadeIn>
      </div>
    </section>

    {/* ResultsTimeline */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-4">
          <Tag>What to Expect</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            What Results Can You Expect from <span class="text-gold">GLP-1 Weight Loss Medication?</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[640px] mx-auto mb-6">
            Clinical trials for semaglutide showed an average weight loss of approximately 15% of body
            weight over 68 weeks<sup class="text-gold">[1]</sup>. Tirzepatide trials showed even higher averages, up to 22.5% of body
            weight in some study arms<sup class="text-gold">[2]</sup>.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-4 gap-4">
          {
            timelinePhases.map((p, i) => (
              <FadeIn delay={i * 100}>
                <div
                  class="bg-surface-raised rounded-[14px] p-6 border border-white/10 h-full hover:border-white/20 transition-colors"
                  style={`border-top:3px solid ${p.color}`}
                >
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-3 border border-white/5" style={`color:${p.color};background-color:${p.color}10`}>
                    <Icon name={p.icon} size={22} />
                  </div>
                  <div class="text-[13px] font-bold tracking-wider uppercase mb-1" style={`color:${p.color}`}>{p.period}</div>
                  <h3 class="text-base font-bold text-cream mb-3">{p.title}</h3>
                  <p class="text-[13px] text-muted leading-relaxed">{p.desc}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>

        <FadeIn delay={500}>
          <p class="text-[15px] text-muted leading-[1.7] mt-8 max-w-[700px] mx-auto text-center">
            The weight loss is real. But what patients tell us matters even more is what comes with it:
