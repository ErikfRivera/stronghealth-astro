---
import FadeIn from "./FadeIn.astro";
import Icon from "./Icon.astro";
import { ALL_CITIES } from "../../data/local/cityTrtConfig";

interface Props {
  variant?: "section" | "inline";
}

const { variant = "section" } = Astro.props;
const linkClass =
  "text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C9A84C]";
---

{
  variant === "inline" ? (
    <div class="mb-10">
      <div class="flex items-center justify-between flex-wrap gap-3 mb-6">
        <div>
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gold mb-2 block">
            Find a Location Near You
          </span>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.1]">
            Strong Health Clinic Locations
          </h2>
        </div>
        <a href="/fl/" class={linkClass}>
          View all Florida locations →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {ALL_CITIES.map((city) => (
          <div class="flex flex-col h-full rounded-xl border border-white/10 bg-surface-card/60 p-4 hover:border-gold/30 transition-colors">
            <div class="flex items-center gap-1.5 mb-2">
              <Icon name="map-pin" size={13} class="text-gold shrink-0" />
              <span class="text-[13px] font-bold text-cream leading-tight">{city.clinicName}</span>
            </div>
            <div class="text-[11px] text-muted mb-3">
              {city.area}, {city.name}, FL
            </div>
            <div class="mt-auto flex flex-col gap-1.5">
              <a href={`/fl/${city.slug}/trt-therapy/`} class={linkClass}>
                TRT Therapy →
              </a>
              <a href={`/fl/${city.slug}/weight-loss-clinic/`} class={linkClass}>
                Weight Loss Clinic →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  ) : (
    <section class="relative px-8 py-16 border-t border-white/5">
      <div class="max-w-[1100px] mx-auto">
        <FadeIn>
          <div class="flex items-center justify-between flex-wrap gap-3 mb-6">
            <div>
              <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gold mb-2 block">
                Find a Location Near You
              </span>
              <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.1]">
                Strong Health Clinic Locations
              </h2>
            </div>
            <a href="/fl/" class={linkClass}>
              View all Florida locations →
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {ALL_CITIES.map((city) => (
              <div class="flex flex-col h-full rounded-xl border border-white/10 bg-surface-card/60 p-4 hover:border-gold/30 transition-colors">
                <div class="flex items-center gap-1.5 mb-2">
                  <Icon name="map-pin" size={13} class="text-gold shrink-0" />
                  <span class="text-[13px] font-bold text-cream leading-tight">{city.clinicName}</span>
                </div>
                <div class="text-[11px] text-muted mb-3">
                  {city.area}, {city.name}, FL
                </div>
                <div class="mt-auto flex flex-col gap-1.5">
                  <a href={`/fl/${city.slug}/trt-therapy/`} class={linkClass}>
                    TRT Therapy →
                  </a>
                  <a href={`/fl/${city.slug}/weight-loss-clinic/`} class={linkClass}>
                    Weight Loss Clinic →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>
  )
}
