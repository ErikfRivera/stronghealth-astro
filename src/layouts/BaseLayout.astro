---
/**
 * The single HTML skeleton for every page. All head tags flow through
 * <Seo /> (FR-3); pages must never emit their own <title> / meta tags.
 *
 * Third-party scripts (same IDs as production index.html):
 *  - Google AdSense (ca-pub-7951814481749634)
 *  - Ahrefs analytics (mUsqdURGMvgEYUov5WFjXw)
 *  - GA4 (G-ESG16019L2)
 * plus the LeadConnector chat widget, injected on scroll ≥ 300px or after
 * 8s (port of src/lib/loadChatWidget.ts — now in src/scripts/site-runtime.ts,
 * loaded once at the end of <body> as a shared external module).
 */
import "../styles/global.css";
import Seo from "../components/seo/Seo.astro";
import MobileStickyCta from "../components/shared/MobileStickyCta.astro";

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, path, ogImage, ogType, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0D0F12" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/dm-sans-latin-900.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/dm-sans-latin-400.woff2" crossorigin />
    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <slot name="head" />
    <meta name="google-adsense-account" content="ca-pub-7951814481749634" />
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7951814481749634"
      crossorigin="anonymous"></script>
    <script
      is:inline
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="mUsqdURGMvgEYUov5WFjXw"
      async></script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-ESG16019L2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ESG16019L2');
    </script>
  </head>
  <body>
    <slot />
    <!-- Mobile-only sticky CTA; reveals on scroll (see site-runtime.ts). -->
    <MobileStickyCta />
    <!-- Shared client runtime (mobile nav, fade-ins, GA4 lead tracking, chat
         widget loader) as one hashed, cacheable module — see
         src/scripts/site-runtime.ts (Phase 8). -->
    <script src="../scripts/site-runtime.ts"></script>
  </body>
</html>
