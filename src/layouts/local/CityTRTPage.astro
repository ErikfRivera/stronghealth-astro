---
/**
 * Port of src/pages/local/CityTRTPage.tsx — config-driven city TRT landing
 * page (hero, symptoms, USPs, clinic details, local proof, physicians,
 * testimonials, neighborhoods, nearby cities, FAQ, final CTA) plus the
 * MedicalClinic / MedicalWebPage / FAQPage / BreadcrumbList JSON-LD.
 */
import BaseLayout from "../BaseLayout.astro";
import PageShell from "../../components/shared/PageShell.astro";
import FadeIn from "../../components/shared/FadeIn.astro";
import Btn from "../../components/shared/Btn.astro";
import Tag from "../../components/shared/Tag.astro";
import Icon from "../../components/shared/Icon.astro";
import FAQSection from "../../components/shared/FAQSection.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import LocalProofSection from "../../components/local/LocalProofSection.astro";
import {
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../components/seo/schemas";
import { ALL_CITIES, type CityTRTConfig } from "../../data/local/cityTrtConfig";
import {
  defaultReviewLinks,
  defaultRelatedInternalLinks,
  defaultPhysicianAvailability,
  DEFAULT_APPOINTMENT_EXPECTATIONS,
  type LocalProofData,
} from "../../data/local/cityLocalProof";

interface Props {
  config: CityTRTConfig;
}

const { config } = Astro.props;

// No city-hub page exists at /fl/{slug}/ yet, so the city level is omitted
// from the breadcrumb trail. Every BreadcrumbList ListItem must include an
// `item` URL for valid structured data (Google Search Console flagged the
// unlinked city entry as a "Missing field 'item'" error), so the trail is
// Home → Florida → [Service Page].
const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Florida", path: "/fl/" },
  { name: "TRT Therapy", path: `/fl/${config.slug}/trt-therapy/` },
];

const fullAddress = `${config.clinic.streetAddress}, ${config.clinic.city}, ${config.clinic.state} ${config.clinic.postalCode}`;
const mapsQuery = encodeURIComponent(`${config.clinic.name}, ${fullAddress}`);

const physicalClinic = config.physicalClinic ?? true;

const localProof: LocalProofData = {
  physicalClinic,
  cityName: config.cityName,
  serviceName: "Testosterone Therapy",
  clinic: {
    name: config.clinic.name,
    streetAddress: config.clinic.streetAddress,
    city: config.clinic.city,
    state: config.clinic.state,
    postalCode: config.clinic.postalCode,
    phone: config.clinic.phone,
    hoursDisplay: config.clinic.hours,
  },
  parkingTransit: config.parkingTransit ?? config.directions,
  physicianAvailability:
    config.physicianAvailability ??
    defaultPhysicianAvailability(config.physicians[0]?.name),
  appointmentExpectations:
    config.appointmentExpectations ?? DEFAULT_APPOINTMENT_EXPECTATIONS,
  neighborhoodsServed: config.neighborhoods,
  reviewLinks:
    config.reviewLinks ?? defaultReviewLinks(config.cityName, config.clinic.name),
  relatedInternalLinks:
    config.relatedInternalLinks ??
    defaultRelatedInternalLinks(config.slug, config.cityName, "trt"),
};

// Port of the inline MedicalClinicJsonLd from CityTRTPage.tsx — emits the
// identical JSON object.
function medicalClinicSchema(cfg: CityTRTConfig, address: string) {
  const openingHoursSpecification: Array<Record<string, unknown>> = [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: cfg.clinic.hoursWeekday.opens,
      closes: cfg.clinic.hoursWeekday.closes,
    },
  ];
  if (cfg.clinic.hoursSaturday) {
    openingHoursSpecification.push({
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: cfg.clinic.hoursSaturday.opens,
      closes: cfg.clinic.hoursSaturday.closes,
    });
  }

  return {
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "@id": `https://www.stronghealth.com/#strong-health-${cfg.slug}`,
    name: cfg.clinic.name,
    url: `https://www.stronghealth.com/fl/${cfg.slug}/trt-therapy/`,
    telephone: cfg.clinic.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: cfg.clinic.streetAddress,
      addressLocality: cfg.clinic.city,
      addressRegion: cfg.clinic.state,
      postalCode: cfg.clinic.postalCode,
      addressCountry: "US",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: cfg.clinic.lat,
      longitude: cfg.clinic.lng,
    },
    openingHoursSpecification,
    medicalSpecialty: "Endocrinology",
    availableService: [
      {
        "@type": "MedicalTherapy",
        name: "Testosterone Replacement Therapy (TRT)",
        description: `Physician-supervised TRT with in-person exams, 50+ biomarker labs, and telehealth follow-ups in ${cfg.cityName}, FL.`,
        medicineSystem: "WesternConventional",
      },
      {
        "@type": "MedicalTest",
        name: "Comprehensive Hormone Panel",
        description: `50+ biomarker lab panel including total and free testosterone, SHBG, estradiol, thyroid, metabolic markers, and more. Drawn on-site at our ${cfg.cityName} clinic.`,
      },
      {
        "@type": "MedicalTherapy",
        name: "Telehealth Follow-ups",
        description: `Ongoing dosing adjustments, lab reviews, and physician check-ins via telehealth for ${cfg.cityName}-area patients.`,
      },
    ],
    areaServed: [
      {
        "@type": "City",
        name: cfg.cityName,
      },
      {
        "@type": "AdministrativeArea",
        name: cfg.county,
      },
    ],
    hasMap: `https://maps.google.com/maps?q=${encodeURIComponent(`${cfg.clinic.name}, ${address}`)}`,
    isAcceptingNewPatients: true,
    currenciesAccepted: "USD",
    paymentAccepted: "Cash, Credit Card, Debit Card",
    parentOrganization: { "@id": "https://www.stronghealth.com/#organization" },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: cfg.reviewRating,
      reviewCount: String(cfg.aggregateReviewCount),
    },
    priceRange: "$$",
  };
}

// ProblemValidation symptoms (icons rendered via <Icon /> in the template).
const symptoms = [
  { icon: "zap", text: "Persistent fatigue that sleep doesn't fix" },
  { icon: "brain", text: "Loss of focus, motivation, mental sharpness" },
  { icon: "trending-down", text: "Decreased libido and sexual performance" },
  { icon: "dumbbell", text: "Losing muscle, gaining fat, despite effort" },
  { icon: "frown", text: "Mood swings, irritability, brain fog" },
];

// USPCards content.
const usps = [
  { icon: "microscope", title: "50+ Biomarkers", desc: "The most thorough lab panel in testosterone therapy, not just total T." },
  { icon: "hospital", title: "Real Physical Exams", desc: "Your first visit is always face-to-face. A real exam, not a video call." },
  { icon: "shield-check", title: "Board-Certified Physicians", desc: "Named, credentialed doctors, not anonymous telehealth \"providers.\"" },
  { icon: "smartphone", title: "Telehealth After", desc: "Ongoing optimization from home after your in-person baseline visit." },
  { icon: "shield", title: "FDA-Approved Medications", desc: "Pharmaceutical-grade testosterone. No supplements. No gray-market compounds." },
  { icon: "clipboard-check", title: "No Long-Term Contracts", desc: "Month-to-month treatment. Stay because it works, not because you're locked in." },
];

// HowItWorks steps.
const steps = [
  {
    num: "01",
    title: config.step1Title,
    desc: config.step1Desc,
    color: "#C9A84C",
  },
  {
    num: "02",
    title: "Get Your Full Lab Results",
    desc: "Within 48–72 hours, your full results are ready. Your physician reviews every marker and builds a custom protocol tailored to your biology.",
    color: "#5DADE2",
  },
  {
    num: "03",
    title: "Start Your Treatment",
    desc: "If TRT is right for you, your physician prescribes FDA-approved testosterone. Medications shipped to your door or available at your local pharmacy.",
    color: "#34D399",
  },
  {
    num: "04",
    title: "Optimize via Telehealth",
    desc: config.step4Desc,
    color: "#D4B96A",
  },
];

const physicianCols = config.physicians.length === 2 ? "md:grid-cols-2" : "md:grid-cols-3";

const nearbyCities = ALL_CITIES.filter((c) => c.slug !== config.slug).slice(0, 8);

const clinicPhotoLabels = ["Clinic Lobby", "Lab Draw Room", "Consultation Suite", "Patient Lounge"];
---

<BaseLayout
  title={config.seoTitle}
  description={config.seoDescription}
  path={`/fl/${config.slug}/trt-therapy/`}
>
  <PageShell>
    {physicalClinic && <JsonLd schema={medicalClinicSchema(config, fullAddress)} />}
    <JsonLd
      schema={medicalWebPageSchema({
        name: config.seoTitle,
        description: config.seoDescription,
        url: `/fl/${config.slug}/trt-therapy/`,
        lastReviewed: "2026-04-01",
        reviewedBy: {
          name: config.reviewedByName,
          credentials: "Board-Certified",
          role: config.reviewedByRole,
        },
      })}
    />
    <JsonLd schema={faqPageSchema(config.faqs)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {
            breadcrumbs.map((crumb, i) => {
              const isLast = i === breadcrumbs.length - 1;
              return (
                <li class="flex items-center gap-1.5">
                  {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
                  {isLast ? (
                    <span class="text-gold font-semibold">{crumb.name}</span>
                  ) : crumb.path ? (
                    <a href={crumb.path} class="hover:text-gold transition-colors">
                      {crumb.name}
                    </a>
                  ) : (
                    <span>{crumb.name}</span>
                  )}
                </li>
              );
            })
          }
        </ol>
      </div>
    </nav>

    {/* CityHero */}
    <section class="relative px-8 pt-12 pb-24 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">{config.reviewRating}</span>
          <span class="text-[13px] text-muted">{config.reviewCount}</span>
        </div>

        <Tag>{config.heroTag}</Tag>

        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[720px] tracking-[-1.5px]">
          {`Testosterone Therapy in ${config.cityName}, FL. `}<span class="text-gold">Physician-supervised. Evidence-based.</span>
        </h1>

        <p class="text-[17px] text-muted leading-relaxed max-w-[560px] mb-8">
          {config.heroSubtitle}
        </p>

        <Btn trackLead>Book Your Free Assessment →</Btn>
        <div class="mt-4 text-xs text-muted">
          No commitment · No insurance needed · 15–20 min in-person visit
        </div>
      </div>
    </section>

    {/* ProblemValidation */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <FadeIn>
            <Tag>Sound Familiar?</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              These symptoms aren't "just aging." <span class="text-gold">They're treatable.</span>
            </h2>
            <p class="text-[15px] text-muted leading-[1.7] mb-6">
              If you're a man in {config.cityName} experiencing any of these, your testosterone levels
              may be clinically low. It's not about willpower. It's biology.
            </p>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="flex flex-col gap-3.5">
              {
                symptoms.map((s) => (
                  <div class="flex items-center gap-3 bg-surface-raised rounded-xl p-4 border border-white/5">
                    <div class="w-9 h-9 rounded-full bg-surface flex items-center justify-center shrink-0 border border-white/5">
                      <Icon name={s.icon} size={18} class="text-gold" />
                    </div>
                    <span class="text-sm text-cream-muted">{s.text}</span>
                  </div>
                ))
              }
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* USPCards */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Why Strong Health</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            What makes us <span class="text-gold">different</span>
          </h2>
        </FadeIn>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          {
            usps.map((u, i) => (
              <FadeIn delay={i * 80}>
                <div class="bg-surface-card rounded-xl p-6 border border-white/10 h-full hover:bg-surface-raised transition-colors">
                  <div class="text-gold mb-4 p-3 rounded-xl bg-surface-raised border border-white/5 w-fit">
                    <Icon name={u.icon} size={28} />
                  </div>
                  <h3 class="text-[15px] font-bold text-cream mb-2">{u.title}</h3>
                  <p class="text-[13px] text-muted leading-relaxed">{u.desc}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* LocalClinicDetails */}
    {
      physicalClinic && (
        <section class="px-8 py-20 bg-surface border-b border-white/5">
          <div class="max-w-[1000px] mx-auto">
            <FadeIn class="text-center mb-10">
              <Tag>Our {config.cityName} Clinic</Tag>
              <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
                Visit Us in <span class="text-gold">{config.clinicArea}</span>
              </h2>
              <p class="text-[15px] text-muted max-w-[540px] mx-auto">{config.clinicAreaBlurb}</p>
            </FadeIn>

            <div class="grid md:grid-cols-2 gap-6">
              <FadeIn>
                <div class="bg-surface-card rounded-2xl border border-white/10 overflow-hidden h-full">
                  <iframe
                    src={`https://maps.google.com/maps?q=${mapsQuery}&output=embed`}
                    class="w-full h-[240px] border-0"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title={`${config.clinic.name} - ${config.clinic.streetAddress}`}
                  />
                  <div class="p-6 flex flex-col gap-4">
                    <div class="flex items-start gap-3">
                      <Icon name="map-pin" size={16} class="text-gold shrink-0 mt-0.5" />
                      <div>
                        <div class="text-sm font-bold text-cream">{config.clinic.name}</div>
                        <div class="text-sm text-cream-muted mt-0.5">{fullAddress}</div>
                      </div>
                    </div>
                    <div class="flex items-start gap-3">
                      <Icon name="phone" size={16} class="text-gold shrink-0 mt-0.5" />
                      <div class="text-sm text-cream-muted">{config.clinic.phone}</div>
                    </div>
                    <div class="flex items-start gap-3">
                      <Icon name="clock" size={16} class="text-gold shrink-0 mt-0.5" />
                      <div class="text-sm text-cream-muted">{config.clinic.hours}</div>
                    </div>
                    <div class="flex items-start gap-3">
                      <Icon name="navigation" size={16} class="text-gold shrink-0 mt-0.5" />
                      <div class="text-xs text-muted leading-relaxed">{config.directions}</div>
                    </div>
                  </div>
                </div>
              </FadeIn>

              <FadeIn delay={200}>
                <div class="grid grid-cols-2 gap-3 h-full">
                  {clinicPhotoLabels.map((label) => (
                    <div class="bg-surface-card rounded-xl border border-white/10 flex items-center justify-center aspect-square">
                      <div class="text-center p-4">
                        <div class="w-10 h-10 rounded-lg bg-surface-raised border border-white/5 flex items-center justify-center mx-auto mb-2">
                          <Icon name="hospital" size={18} class="text-gold" />
                        </div>
                        <p class="text-[11px] text-muted">{label}</p>
                        <p class="text-[9px] text-text-subtle mt-0.5">Photo placeholder</p>
                      </div>
                    </div>
                  ))}
                </div>
              </FadeIn>
            </div>
          </div>
        </section>
      )
    }

    <LocalProofSection data={localProof} />

    {/* CityIntro */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <FadeIn>
            <Tag>Why {config.cityName} Men Choose Us</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-5">
              Built for men who take <span class="text-gold">{config.paceLine}</span> seriously
            </h2>
            <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
              {config.introParagraphs.map((p) => <p>{p}</p>)}
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-raised rounded-2xl p-8 border border-white/10">
              <h3 class="text-lg font-bold text-cream mb-5">What sets us apart in {config.cityName}</h3>
              {
                config.differentiators.map((item) => (
                  <div class="flex items-start gap-3 mb-3.5">
                    <div class="w-5 h-5 rounded-full bg-[#34D399]/10 flex items-center justify-center shrink-0 mt-0.5">
                      <Icon name="check" size={11} class="text-[#34D399] stroke-[3]" />
                    </div>
                    <span class="text-[14px] text-cream-muted leading-[1.5]">{item}</span>
                  </div>
                ))
              }
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* HowItWorks */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>How It Works</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Four steps. <span class="text-gold">Real treatment.</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[500px] mx-auto">
            From your first walk-in to ongoing optimization, here's exactly how it works.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-4 gap-4">
          {
            steps.map((s, i) => (
              <FadeIn delay={i * 100}>
                <div
                  class="bg-surface-card rounded-[14px] p-6 border border-white/10 h-full hover:border-white/20 transition-colors"
                  style={`border-top:3px solid ${s.color}`}
                >
                  <div class="text-[28px] font-black mb-3" style={`color:${s.color}`}>{s.num}</div>
                  <h3 class="text-base font-bold text-cream mb-3">{s.title}</h3>
                  <p class="text-[13px] text-muted leading-relaxed">{s.desc}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* LocalPhysicians */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Your {config.cityName} Physicians</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Named doctors. <span class="text-gold">Real credentials.</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[500px] mx-auto">
            No anonymous "providers." You'll know exactly who's managing your treatment.
          </p>
        </FadeIn>

        <div class={`grid ${physicianCols} gap-5`}>
          {
            config.physicians.map((doc, i) => (
              <FadeIn delay={i * 150}>
                <div class="bg-surface-raised rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#C9A84C]/20 to-[#1A1F2A] border border-white/10 flex items-center justify-center mb-4">
                    <Icon name="user-check" size={28} class="text-gold" />
                  </div>
                  <h3 class="text-lg font-bold text-cream mb-1">{doc.name}</h3>
                  <div class="text-[11px] font-bold text-gold tracking-wider uppercase mb-3">{doc.title}</div>
                  <p class="text-[12px] text-muted leading-relaxed mb-3 border-b border-white/5 pb-3">{doc.credentials}</p>
                  <p class="text-[13px] text-cream-muted leading-relaxed flex-grow">{doc.focus}</p>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* LocalTestimonials */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>{config.cityName} Patient Reviews</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Real results from <span class="text-gold">real {config.cityName} patients</span>
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-5">
          {
            config.testimonials.map((r, i) => (
              <FadeIn delay={i * 100}>
                <div class="bg-surface-raised rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                  <div class="flex items-center gap-2 mb-4">
                    <div class="flex gap-0.5">
                      {Array.from({ length: 5 }).map(() => (
                        <Icon name="star" size={13} class="fill-[#C9A84C] text-gold" />
                      ))}
                    </div>
                    <span class="text-[10px] text-muted uppercase tracking-wider font-semibold">Verified Patient</span>
                  </div>
                  <Icon name="quote" size={20} class="text-gold/30 mb-2" />
                  <p class="text-[13px] text-cream-muted leading-relaxed flex-grow mb-4">{r.text}</p>
                  <div class="border-t border-white/5 pt-3 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center">
                      <span class="text-[11px] font-bold text-gold">{r.name[0]}</span>
                    </div>
                    <div>
                      <div class="text-sm font-semibold text-cream">{r.name}</div>
                      <div class="text-[11px] text-muted">{r.neighborhood}, {config.cityName}</div>
                    </div>
                  </div>
                </div>
              </FadeIn>
            ))
          }
        </div>
      </div>
    </section>

    {/* NeighborhoodsServed */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Areas We Serve</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Serving neighborhoods across <span class="text-gold">{config.neighborhoodAreaName}</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            {config.neighborhoodSubtitle}
          </p>
        </FadeIn>

        <FadeIn delay={200}>
          <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 gap-3">
            {
              config.neighborhoods.map((n) => (
                <div class="bg-surface-card rounded-lg px-4 py-3 border border-white/10 text-center hover:border-gold/30 transition-colors">
                  <span class="text-[13px] font-medium text-cream-muted">{n}</span>
                </div>
              ))
            }
          </div>
        </FadeIn>
      </div>
    </section>

    {/* NearbyCities */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Nearby Locations</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            TRT therapy in <span class="text-gold">nearby cities</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[500px] mx-auto">
            Strong Health serves patients across South Florida. Explore locations near you.
          </p>
        </FadeIn>

        <FadeIn delay={200}>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {
              nearbyCities.map((c) => (
                <a
                  href={`/fl/${c.slug}/trt-therapy/`}
                  class="bg-surface-raised rounded-lg px-4 py-3.5 border border-white/10 text-center hover:border-gold/30 hover:bg-surface-raised/80 transition-colors group"
                >
                  <span class="text-[13px] font-semibold text-cream-muted group-hover:text-gold transition-colors">{c.name}, FL</span>
                  <div class="text-[10px] text-muted mt-0.5">TRT Therapy →</div>
                </a>
              ))
            }
          </div>
        </FadeIn>
      </div>
    </section>

    {/* LocalFAQ */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-2">
          <Tag>{config.cityName} TRT FAQ</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Common questions about <span class="text-gold">TRT in {config.cityName}</span>
          </h2>
        </FadeIn>
        <FAQSection items={config.faqs} />
      </div>
    </section>

    {/* FinalCTA */}
    <section class="px-8 py-24 bg-gradient-to-br from-[#C9A84C]/[0.08] to-[#0D0F12] border-b border-white/5">
      <div class="max-w-[700px] mx-auto text-center">
        <FadeIn>
          <h2 class="text-[36px] font-black text-cream leading-[1.1] mb-4">
            Ready to start TRT in {config.cityName}?
          </h2>
          <p class="text-[17px] text-muted leading-relaxed mb-8 max-w-[520px] mx-auto">
            {config.finalCtaCopy}
          </p>
          <Btn trackLead>Book Your Free Assessment →</Btn>
          <div class="mt-5 flex flex-wrap justify-center gap-4 text-xs text-muted">
            <span>No commitment</span>
            <span>·</span>
            <span>No insurance needed</span>
            <span>·</span>
            <span>Results in 48–72 hrs</span>
          </div>
          {
            config.relatedServiceLink && (
              <div class="mt-8 pt-6 border-t border-white/5 text-[13px] text-muted">
                Also available at this clinic:{" "}
                <a href={config.relatedServiceLink.href} class="text-gold font-semibold hover:underline">
                  {config.relatedServiceLink.label} →
                </a>
              </div>
            )
          }
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
