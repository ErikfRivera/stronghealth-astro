---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<ul class="flex flex-col gap-2 mb-4 pl-1">
  {
    items.map((item) => (
      <li class="flex items-start gap-3 text-[15px] text-muted leading-[1.6]">
        <span class="text-gold mt-1 shrink-0">&bull;</span>
        <span>{item}</span>
      </li>
    ))
  }
</ul>
