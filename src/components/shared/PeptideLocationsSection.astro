---
// Peptide therapy locations grid — links the homepage to every city
// peptide-therapy page. Card data is derived from the same configs that
// render the city pages, so new cities appear here automatically once
// their config + page wrapper exist.
import FadeIn from "./FadeIn.astro";
import Icon from "./Icon.astro";
import {
  MIAMI_PEPTIDE_CONFIG,
  DELRAY_BEACH_PEPTIDE_CONFIG,
  TAMPA_PEPTIDE_CONFIG,
  NEW_YORK_PEPTIDE_CONFIG,
  SAN_DIEGO_PEPTIDE_CONFIG,
  LAS_VEGAS_PEPTIDE_CONFIG,
  ATLANTA_PEPTIDE_CONFIG,
  AUSTIN_PEPTIDE_CONFIG,
  type CityPeptideConfig,
} from "../../data/local/cityPeptideConfig";

const configs: CityPeptideConfig[] = [
  MIAMI_PEPTIDE_CONFIG,
  DELRAY_BEACH_PEPTIDE_CONFIG,
  TAMPA_PEPTIDE_CONFIG,
  NEW_YORK_PEPTIDE_CONFIG,
  SAN_DIEGO_PEPTIDE_CONFIG,
  LAS_VEGAS_PEPTIDE_CONFIG,
  ATLANTA_PEPTIDE_CONFIG,
  AUSTIN_PEPTIDE_CONFIG,
];

const locations = configs.map((c) => ({
  cityName: c.cityName,
  state: c.clinic.state,
  href: `/${c.statePrefix ?? "fl"}/${c.slug}/peptide-therapy/`,
  inPerson: c.physicalClinic !== false,
  detail:
    c.physicalClinic !== false
      ? `In-person visits & on-site labs · ${c.clinicArea}`
      : "Telehealth visits with local lab draws",
}));
---

<section class="relative px-8 py-16 border-t border-white/5 bg-surface-card">
  <div class="max-w-[1100px] mx-auto">
    <FadeIn>
      <div class="flex items-center justify-between flex-wrap gap-3 mb-6">
        <div>
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gold mb-2 block">
            Physician-Supervised Peptide Therapy
          </span>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-[1.1] text-cream">
            Peptide Therapy Locations
          </h2>
          <p class="text-[13px] text-muted mt-2 max-w-[560px]">
            In-person care at our Miami Brickell clinic, and telehealth programs with local
            lab draws for patients in the cities below.
          </p>
        </div>
        <a
          href="/peptides/"
          class="text-[12px] font-semibold text-gold hover:text-gold-hover transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C9A84C]"
        >
          Learn about peptide therapy →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {locations.map((loc) => (
          <a
            href={loc.href}
            class="flex flex-col h-full rounded-xl border border-white/10 bg-surface-raised/60 p-4 hover:border-gold/40 focus-visible:border-gold/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/50 transition-colors group"
          >
            <div class="flex items-center gap-1.5 mb-2">
              <Icon
                name={loc.inPerson ? "map-pin" : "smartphone"}
                size={13}
                class="text-gold shrink-0"
              />
              <span class="text-[13px] font-bold text-cream leading-tight">
                {loc.cityName}, {loc.state}
              </span>
            </div>
            <div class="text-[11px] text-muted mb-3">{loc.detail}</div>
            <span class="mt-auto text-[12px] font-semibold text-gold group-hover:text-gold-hover transition-colors">
              Peptide Therapy in {loc.cityName}
              <span class="inline-block group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </a>
        ))}
      </div>
    </FadeIn>
  </div>
</section>
