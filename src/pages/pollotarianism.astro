---
// /pollotarianism/ — poultry-only semi-vegetarian diet guide. Follows the
// diet-article pattern established by /stillman-diet/ and /semaglutide-diet/
// (BlogArticleLayout + HTML fragments + AccordionFoodList).
import BlogArticleLayout from "../layouts/BlogArticleLayout.astro";
import AccordionFoodList from "../components/diet/AccordionFoodList.astro";
import { faqPageSchema } from "../components/seo/schemas";
import { ARTICLE_AUTHORSHIP } from "../data/articleAuthors";
import body0 from "../content/fragments/pollotarianism.0.html?raw";
import body1 from "../content/fragments/pollotarianism.1.html?raw";
import body2 from "../content/fragments/pollotarianism.2.html?raw";

const path = "/pollotarianism/";
const { author, reviewer } = ARTICLE_AUTHORSHIP[path]!;

const faqs = [{"question": "What is a pollotarian?", "answer": "A pollotarian is someone who eats poultry (chicken, turkey, duck) but no other meat. Beef, pork, lamb, and game are excluded, and strict pollotarians also skip fish and seafood. The rest of the diet is built around vegetables, fruits, whole grains, legumes, nuts, and seeds, with eggs and dairy as optional additions. It's considered a semi-vegetarian eating pattern, alongside pescatarianism and flexitarianism."}, {"question": "What does the word 'pollotarian' mean and how do you pronounce it?", "answer": "The word combines 'pollo' — Spanish and Italian for chicken — with the '-tarian' suffix from vegetarian. It's pronounced 'pull-oh-TAIR-ee-un.' You'll also see the same diet called pollo-vegetarianism or, informally, a chicketarian diet. The pattern has no single founder or official rulebook; it emerged as a named point on the semi-vegetarian spectrum."}, {"question": "Do pollotarians eat fish?", "answer": "Strict pollotarians don't eat fish or seafood — poultry is the only animal flesh in the diet. People who eat both poultry and fish while avoiding red meat follow a pesce-pollotarian diet. Nutritionally, adding fish is the strongest upgrade to a pollotarian pattern because fatty fish supplies the long-chain omega-3s (EPA and DHA) that poultry lacks."}, {"question": "Do pollotarians eat eggs and dairy?", "answer": "Usually, yes — but it's a personal choice, not a rule. Most pollotarians include eggs, milk, yogurt, and cheese, which makes hitting protein, calcium, and B12 targets easier. Some exclude one or both for ethical or digestive reasons. If you skip eggs and dairy along with red meat and fish, plan more carefully around B12, calcium, and overall protein."}, {"question": "Is a pollotarian diet healthy?", "answer": "It can be very healthy when it's built on skinless poultry, vegetables, legumes, and whole grains. Replacing a daily serving of red meat with poultry was associated with a 19% lower risk of coronary heart disease in a 26-year Harvard cohort study, and dropping red and processed meat removes the food categories the WHO classifies as carcinogenic or probably carcinogenic. The caveats: fried and processed poultry erase much of the benefit, and a randomized trial found white meat raises LDL cholesterol similarly to red meat when saturated fat intake is high — so preparation and the plant half of the plate matter as much as the meat swap."}, {"question": "Can you lose weight on a pollotarian diet?", "answer": "Yes, but the diet doesn't create a calorie deficit automatically. It stacks the odds in your favor: skinless poultry is one of the leanest, most satiating proteins available, and the plant-forward plate is high in fiber and low in calorie density. In the Adventist Health Study-2, semi-vegetarians averaged a lower BMI (27.3) than nonvegetarians (28.8). To lose weight you still need a calorie deficit — the pollotarian framework just makes one easier to maintain."}, {"question": "What's the difference between a pollotarian and a pescatarian?", "answer": "They're mirror images. A pollotarian eats poultry but no fish; a pescatarian eats fish but no poultry. Both exclude red meat and pork, and both outperform standard omnivorous diets in cohort studies. Pescatarians get EPA and DHA omega-3s directly from fish, while pollotarians get a cheaper, more convenient everyday protein. People who eat both poultry and fish — but no red meat — are pesce-pollotarians."}, {"question": "Is eating chicken every day bad for you?", "answer": "For most healthy people, moderate daily poultry intake is fine — poultry isn't linked to the mortality or cancer risks associated with red and processed meat. Two caveats: a 2020 JAMA Internal Medicine analysis found a small association between poultry intake and cardiovascular disease (though not mortality), and an RCT found white meat raises LDL cholesterol more than plant proteins do. The practical answer is to make poultry a rotating player — a few meals per week — with legumes, eggs, and other plant proteins filling the rest, and to favor grilled or roasted over fried."}, {"question": "Can I follow a pollotarian diet while on semaglutide or other GLP-1 medications?", "answer": "Yes — it's one of the better-suited named diets for GLP-1 therapy. Lean poultry helps you hit the 1.0-1.5 g/kg/day protein target that protects muscle during rapid weight loss, and the plant-forward base supplies the 25-38g of daily fiber that counteracts GLP-1-related constipation. The one adjustment: avoid fried and heavily breaded poultry, which triggers nausea when gastric emptying is slowed by the medication."}, {"question": "Is pollotarianism better for the environment?", "answer": "Meaningfully better than a red-meat-heavy diet, though not as low-impact as vegetarian or vegan eating. The largest global food-systems analysis found beef generates roughly 10 times the greenhouse gas emissions of poultry per gram of protein, with far higher land and water use. Replacing beef and lamb with poultry and plants captures a large share of the footprint reduction available from dietary change."}];

const citations = [{"id": 1, "text": "Bernstein AM, et al. Major dietary protein sources and risk of coronary heart disease in women. Circulation. 2010;122(9):876-883.", "url": "https://pubmed.ncbi.nlm.nih.gov/20713902/"}, {"id": 2, "text": "Pan A, et al. Red meat consumption and mortality: results from 2 prospective cohort studies. Arch Intern Med. 2012;172(7):555-563.", "url": "https://pubmed.ncbi.nlm.nih.gov/22412075/"}, {"id": 3, "text": "Bouvard V, et al. Carcinogenicity of consumption of red and processed meat. Lancet Oncol. 2015;16(16):1599-1600.", "url": "https://pubmed.ncbi.nlm.nih.gov/26514947/"}, {"id": 4, "text": "Zhong VW, et al. Associations of processed meat, unprocessed red meat, poultry, or fish intake with incident cardiovascular disease and all-cause mortality. JAMA Intern Med. 2020;180(4):503-512.", "url": "https://pubmed.ncbi.nlm.nih.gov/32011623/"}, {"id": 5, "text": "Bergeron N, et al. Effects of red meat, white meat, and nonmeat protein sources on atherogenic lipoprotein measures: a randomized controlled trial. Am J Clin Nutr. 2019;110(1):24-33.", "url": "https://pubmed.ncbi.nlm.nih.gov/31161217/"}, {"id": 6, "text": "Tonstad S, et al. Type of vegetarian diet, body weight, and prevalence of type 2 diabetes. Diabetes Care. 2009;32(5):791-796.", "url": "https://pubmed.ncbi.nlm.nih.gov/19351712/"}, {"id": 7, "text": "Satija A, et al. Healthful and unhealthful plant-based diets and the risk of coronary heart disease in US adults. J Am Coll Cardiol. 2017;70(4):411-422.", "url": "https://pubmed.ncbi.nlm.nih.gov/28728684/"}, {"id": 8, "text": "Marangoni F, et al. Role of poultry meat in a balanced diet aimed at maintaining health and wellbeing: an Italian consensus document. Food Nutr Res. 2015;59:27606.", "url": "https://pubmed.ncbi.nlm.nih.gov/26065493/"}, {"id": 9, "text": "Poore J, Nemecek T. Reducing food's environmental impacts through producers and consumers. Science. 2018;360(6392):987-992.", "url": "https://pubmed.ncbi.nlm.nih.gov/29853680/"}, {"id": 10, "text": "Reynolds A, et al. Carbohydrate quality and human health: a series of systematic reviews and meta-analyses. Lancet. 2019;393(10170):434-445.", "url": "https://pubmed.ncbi.nlm.nih.gov/30638909/"}, {"id": 11, "text": "Hurrell R, Egli I. Iron bioavailability and dietary reference values. Am J Clin Nutr. 2010;91(5):1461S-1467S.", "url": "https://pubmed.ncbi.nlm.nih.gov/20200263/"}, {"id": 12, "text": "Wilding JPH, et al. Once-weekly semaglutide in adults with overweight or obesity (STEP 1). N Engl J Med. 2021;384(11):989-1002.", "url": "https://pubmed.ncbi.nlm.nih.gov/33567185/"}, {"id": 13, "text": "Wharton S, et al. Managing the gastrointestinal side effects of GLP-1 receptor agonists in obesity. Obesity (Silver Spring). 2022;30(1):17-22.", "url": "https://pubmed.ncbi.nlm.nih.gov/34936189/"}];

const foodsToEat = [{"category": "Poultry", "emoji": "🍗", "items": ["Chicken (breast, thighs, drumsticks, whole roasted — skinless most of the time)", "Turkey (breast, ground turkey, tenderloin)", "Duck, goose, quail, and other fowl (occasionally; higher in fat)", "Ground chicken or turkey for chili, tacos, burgers, and meatballs"]}, {"category": "Vegetables & Fruits", "emoji": "🥦", "items": ["All vegetables: leafy greens, broccoli, peppers, carrots, tomatoes, squash", "All fruits: berries, apples, citrus, bananas, melon", "Aim to fill half your plate here — this is where the fiber comes from", "Frozen counts: frozen vegetables and fruit are nutritionally equivalent and cheaper"]}, {"category": "Whole Grains & Legumes", "emoji": "🌾", "items": ["Oats, quinoa, brown rice, farro, barley, whole-grain bread and pasta", "Beans, lentils, chickpeas, and split peas (protein + fiber in one food)", "Starchy vegetables: potatoes, sweet potatoes, corn", "Target 25g+ of daily fiber from this group plus produce"]}, {"category": "Nuts, Seeds & Healthy Fats", "emoji": "🥑", "items": ["Walnuts, almonds, pistachios, and natural nut butters", "Chia, flax, and hemp seeds (plant omega-3 sources — important without fish)", "Extra virgin olive oil as the primary cooking fat", "Avocado and olives"]}, {"category": "Eggs & Dairy (Optional)", "emoji": "🥚", "items": ["Eggs — most pollotarians keep them; a cheap complete protein", "Greek yogurt, skyr, and cottage cheese (protein-dense choices)", "Milk, kefir, and cheese in moderation", "Fortified soy or other plant milks if you skip dairy (check for B12 and calcium)"]}];

const foodsToAvoid = [{"category": "Red Meat", "emoji": "🥩", "items": ["Beef in all forms: steak, ground beef, roasts", "Pork: chops, tenderloin, ribs", "Lamb, veal, goat, and mutton", "Game meats: venison, bison, elk, rabbit"]}, {"category": "Processed & Cured Meats", "emoji": "🥓", "items": ["Bacon, ham, and prosciutto", "Sausage, hot dogs, and pepperoni", "Beef jerky and cured deli meats", "This is the category with the strongest cancer-risk classification (IARC Group 1)"]}, {"category": "Fish & Seafood (Strict Version)", "emoji": "🐟", "items": ["All fish: salmon, tuna, cod, sardines", "Shellfish: shrimp, crab, lobster, oysters", "Excluded by strict pollotarians only — keeping fish makes you a pesce-pollotarian", "If you drop fish, plan an alternate omega-3 source (algae oil, walnuts, chia, flax)"]}, {"category": "Technically Allowed, Worth Limiting", "emoji": "🍟", "items": ["Fried chicken, wings, nuggets, and breaded patties", "Processed poultry deli slices (high sodium, often cured)", "Refined grains, sweets, and sugary drinks — 'plant-based' junk is still junk", "Poultry skin as a daily habit (fine occasionally, adds mostly saturated fat)"]}];

const tocItems = [{"id": "what-is", "title": "What Is Pollotarianism?"}, {"id": "why-pollotarian", "title": "Why People Go Pollotarian"}, {"id": "scorecard", "title": "Diet Scorecard"}, {"id": "macro-profile", "title": "Macro & Nutrition Profile"}, {"id": "foods-to-eat", "title": "Pollotarian Food List: What You Can Eat"}, {"id": "foods-to-avoid", "title": "Foods Pollotarians Avoid"}, {"id": "meal-plan", "title": "Sample One-Day Pollotarian Meal Plan"}, {"id": "health-benefits", "title": "Health Benefits & Evidence"}, {"id": "risks", "title": "Risks & Downsides"}, {"id": "how-to-start", "title": "How to Start a Pollotarian Diet"}, {"id": "glp1-compatibility", "title": "GLP-1 Compatibility"}, {"id": "vs-other-diets", "title": "Pollotarian vs. Pescatarian, Flexitarian & More"}, {"id": "faq", "title": "FAQ"}, {"id": "bottom-line", "title": "The Bottom Line"}, {"id": "references", "title": "References"}];

const relatedLinks = [{"url": "/semaglutide-diet/", "label": "Semaglutide Diet: Complete Guide for Weight Loss"}, {"url": "/stillman-diet/", "label": "The Stillman Diet: History, Risks, and Why Modern Medicine Moved On"}, {"url": "/foods-that-lower-testosterone/", "label": "Foods That Lower Testosterone: Separating Myth from Evidence"}, {"url": "/peptides-for-weight-loss/", "label": "Peptides for Weight Loss: GLP-1, GH Secretagogues, and Fat-Loss Protocols"}, {"url": "/dexa-scan/", "label": "DEXA Scan: The Gold Standard for Body Composition Analysis"}];

// Match the diet-article pattern: FAQPage schema wrapped in an @graph envelope.
const { ["@context"]: _ctx, ...faqNoCtx } = faqPageSchema(faqs) as Record<string, unknown>;
const structuredData = { "@context": "https://schema.org", "@graph": [faqNoCtx] };
---

<BlogArticleLayout
  title="Pollotarianism: The Complete Guide to the Pollotarian Diet (2026)"
  seoTitle="Pollotarian Diet: Benefits, Foods & Plan"
  subtitle="Poultry stays, every other meat goes. What the research actually shows about the pollotarian diet, what to eat, and how to decide whether this semi-vegetarian approach fits your health goals."
  seoDescription="Pollotarianism explained: what pollotarians eat, evidence-based benefits of a poultry-only meat diet, full food list, sample meal plan, and comparisons."
  path={path}
  author={author}
  reviewer={reviewer}
  datePublishedISO="2026-07-18"
  dateModifiedISO="2026-07-18"
  readTime="15 min"
  tocItems={tocItems}
  faqs={faqs}
  citations={citations}
  relatedLinks={relatedLinks}
  structuredData={structuredData}
  ctaHeading="Changing Your Diet for a Health Goal?"
  ctaText="Get baseline labs and a physician's read on your plan before you start. Our doctors build evidence-based nutrition and treatment plans around your body, not a template."
  ctaButtonText="Book Your Free Assessment →"
>
  <Fragment set:html={body0} />
  <AccordionFoodList groups={foodsToEat} variant="eat" />
  <Fragment set:html={body1} />
  <AccordionFoodList groups={foodsToAvoid} variant="avoid" />
  <Fragment set:html={body2} />
</BlogArticleLayout>
