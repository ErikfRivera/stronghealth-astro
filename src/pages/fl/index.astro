---
// /fl/ — port of src/pages/local/FloridaHub.tsx (source monorepo).
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageShell from "../../components/shared/PageShell.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import {
  breadcrumbSchema,
  collectionPageSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from "../../components/seo/schemas";
import FadeIn from "../../components/shared/FadeIn.astro";
import Btn from "../../components/shared/Btn.astro";
import Tag from "../../components/shared/Tag.astro";
import Icon from "../../components/shared/Icon.astro";
import { ALL_CITIES } from "../../data/local/cityTrtConfig";

const breadcrumbs = [
  { name: "Home", path: "/" },
  { name: "Florida", path: "/fl/" },
];

const REGIONS = [
  {
    name: "Miami-Dade County",
    cities: ["miami"],
  },
  {
    name: "Palm Beach County",
    cities: ["delray-beach"],
  },
];

const services = [
  {
    name: "Testosterone Replacement Therapy",
    desc: "Physician-supervised TRT with in-person exams, 50+ biomarker labs, and FDA-approved medications. Available at our Miami and Delray Beach clinics.",
    href: "/fl/miami/trt-therapy/",
    cta: "Learn about TRT in Miami →",
  },
  {
    name: "Medical Weight Loss (GLP-1)",
    desc: "Physician-supervised semaglutide and tirzepatide programs with full metabolic workups and ongoing monitoring.",
    href: "/fl/miami/weight-loss-clinic/",
    cta: "Learn about weight loss in Miami →",
  },
  {
    name: "Comprehensive Lab Testing",
    desc: "50+ biomarker hormone panels, including total and free testosterone, SHBG, estradiol, thyroid, and metabolic markers.",
    href: "/services/",
    cta: "All services →",
  },
  {
    name: "Peptide Therapy",
    desc: "Evidence-based peptide protocols for healing, recovery, sleep, and longevity, with physician oversight. Available at our Miami and Delray Beach clinics.",
    href: "/fl/miami/peptide-therapy/",
    cta: "Learn about peptide therapy →",
  },
  {
    name: "DEXA Scan (Body Composition)",
    desc: "Clinical DEXA scan body composition and bone density analysis at our Brickell clinic. Lean mass, body fat %, visceral fat, and bone density with a 1–2% margin of error.",
    href: "/fl/miami/dexascan/",
    cta: "DEXA Scan in Miami →",
  },
];

const STATEWIDE_FAQS = [
  {
    question: "Where are Strong Health's Florida clinics located?",
    answer:
      "Strong Health operates two clinics in South Florida: Miami (Brickell, at 1000 Brickell Plaza) and Delray Beach (Atlantic Avenue). Coverage spans Miami-Dade and Palm Beach counties. Telehealth follow-ups are available statewide after an in-person baseline visit at either clinic.",
  },
  {
    question: "Do both Strong Health Florida clinics offer the same services?",
    answer:
      "Yes. Both Strong Health clinics offer the same core services: physician-supervised testosterone replacement therapy (TRT), comprehensive 50+ biomarker hormone lab panels (drawn on-site), medical weight loss programs, peptide therapy, and ongoing telehealth follow-ups. Both clinics are staffed by board-certified physicians and follow the same evidence-based clinical protocols. DEXA scan body-composition imaging is offered at the Miami (Brickell) clinic.",
  },
  {
    question: "Can I do my initial visit at one Florida clinic and follow-ups at the other?",
    answer:
      "Yes. Once you've completed your initial in-person assessment and labs at either Strong Health clinic, you can do follow-up labs and in-person visits at the other location. Telehealth follow-ups travel with you regardless of which clinic you originally visited.",
  },
  {
    question: "Are Strong Health Florida clinics bilingual?",
    answer:
      "Yes. Both Strong Health clinics offer bilingual care in English and Spanish, reflecting the communities we serve across South Florida. Our Miami (Brickell) clinic has multiple Spanish-speaking team members including the Medical Director.",
  },
  {
    question: "Does Strong Health accept insurance at its Florida clinics?",
    answer:
      "Strong Health operates on a transparent direct-pay model at both Florida clinics. We do not bill insurance directly, but we provide itemized superbills that many patients submit for partial reimbursement under plans common in Florida, including Florida Blue, Aetna, UnitedHealthcare, and Cigna. The direct-pay model keeps care affordable and free from insurance-driven restrictions on lab work and treatment options.",
  },
  {
    question: "Are Saturday appointments available at Strong Health Florida clinics?",
    answer:
      "Yes. Both Strong Health Florida clinics offer Saturday morning appointments from 9:00 AM to 1:00 PM, in addition to weekday hours from 8:00 AM to 6:00 PM. Saturday hours are designed for working professionals, tradespeople, and shift workers who can't easily make weekday appointments.",
  },
  {
    question: "Is testosterone replacement therapy legal in Florida?",
    answer:
      "Yes, when prescribed and supervised by a licensed physician. In Florida, testosterone is a Schedule III controlled substance, which means it requires physician oversight, a documented medical need based on lab work and symptoms, and ongoing monitoring. Strong Health follows all Florida regulations and works only with FDA-approved medications dispensed through licensed pharmacies.",
  },
  {
    question: "Are Strong Health Florida clinics open to seasonal residents and snowbirds?",
    answer:
      "Yes. Strong Health serves a large population of seasonal residents who split time between Florida and other states or countries, particularly around the Delray Beach and Aventura/North Miami markets. Telehealth follow-ups travel with you, and we coordinate refills with pharmacies near wherever you happen to be. Initial in-person visits and quarterly labs can be scheduled around your time in Florida.",
  },
];

const cityItems = ALL_CITIES.flatMap((c) => [
  {
    name: `Strong Health ${c.name} — TRT Therapy`,
    url: `/fl/${c.slug}/trt-therapy/`,
  },
  {
    name: `Strong Health ${c.name} — Weight Loss Clinic`,
    url: `/fl/${c.slug}/weight-loss-clinic/`,
  },
]);
---

<BaseLayout
  title="South Florida TRT & Men's Health Clinics"
  description="Physician-supervised testosterone therapy at Strong Health's Miami (Brickell) and Delray Beach (Atlantic Avenue) clinics."
  path="/fl/"
>
  <PageShell>
    <JsonLd
      schema={medicalWebPageSchema({
        name: "Strong Health Florida — TRT & Men's Health Clinics in Miami and Delray Beach",
        description:
          "Physician-supervised testosterone therapy at Strong Health clinics in Miami (Brickell) and Delray Beach (Atlantic Avenue). Coverage across Miami-Dade and Palm Beach counties.",
        url: "/fl/",
        lastReviewed: "2026-04-01",
        reviewedBy: {
          name: "Dr. Angel Rivera, M.D.",
          credentials: "Board-Certified",
          role: "Medical Director — Strong Health",
        },
      })}
    />
    <JsonLd
      schema={collectionPageSchema({
        name: "Strong Health Florida Locations",
        description: "Strong Health TRT clinics across South Florida",
        url: "/fl/",
        items: cityItems,
      })}
    />
    <JsonLd schema={faqPageSchema(STATEWIDE_FAQS)} />
    <JsonLd schema={breadcrumbSchema(breadcrumbs)} />

    {/* Breadcrumbs */}
    <nav aria-label="Breadcrumb" class="px-8 pt-4 pb-0">
      <div class="max-w-[1000px] mx-auto">
        <ol class="flex items-center gap-1.5 text-[12px] text-muted">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <Icon name="chevron-right" size={12} class="text-text-subtle" />}
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.path} class="hover:text-gold transition-colors">
                  {crumb.name}
                </a>
              ) : (
                <span class="text-gold font-semibold">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>

    {/* Hero */}
    <section class="relative px-8 pt-12 pb-20 overflow-hidden border-b border-white/5">
      <div aria-hidden="true" class="hidden md:block absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-navy/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div aria-hidden="true" class="hidden md:block absolute bottom-0 right-1/4 translate-x-1/2 translate-y-1/4 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="max-w-[1000px] mx-auto relative z-10">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-[#C9A84C] text-gold" />)}
          </div>
          <span class="text-sm font-bold text-gold">4.9</span>
          <span class="text-[13px] text-muted">from 1,000+ Florida patient reviews</span>
        </div>
        <Tag>Strong Health Florida · Miami & Delray Beach Clinics</Tag>
        <h1 class="text-4xl md:text-[52px] font-black text-cream leading-[1.08] mt-6 mb-5 max-w-[760px] tracking-[-1.5px]">
          Strong Health clinics in <span class="text-gold">Miami and Delray Beach.</span>
        </h1>
        <p class="text-[17px] text-muted leading-relaxed max-w-[600px] mb-8">
          Physician-supervised testosterone replacement therapy and men's hormone health, with
          in-person clinics in Miami-Dade and Palm Beach counties. Find the location nearest you.
        </p>
        <Btn trackLead>Book Your Free Assessment →</Btn>
        <div class="mt-4 text-xs text-muted">
          No commitment · No insurance needed · 15–20 min in-person visit
        </div>
      </div>
    </section>

    {/* LocationsByRegion */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Find Your Clinic</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Strong Health locations across <span class="text-gold">South Florida</span>
          </h2>
          <p class="text-[15px] text-muted max-w-[560px] mx-auto">
            Each clinic offers in-person physician visits, on-site lab draws, and ongoing
            telehealth follow-ups. Pick the location closest to you to get started.
          </p>
        </FadeIn>

        <div class="flex flex-col gap-10">
          {REGIONS.map((region) => (
            <FadeIn>
              <div>
                <h3 class="text-[20px] font-bold text-cream mb-4 flex items-center gap-2">
                  <Icon name="map-pin" size={18} class="text-gold" />
                  {region.name}
                </h3>
                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
                  {region.cities.map((slug) => {
                    const city = ALL_CITIES.find((c) => c.slug === slug)!;
                    return (
                      <div class="bg-surface-raised rounded-xl p-5 border border-white/10 flex flex-col gap-1.5">
                        <div class="text-[15px] font-bold text-cream">
                          {city.clinicName}
                        </div>
                        <div class="flex items-center gap-1.5 text-[12px] text-cream-muted">
                          <Icon name="map-pin" size={11} class="text-gold flex-shrink-0" />
                          <span>{city.area}, {city.name}, FL</span>
                        </div>
                        <div class="flex items-center gap-1.5 text-[12px] text-cream-muted">
                          <Icon name="phone" size={11} class="text-gold flex-shrink-0" />
                          <span>{city.phone}</span>
                        </div>
                        <div class="flex flex-col gap-1.5 mt-2 pt-2 border-t border-white/5">
                          <a
                            href={`/fl/${slug}/trt-therapy/`}
                            class="text-[12px] text-gold font-semibold hover:underline"
                          >
                            TRT Therapy →
                          </a>
                          <a
                            href={`/fl/${slug}/weight-loss-clinic/`}
                            class="text-[12px] text-gold font-semibold hover:underline"
                          >
                            Weight Loss Clinic →
                          </a>
                          <a
                            href={`/fl/${slug}/peptide-therapy/`}
                            class="text-[12px] text-gold font-semibold hover:underline"
                          >
                            Peptide Therapy →
                          </a>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* ServicesOverview */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Services Across All Florida Locations</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            Real medicine. <span class="text-gold">Same standard, every clinic.</span>
          </h2>
        </FadeIn>
        <div class="grid md:grid-cols-2 gap-5">
          {services.map((s, i) => (
            <FadeIn delay={i * 80}>
              <div class="bg-surface-card rounded-2xl p-6 border border-white/10 h-full flex flex-col">
                <h3 class="text-lg font-bold text-cream mb-3">{s.name}</h3>
                <p class="text-[14px] text-muted leading-relaxed flex-grow mb-4">{s.desc}</p>
                <a href={s.href} class="text-[13px] font-semibold text-gold hover:underline">
                  {s.cta}
                </a>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* WhyFlorida */}
    <section class="px-8 py-20 bg-surface-card border-b border-white/5">
      <div class="max-w-[1000px] mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <FadeIn>
            <Tag>Built for South Florida</Tag>
            <h2 class="text-[32px] font-extrabold text-cream leading-[1.15] mt-4 mb-4">
              Why we built Strong Health <span class="text-gold">in South Florida</span>
            </h2>
            <div class="text-[15px] text-muted leading-[1.8] flex flex-col gap-4">
              <p>
                South Florida has no shortage of clinics offering testosterone. What it lacked was
                a physician-led practice that treats hormone health as real medicine:
                comprehensive diagnostics, board-certified physicians, and ongoing monitoring, on
                a transparent direct-pay model that doesn't require an annual concierge membership
                or a recurring supplement subscription.
              </p>
              <p>
                We started in Miami's Brickell neighborhood and expanded north to Delray Beach to
                serve Palm Beach County patients who were driving down for visits. Both clinics
                share the same staff training, the same clinical protocols, and the same Saturday
                hours for working professionals.
              </p>
              <p>
                Whether you work in Brickell or live near Atlantic Avenue in Delray, your closest
                clinic is in-person and physician-staffed.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-surface-raised rounded-2xl p-8 border border-white/10">
              <h3 class="text-lg font-bold text-cream mb-5">The same standard, both clinics</h3>
              <div class="text-[14px] text-cream-muted leading-[1.7] flex flex-col gap-3">
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Board-certified physicians at both locations</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>50+ biomarker lab panel drawn on-site</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Real physical exam on day one</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>FDA-approved medications. No supplements, no gray-market compounds</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Telehealth follow-ups after your in-person baseline</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Bilingual care (English & Spanish)</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-gold font-bold">·</span>
                  <span>Month-to-month treatment. No long-term contracts</span>
                </div>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    {/* FAQSection */}
    <section class="px-8 py-20 bg-surface border-b border-white/5">
      <div class="max-w-[800px] mx-auto">
        <FadeIn class="text-center mb-10">
          <Tag>Statewide FAQs</Tag>
          <h2 class="text-[34px] font-extrabold text-cream mt-4 mb-3">
            About Strong Health <span class="text-gold">in Florida</span>
          </h2>
        </FadeIn>
        <div class="flex flex-col gap-4">
          {STATEWIDE_FAQS.map((faq, i) => (
            <FadeIn delay={i * 40}>
              <details class="bg-surface-card rounded-xl border border-white/10 group">
                <summary class="cursor-pointer p-5 list-none flex items-start justify-between gap-4">
                  <h3 class="text-[15px] font-bold text-cream pr-2">{faq.question}</h3>
                  <Icon
                    name="chevron-right"
                    size={18}
                    class="text-gold flex-shrink-0 transition-transform group-open:rotate-90 mt-0.5"
                  />
                </summary>
                <div class="px-5 pb-5 text-[14px] text-muted leading-[1.7]">{faq.answer}</div>
              </details>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    {/* FinalCTA */}
    <section class="px-8 py-24 bg-gradient-to-br from-[#C9A84C]/[0.08] to-[#0D0F12] border-b border-white/5">
      <div class="max-w-[700px] mx-auto text-center">
        <FadeIn>
          <h2 class="text-[36px] font-black text-cream leading-[1.1] mb-4">
            Find your closest Strong Health clinic
          </h2>
          <p class="text-[17px] text-muted leading-relaxed mb-8 max-w-[520px] mx-auto">
            Two locations across Miami-Dade and Palm Beach counties. Pick the one nearest you and
            book a free assessment with a board-certified physician.
          </p>
          <div class="flex items-center justify-center gap-2 mb-6 text-[13px] text-muted">
            <Icon name="phone" size={14} class="text-gold" />
            <span>Or call either clinic directly</span>
          </div>
          <Btn trackLead>Book Your Free Assessment →</Btn>
        </FadeIn>
      </div>
    </section>
  </PageShell>
</BaseLayout>
