const faqs = [{"question": "Do peptides help with anxiety?", "answer": "Selank is studied as a non-sedating anxiolytic, and a small Russian clinical study found it comparable to a benzodiazepine for generalized anxiety. The evidence is early and limited, so it’s considered an adjunct to — not a replacement for — established anxiety care."}, {"question": "Is Selank a nootropic?", "answer": "It’s studied for both anxiety reduction and cognitive support, partly through proposed effects on BDNF and monoamine signaling. Calling it a “nootropic” overstates a still-early evidence base; think of it as a promising compound under investigation."}, {"question": "Is Selank addictive like benzodiazepines?", "answer": "Available research reports no sedation, dependence, or withdrawal with Selank, which is part of its appeal. But human data are limited, so it’s still prescribed carefully and coordinated with any existing treatment."}, {"question": "Can peptides replace my anxiety or depression medication?", "answer": "No. Peptides are not a substitute for evidence-based mental-health treatment. Never stop prescribed medication on your own; any addition or change should be made with your prescribing clinician."}, {"question": "Are brain peptides FDA-approved?", "answer": "No. Selank and related peptides are not FDA-approved in the U.S. Where used, they’re physician-prescribed, pharmacy-compounded preparations — and best considered alongside, not instead of, established care."}];

